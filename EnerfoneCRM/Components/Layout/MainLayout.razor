@inherits LayoutComponentBase
@using EnerfoneCRM.Services
@inject EnerfoneCRM.Services.EnvironmentService EnvService
@inject EnerfoneCRM.Services.AuthService AuthService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="page">
    <NavMenu />

    <main class="main-content">
        <article class="content-wrapper">
            @Body
        </article>
        <Footer />
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Cargar sesión solo UNA VEZ cuando la app se carga
            await AuthService.CargarSesionAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        // Limpieza si es necesaria
    }
}
