                            <i class="bi bi-briefcase me-2" style="font-size: 1.4rem; vertical-align: middle; color: #66BB6A;"></i>Gestiones
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownGestiones">
                            @if (AuthService.PuedeVerLiquidaciones)
                            {
                                <li><a class="dropdown-item" href="liquidaciones"><i class="bi bi-cash-coin me-2" style="color: #4CAF50;"></i>Liquidaciones</a></li>
                            }
                            @if (AuthService.PuedeVerOfertas)
                            {
                                <li><a class="dropdown-item" href="ofertas"><i class="bi bi-tag me-2" style="color: #FF9800;"></i>Ofertas</a></li>
                            }
                            <li><a class="dropdown-item" href="noticias"><i class="bi bi-megaphone me-2" style="color: #03A9F4;"></i>Noticias</a></li>
                            <li><a class="dropdown-item" href="proximamente"><i class="bi bi-arrow-repeat me-2" style="color: #2196F3;"></i>Renovaciones</a></li>
                            <li><a class="dropdown-item" href="repositorio"><i class="bi bi-folder-fill me-2" style="color: #EF5350;"></i>Repositorio</a></li>
                            @if (AuthService.PuedeVerSips)
                            {
                                <li><a class="dropdown-item" href="sips"><i class="bi bi-credit-card me-2" style="color: #9C27B0;"></i>SIPS</a></li>
                            }
                        </ul>
                    </li>

                    @if (AuthService.EsAdministrador)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3 py-2 rounded transition" href="#" id="navbarDropdownContabilidad" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="transition: all 0.3s ease;">
                                <i class="bi bi-calculator me-2" style="font-size: 1.4rem; vertical-align: middle; color: #9C27B0;"></i>Contabilidad
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownContabilidad">
                                <li><a class="dropdown-item" href="proximamente"><i class="bi bi-file-earmark-text me-2" style="color: #3F51B5;"></i>Presupuestos</a></li>
                                <li><a class="dropdown-item" href="proximamente"><i class="bi bi-receipt me-2" style="color: #4CAF50;"></i>Facturas venta</a></li>
                                <li><a class="dropdown-item" href="proximamente"><i class="bi bi-people me-2" style="color: #FF5722;"></i>Proveedores</a></li>
                                <li><a class="dropdown-item" href="proximamente"><i class="bi bi-file-earmark-minus me-2" style="color: #F44336;"></i>Facturas compra</a></li>
                            </ul>
                        </li>
                    }
                    
                    @if (AuthService.EsAdministrador || AuthService.EsBackoffice)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3 py-2 rounded transition" href="#" id="navbarDropdownConfiguracion" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="transition: all 0.3s ease;" title="Configuración">
                                <i class="bi bi-sliders" style="font-size: 1.4rem; vertical-align: middle; color: #BDBDBD;"></i>
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownConfiguracion">
                                <li class="dropdown-submenu">
                                    <a class="dropdown-item dropdown-toggle" href="javascript:void(0);" id="navbarDropdownUsuarios" role="button" aria-expanded="false">
                                        <i class="bi bi-person-badge-fill me-2" style="color: #42A5F5;"></i>Usuarios
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownUsuarios">
                                        @if (AuthService.EsAdministrador)
                                        {
                                            <li><a class="dropdown-item" href="usuarios"><i class="bi bi-people-fill text-primary me-2"></i>Gestión Usuarios</a></li>
                                        }
                                        <li><a class="dropdown-item" href="tareas"><i class="bi bi-list-check text-success me-2"></i>Tareas</a></li>
                                    </ul>
                                </li>
                                <li><a class="dropdown-item" href="inicio-rapido"><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Inicio Rápido</a></li>
                                <li><a class="dropdown-item" href="configuracion-empresa"><i class="bi bi-building me-2"></i>Datos de Empresa</a></li>
                                <li><a class="dropdown-item" href="configuracion-comisiones"><i class="bi bi-percent me-2 text-success"></i>Configuración de Comisiones</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white px-3 py-2 rounded transition" href="tareas" style="transition: all 0.3s ease;">
                                <i class="bi bi-list-check me-2" style="font-size: 1.4rem; vertical-align: middle; color: #66BB6A;"></i>Tareas
                            </a>
                        </li>
                    }
                </ul>

                <div class="d-flex align-items-center text-white">
                    @if (AuthService.PuedeVerContratos)
                    {
                        <button @onclick="MostrarAvisosModificaciones" class="me-3 btn-avisos-contratos" style="display: flex; align-items: center; justify-content: center; gap: 3px; width: 80px; height: 50px; border: 2px solid #9E9E9E; border-radius: 8px; background: transparent; text-decoration: none; transition: all 0.3s ease; position: relative; cursor: pointer; padding: 0;" title="Avisos de Modificaciones">
                            <i class="bi bi-bell-fill" style="font-size: 0.85rem; color: #FFD54F; margin: 0; padding: 0; line-height: 1;"></i>
                            <i class="bi bi-bell-fill" style="font-size: 0.85rem; color: #4FC3F7; margin: 0; padding: 0; line-height: 1;"></i>
                            <i class="bi bi-bell-fill" style="font-size: 0.85rem; color: #EF5350; margin: 0; padding: 0; line-height: 1;"></i>
                            @if (hayModificacionesNoVistas)
                            {
                                <span class="badge bg-danger" style="position: absolute; top: -5px; right: -5px; font-size: 0.6rem; padding: 3px 5px;">!</span>
                            }
                        </button>
                    }
                    @if (AuthService.PuedeVerIncidencias)
                    {
                        <a href="incidencias" class="me-3 btn-incidencia" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: 2px solid #ffc107; border-radius: 8px; background: transparent; text-decoration: none; transition: all 0.3s ease;" title="Gestión de Incidencias">
                            <i class="bi bi-exclamation-triangle-fill" style="font-size: 1.1rem; color: #ffc107; margin: 0; padding: 0; line-height: 1;"></i>
                        </a>
                    }
                    
                    <!-- Menú de usuario con dropdown -->
                    <div class="dropdown me-3">
                        <button class="btn btn-link text-white text-decoration-none d-flex align-items-center" 
                                type="button" 
                                id="userMenuDropdown" 
                                data-bs-toggle="dropdown" 
                                aria-expanded="false"
                                style="padding: 8px 16px; background: rgba(255, 255, 255, 0.1); border-radius: 8px; backdrop-filter: blur(10px); border: none;">
                            <i class="bi bi-person-circle me-2" style="font-size: 1.2rem;"></i>
                            <div class="d-none d-md-block">
                                <div style="font-size: 0.9rem; font-weight: 500; text-align: left;">@AuthService.UsuarioActual?.NombreUsuario</div>
                                <div style="font-size: 0.75rem; opacity: 0.8; text-align: left;">@AuthService.UsuarioActual?.Rol</div>
                            </div>
                            <i class="bi bi-chevron-down ms-2" style="font-size: 0.8rem;"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
                            <li>
                                <a class="dropdown-item" href="/mi-perfil">
                                    <i class="bi bi-person-circle me-2"></i>Mi Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/cambiar-password">
                                    <i class="bi bi-key me-2"></i>Cambiar Contraseña
                                </a>
                            </li>
                        </ul>
                    </div>
                    
                    <!-- Botón cerrar sesión separado -->
                    <button class="btn btn-link text-white text-decoration-none" 
                            @onclick="Logout"
                            style="padding: 8px 12px; background: rgba(220, 53, 69, 0.2); border-radius: 8px; border: 1px solid rgba(220, 53, 69, 0.5);">
                        <i class="bi bi-box-arrow-right me-1"></i>
                        <span class="d-none d-md-inline">Salir</span>
                    </button>
                </div>
            }
        </div>
    </div>
</nav>

<!-- Modal de Avisos de Modificaciones -->
@if (mostrarModalAvisos)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); color: white;">
                    <h5 class="modal-title">
                        <i class="bi bi-bell-fill text-warning me-2"></i>
                        Contratos Modificados Recientemente
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalAvisos"></button>
                </div>
                <div class="modal-body">
                    @if (cargandoModificaciones)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-3 text-muted">Cargando modificaciones...</p>
                        </div>
                    }
                    else if (!contratosModificados.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            No hay contratos modificados recientemente
                        </div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var contrato in contratosModificados)
                            {
                                <button class="list-group-item list-group-item-action" @onclick="async () => await IrAContrato(contrato)">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center mb-1">
                                                @{
                                                    var tipoLower = contrato.Tipo?.ToLower() ?? "";
                                                }
                                                @if (tipoLower == "energia" || tipoLower == "energía")
                                                {
                                                    <i class="bi bi-lightning-charge-fill text-warning me-2" style="font-size: 1.2rem;"></i>
                                                }
                                                else if (tipoLower == "telefonia" || tipoLower == "telefonía")
                                                {
                                                    <i class="bi bi-telephone-fill text-primary me-2" style="font-size: 1.2rem;"></i>
                                                }
                                                else if (tipoLower == "alarma" || tipoLower == "alarmas")
                                                {
                                                    <i class="bi bi-shield-check text-danger me-2" style="font-size: 1.2rem;"></i>
                                                }
                                                <h6 class="mb-0">
                                                    <strong>Contrato #@contrato.Id</strong> - @contrato.NombreCliente
                                                </h6>
                                            </div>
                                            <p class="mb-1 text-muted" style="font-size: 0.9rem;">
                                                <strong>Estado:</strong> @contrato.Estado | 
                                                <strong>Comercial:</strong> @contrato.Comercial
                                            </p>
                                            @if (!string.IsNullOrEmpty(contrato.Direccion))
                                            {
                                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">
                                                    <i class="bi bi-geo-alt me-1"></i>@contrato.Direccion
                                                </p>
                                            }
                                        </div>
                                        <div class="text-end ms-3">
                                            <small class="text-muted d-block">
                                                <i class="bi bi-clock me-1"></i>
                                                @contrato.FechaModificacion?.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                            <span class="badge bg-primary mt-1">Ver contrato</span>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalAvisos">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .nav-link:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
    }

    .btn-incidencia:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
    }

    .btn-avisos-contratos:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
    }

    .dropdown-menu {
        background-color: #2d2d2d;
        border: none !important;
    }

    .dropdown-item {
        color: #fff;
        transition: all 0.3s ease;
        border: none !important;
        border-top: none !important;
        border-bottom: none !important;
    }

    .dropdown-item:hover {
        background-color: rgba(255, 255, 255, 0.1);
        color: #fff;
    }

    /* Eliminar separadores entre elementos */
    .dropdown-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
    }

    /* Estilos para submenús multinivel */
    .dropdown-submenu {
        position: relative;
        border: none !important;
    }

    /* En escritorio, submenús a la derecha */
    @@media (min-width: 992px) {
        .dropdown-submenu .dropdown-menu {
            top: 0;
            left: 100%;
            margin-top: -1px;
            margin-left: 0;
            border: none !important;
            display: none;
        }

        .dropdown-submenu .dropdown-menu.show {
            display: block;
        }
    }
    
    /* En móvil, submenús horizontales debajo */
    @@media (max-width: 991.98px) {
        .dropdown-submenu .dropdown-menu {
            position: static !important;
            display: none;
        }
        
        .dropdown-submenu .dropdown-menu.show {
            display: flex !important;
        }
    }

    .dropdown-submenu > .dropdown-item::after {
        content: "\f285";
        font-family: "bootstrap-icons";
        float: right;
        margin-left: 10px;
        border: none !important;
    }

    /* Eliminar cualquier borde en los items de lista */
    .dropdown-menu li {
        border: none !important;
        border-top: none !important;
        border-bottom: none !important;
    }
</style>

@code {
    private bool cargado = false;
    private string? logoUrl;
    private bool mostrarModalAvisos = false;
    private bool cargandoModificaciones = false;
    private bool hayModificacionesNoVistas = false;
    private List<Contrato> contratosModificados = new();
    private const string STORAGE_KEY = "contratos_vistos_v2";
    private System.Timers.Timer? verificacionTimer;

    protected override void OnInitialized()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !cargado)
        {
            Console.WriteLine("[NavMenu] Iniciando componente NavMenu");
            await AuthService.CargarSesionAsync();
            await CargarLogoAsync();
            await VerificarModificacionesNoVistas();
            
            // Iniciar timer para verificar cada 30 segundos
            if (AuthService.PuedeVerContratos)
            {
                Console.WriteLine("[NavMenu] Timer iniciado - verificará cada 30 segundos");
                verificacionTimer = new System.Timers.Timer(30000); // 30 segundos
                verificacionTimer.Elapsed += async (sender, e) => await OnTimerElapsed();
                verificacionTimer.AutoReset = true;
                verificacionTimer.Start();
            }
            else
            {
                Console.WriteLine("[NavMenu] Timer NO iniciado - usuario no puede ver contratos");
            }
            
            cargado = true;
            StateHasChanged();
        }
    }

    private async Task OnTimerElapsed()
    {
        Console.WriteLine("[NavMenu] ⏰ Timer ejecutado - verificando modificaciones...");
        await InvokeAsync(async () =>
        {
            await VerificarModificacionesNoVistas();
            StateHasChanged();
        });
    }

    private async Task CargarLogoAsync()
    {
        try
        {
            var configuracion = await ConfiguracionService.ObtenerConfiguracionAsync();
            logoUrl = configuracion?.LogoUrl;
        }
        catch (Exception)
        {
            logoUrl = null;
        }
    }

    private async Task VerificarModificacionesNoVistas()
    {
        try
        {
            if (AuthService.PuedeVerContratos)
            {
                var contratosEnergia = await ContratoService.ObtenerTodosPorTipoAsync("energia", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
                var contratosTelefonia = await ContratoService.ObtenerTodosPorTipoAsync("telefonia", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
                var contratosAlarmas = await ContratoService.ObtenerTodosPorTipoAsync("alarma", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
                
                Console.WriteLine($"[NavMenu] Contratos obtenidos - Energía: {contratosEnergia.Count()}, Telefonía: {contratosTelefonia.Count()}, Alarmas: {contratosAlarmas.Count()}");
                
                var todosContratos = contratosEnergia.Concat(contratosTelefonia).Concat(contratosAlarmas)
                    .Where(c => c.FechaModificacion.HasValue)
                    .OrderByDescending(c => c.FechaModificacion)
                    .Take(20)
                    .ToList();

                Console.WriteLine($"[NavMenu] Total contratos con FechaModificacion: {todosContratos.Count}");
                
                // Obtener contratos vistos con sus fechas de modificación
                var contratosVistos = await SessionStorage.GetItemAsync<Dictionary<int, DateTime>>(STORAGE_KEY) ?? new Dictionary<int, DateTime>();
                
                Console.WriteLine($"[NavMenu] Contratos vistos en storage: {contratosVistos.Count}");
                
                // Verificar si hay contratos nuevos o modificados después de ser vistos
                hayModificacionesNoVistas = todosContratos.Any(c => 
                    !contratosVistos.ContainsKey(c.Id) || 
                    (c.FechaModificacion.HasValue && contratosVistos[c.Id] < c.FechaModificacion.Value));
                
                Console.WriteLine($"[NavMenu] Hay modificaciones no vistas: {hayModificacionesNoVistas}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] Error en VerificarModificacionesNoVistas: {ex.Message}");
            hayModificacionesNoVistas = false;
        }
    }

    private async Task MostrarAvisosModificaciones()
    {
        mostrarModalAvisos = true;
        cargandoModificaciones = true;
        StateHasChanged();

        try
        {
            var contratosEnergia = await ContratoService.ObtenerTodosPorTipoAsync("energia", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
            var contratosTelefonia = await ContratoService.ObtenerTodosPorTipoAsync("telefonia", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
            var contratosAlarmas = await ContratoService.ObtenerTodosPorTipoAsync("alarma", AuthService.UsuarioActual?.Rol, AuthService.UsuarioActual?.NombreUsuario, AuthService.UsuarioActual?.Id);
            
            var todosContratos = contratosEnergia.Concat(contratosTelefonia).Concat(contratosAlarmas);
            contratosModificados = todosContratos
                .Where(c => c.FechaModificacion.HasValue)
                .OrderByDescending(c => c.FechaModificacion)
                .Take(20)
                .ToList();

            Console.WriteLine($"[NavMenu] Modal abierto - Contratos modificados a mostrar: {contratosModificados.Count}");
            foreach (var c in contratosModificados)
            {
                Console.WriteLine($"[NavMenu] Contrato #{c.Id} - {c.NombreCliente} - Última modificación: {c.FechaModificacion}");
            }

            // Marcar todos los contratos actuales como vistos con sus fechas
            var contratosVistos = await SessionStorage.GetItemAsync<Dictionary<int, DateTime>>(STORAGE_KEY) ?? new Dictionary<int, DateTime>();
            foreach (var contrato in contratosModificados)
            {
                if (contrato.FechaModificacion.HasValue)
                {
                    contratosVistos[contrato.Id] = contrato.FechaModificacion.Value;
                }
            }
            await SessionStorage.SetItemAsync(STORAGE_KEY, contratosVistos);
            
            // Actualizar el indicador de no vistos
            hayModificacionesNoVistas = false;
        }
        catch (Exception)
        {
            contratosModificados = new List<Contrato>();
        }
        finally
        {
            cargandoModificaciones = false;
            StateHasChanged();
        }
    }

    private void CerrarModalAvisos()
    {
        mostrarModalAvisos = false;
        StateHasChanged();
    }

    private async Task IrAContrato(Contrato contrato)
    {
        try
        {
            // Marcar este contrato como visto antes de navegar
            if (contrato.FechaModificacion.HasValue)
            {
                var contratosVistos = await SessionStorage.GetItemAsync<Dictionary<int, DateTime>>(STORAGE_KEY) ?? new Dictionary<int, DateTime>();
                contratosVistos[contrato.Id] = contrato.FechaModificacion.Value;
                await SessionStorage.SetItemAsync(STORAGE_KEY, contratosVistos);
                
                // Verificar si quedan contratos sin ver
                await VerificarModificacionesNoVistas();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al marcar contrato como visto: {ex.Message}");
        }
        
        var tipo = contrato.Tipo?.ToLower() ?? "";
        if (tipo == "energia" || tipo == "energía")
        {
            Navigation.NavigateTo($"/contratos/energia?id={contrato.Id}", true);
        }
        else if (tipo == "telefonia" || tipo == "telefonía")
        {
            Navigation.NavigateTo($"/contratos/telefonia?id={contrato.Id}", true);
        }
        else if (tipo == "alarma" || tipo == "alarmas")
        {
            Navigation.NavigateTo($"/contratos/alarmas?id={contrato.Id}", true);
        }
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
        
        if (verificacionTimer != null)
        {
            verificacionTimer.Stop();
            verificacionTimer.Dispose();
        }
    }
}


