    private async Task RechazarLiquidacionPendiente(int usuarioId)
    {
        try
        {
            // Verificar que el usuario sea Administrador
            if (AuthService.UsuarioActual?.Rol != "Administrador")
            {
                mensajeError = "Solo los administradores pueden rechazar liquidaciones pendientes.";
                return;
            }

            // Obtener información del usuario
            await using var context = DbContextProvider.CreateDbContext();
            var usuario = await context.Usuarios.FindAsync(usuarioId);
            
            if (usuario == null)
            {
                mensajeError = "Usuario no encontrado.";
                return;
            }

            // Contar contratos facturables
            var cantidadContratos = await context.Contratos
                .Where(c => c.Comercial == usuario.NombreUsuario
                    && (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .CountAsync();

            // Solicitar confirmación
            bool confirmado = await JSRuntime.InvokeAsync<bool>(
                "confirm", 
                $"¿Está seguro de que desea rechazar la liquidación pendiente de {usuario.NombreUsuario}?\\n\\n" +
                $"Esto cambiará el estado de {cantidadContratos} contrato(s) de 'Act/Facturable' a 'Pendiente'.\\n\\n" +
                $"Esta acción se puede revertir cambiando manualmente el estado de los contratos.");
            
            if (!confirmado)
            {
                return;
            }

            // Obtener todos los contratos facturables del usuario
            var contratos = await context.Contratos
                .Where(c => c.Comercial == usuario.NombreUsuario
                    && (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .ToListAsync();

            // Cambiar el estado de todos los contratos a "Pendiente"
            foreach (var contrato in contratos)
            {
                contrato.Estado = "Pendiente";
            }

            await context.SaveChangesAsync();
            
            // Recargar la lista de usuarios con contratos
            await CargarUsuariosConContratos();
            
            mensajeError = string.Empty;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al rechazar la liquidación pendiente: {ex.Message}";
        }
    }

