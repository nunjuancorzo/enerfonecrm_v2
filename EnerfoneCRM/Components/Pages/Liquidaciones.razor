    private async Task AprobarLiquidacion(int usuarioId)
    {
        try
        {
            var usuario = usuariosConContratos.FirstOrDefault(u => u.Usuario.Id == usuarioId);
            if (usuario == null) return;

            // Validación de seguridad: colaboradores solo pueden aprobar su propia liquidación
            if (!AuthService.PuedeGestionarLiquidaciones && AuthService.UsuarioActual?.Id != usuarioId)
            {
                mensajeError = "No tienes permisos para aprobar esta liquidación";
                return;
            }

            usuario.Aprobando = true;
            StateHasChanged();

            await using var context = DbContextProvider.CreateDbContext();
            
            var usuarioDb = await context.Usuarios.FindAsync(usuarioId);
            if (usuarioDb == null)
            {
                mensajeError = "Usuario no encontrado";
                return;
            }

            Console.WriteLine($"[LIQUIDACIONES] ===== APROBANDO LIQUIDACIÓN =====");
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {usuarioDb.NombreUsuario} (ID: {usuarioDb.Id}, Rol: {usuarioDb.Rol})");
            Console.WriteLine($"[LIQUIDACIONES] Jerarquía:");
            Console.WriteLine($"[LIQUIDACIONES]   - GestorId: {usuarioDb.GestorId}");
            Console.WriteLine($"[LIQUIDACIONES]   - JefeVentasId: {usuarioDb.JefeVentasId}");
            Console.WriteLine($"[LIQUIDACIONES]   - DirectorComercialId: {usuarioDb.DirectorComercialId}");
            Console.WriteLine($"[LIQUIDACIONES] =====================================");

            // Obtener todos los contratos facturables del usuario
            var contratos = await context.Contratos
                .Where(c => c.Comercial == usuarioDb.NombreUsuario
                    && (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .ToListAsync();

            if (!contratos.Any())
            {
                mensajeError = "No hay contratos facturables para aprobar";
                usuario.Aprobando = false;
                StateHasChanged();
                return;
            }

            // Contar contratos por tipo
            var contratosEnergia = contratos.Count(c => c.Tipo == "energia" || c.Tipo == "Energía");
            var contratosTelefonia = contratos.Count(c => c.Tipo == "telefonia" || c.Tipo == "Telefonía");
            var contratosAlarmas = contratos.Count(c => c.Tipo == "alarma" || c.Tipo == "Alarma");
            
            // Calcular total base de comisiones (antes de aplicar distribución jerárquica)
            var totalComisionesBase = contratos.Sum(c => c.Comision ?? 0);
            
            // Obtener decomisiones pendientes del usuario (no asignadas a ninguna liquidación)
            var decomisionesPendientes = await context.Decomisiones
                .Where(d => d.UsuarioId == usuarioId && d.LiquidacionDecomisionId == null)
                .ToListAsync();
            
            var totalDecomisiones = decomisionesPendientes.Sum(d => d.ImporteDecomision);
            
            // ===== CALCULAR LA COMISIÓN QUE LE CORRESPONDE AL COLABORADOR =====
            decimal totalComisionesColaborador;
            
            // Si el usuario es Backoffice, no recibe comisiones (todo va al Administrador)
            if (usuarioDb.Rol == "Backoffice")
            {
                totalComisionesColaborador = 0;
            }
            else
            {
                // Obtener la configuración de comisiones del usuario
                // Aquí debemos calcular el porcentaje promedio ponderado según los contratos
                decimal totalConPorcentaje = 0;
                
                foreach (var contrato in contratos)
                {
                    // Calcular la distribución para este contrato
                    var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, null);
                    Console.WriteLine($"[LIQUIDACIONES] Contrato {contrato.Id}: Base={detalle.ComisionBase}€, %Colaborador={detalle.PorcentajeColaborador}%, Colaborador={detalle.ComisionColaborador}€");
                    totalConPorcentaje += detalle.ComisionColaborador;
                }
                
                totalComisionesColaborador = totalConPorcentaje;
                Console.WriteLine($"[LIQUIDACIONES] Total calculado para colaborador: {totalComisionesColaborador}€");
            }
            
            // Restar decomisiones del total del colaborador
            totalComisionesColaborador -= totalDecomisiones;
            
            Console.WriteLine($"[LIQUIDACIONES] Total base: {totalComisionesBase}€, Comisión colaborador: {totalComisionesColaborador}€, Decomisiones: {totalDecomisiones}€");

            // Guardar en el histórico (excepto si es superadmin)
            if (AuthService.UsuarioActual?.NombreUsuario != "superadmin")
            {
                // ===== RECOPILAR TODOS LOS USUARIOS QUE RECIBIRÁN COMISIÓN =====
                var usuariosConComision = new Dictionary<int, (Usuario usuario, decimal totalComision)>();
                
                // Calcular distribución para todos los contratos y acumular por usuario
                foreach (var contrato in contratos)
                {
                    var detalleComision = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, null);
                    
                    Console.WriteLine($"[LIQUIDACIONES] Contrato {contrato.Id}:");
                    Console.WriteLine($"  - Colaborador (ID {detalleComision.ColaboradorId}): {detalleComision.ComisionColaborador}€ ({detalleComision.PorcentajeColaborador}%)");
                    Console.WriteLine($"  - Gestor (ID {detalleComision.GestorId}): {detalleComision.ComisionGestor}€ ({detalleComision.PorcentajeGestor}%)");
                    Console.WriteLine($"  - Jefe Ventas (ID {detalleComision.JefeVentasId}): {detalleComision.ComisionJefeVentas}€ ({detalleComision.PorcentajeJefeVentas}%)");
                    Console.WriteLine($"  - Director (ID {detalleComision.DirectorComercialId}): {detalleComision.ComisionDirectorComercial}€ ({detalleComision.PorcentajeDirectorComercial}%)");
                    Console.WriteLine($"  - Administrador (ID {detalleComision.AdministradorId}): {detalleComision.ComisionAdministrador}€ ({detalleComision.PorcentajeAdministrador}%)");
                    
                    // Colaborador
                    if (detalleComision.ComisionColaborador > 0)
                    {
                        if (!usuariosConComision.ContainsKey(detalleComision.ColaboradorId))
                        {
                            usuariosConComision[detalleComision.ColaboradorId] = (usuarioDb, 0);
                        }
                        var actual = usuariosConComision[detalleComision.ColaboradorId];
                        usuariosConComision[detalleComision.ColaboradorId] = (actual.usuario, actual.totalComision + detalleComision.ComisionColaborador);
                    }
                    
                    // Gestor
                    if (detalleComision.GestorId.HasValue && detalleComision.ComisionGestor.HasValue && detalleComision.ComisionGestor.Value > 0)
                    {
                        var gestor = await context.Usuarios.FindAsync(detalleComision.GestorId.Value);
                        if (gestor != null && gestor.Activo)
                        {
                            if (!usuariosConComision.ContainsKey(gestor.Id))
                            {
                                usuariosConComision[gestor.Id] = (gestor, 0);
                                Console.WriteLine($"[LIQUIDACIONES] *** Agregando Gestor ID {gestor.Id} ({gestor.NombreUsuario}) al diccionario");
                            }
                            var actual = usuariosConComision[gestor.Id];
                            usuariosConComision[gestor.Id] = (actual.usuario, actual.totalComision + detalleComision.ComisionGestor.Value);
                            Console.WriteLine($"[LIQUIDACIONES] *** Gestor acumulado: {usuariosConComision[gestor.Id].totalComision}€");
                        }
                        else
                        {
                            Console.WriteLine($"[LIQUIDACIONES] *** ADVERTENCIA: Gestor ID {detalleComision.GestorId} no encontrado o inactivo");
                        }
                    }
                    else
                    {
                        if (!detalleComision.GestorId.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: No tiene GestorId asignado");
                        else if (!detalleComision.ComisionGestor.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionGestor es NULL");
                        else if (detalleComision.ComisionGestor.Value <= 0)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionGestor es 0 o negativa");
                    }
                    
                    // Jefe de Ventas
                    if (detalleComision.JefeVentasId.HasValue && detalleComision.ComisionJefeVentas.HasValue && detalleComision.ComisionJefeVentas.Value > 0)
                    {
                        var jefeVentas = await context.Usuarios.FindAsync(detalleComision.JefeVentasId.Value);
                        if (jefeVentas != null && jefeVentas.Activo)
                        {
                            if (!usuariosConComision.ContainsKey(jefeVentas.Id))
                            {
                                usuariosConComision[jefeVentas.Id] = (jefeVentas, 0);
                                Console.WriteLine($"[LIQUIDACIONES] *** Agregando Jefe de Ventas ID {jefeVentas.Id} ({jefeVentas.NombreUsuario}) al diccionario");
                            }
                            var actual = usuariosConComision[jefeVentas.Id];
                            usuariosConComision[jefeVentas.Id] = (actual.usuario, actual.totalComision + detalleComision.ComisionJefeVentas.Value);
                            Console.WriteLine($"[LIQUIDACIONES] *** Jefe de Ventas acumulado: {usuariosConComision[jefeVentas.Id].totalComision}€");
                        }
                        else
                        {
                            Console.WriteLine($"[LIQUIDACIONES] *** ADVERTENCIA: Jefe de Ventas ID {detalleComision.JefeVentasId} no encontrado o inactivo");
                        }
                    }
                    else
                    {
                        if (!detalleComision.JefeVentasId.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: No tiene JefeVentasId asignado");
                        else if (!detalleComision.ComisionJefeVentas.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionJefeVentas es NULL");
                        else if (detalleComision.ComisionJefeVentas.Value <= 0)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionJefeVentas es 0 o negativa");
                    }
                    
                    // Director Comercial
                    if (detalleComision.DirectorComercialId.HasValue && detalleComision.ComisionDirectorComercial.HasValue && detalleComision.ComisionDirectorComercial.Value > 0)
                    {
                        var director = await context.Usuarios.FindAsync(detalleComision.DirectorComercialId.Value);
                        if (director != null && director.Activo)
                        {
                            if (!usuariosConComision.ContainsKey(director.Id))
                            {
                                usuariosConComision[director.Id] = (director, 0);
                                Console.WriteLine($"[LIQUIDACIONES] *** Agregando Director Comercial ID {director.Id} ({director.NombreUsuario}) al diccionario");
                            }
                            var actual = usuariosConComision[director.Id];
                            usuariosConComision[director.Id] = (actual.usuario, actual.totalComision + detalleComision.ComisionDirectorComercial.Value);
                            Console.WriteLine($"[LIQUIDACIONES] *** Director Comercial acumulado: {usuariosConComision[director.Id].totalComision}€");
                        }
                        else
                        {
                            Console.WriteLine($"[LIQUIDACIONES] *** ADVERTENCIA: Director Comercial ID {detalleComision.DirectorComercialId} no encontrado o inactivo");
                        }
                    }
                    else
                    {
                        if (!detalleComision.DirectorComercialId.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: No tiene DirectorComercialId asignado");
                        else if (!detalleComision.ComisionDirectorComercial.HasValue)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionDirectorComercial es NULL");
                        else if (detalleComision.ComisionDirectorComercial.Value <= 0)
                            Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionDirectorComercial es 0 o negativa");
                    }
                    
                    // Administrador
                    if (detalleComision.ComisionAdministrador > 0)
                    {
                        var admin = await context.Usuarios.FindAsync(detalleComision.AdministradorId);
                        if (admin != null && admin.Activo)
                        {
                            if (!usuariosConComision.ContainsKey(admin.Id))
                            {
                                usuariosConComision[admin.Id] = (admin, 0);
                                Console.WriteLine($"[LIQUIDACIONES] *** Agregando Administrador ID {admin.Id} ({admin.NombreUsuario}) al diccionario");
                            }
                            var actual = usuariosConComision[admin.Id];
                            usuariosConComision[admin.Id] = (actual.usuario, actual.totalComision + detalleComision.ComisionAdministrador);
                            Console.WriteLine($"[LIQUIDACIONES] *** Administrador acumulado: {usuariosConComision[admin.Id].totalComision}€");
                        }
                        else
                        {
                            Console.WriteLine($"[LIQUIDACIONES] *** ADVERTENCIA: Administrador ID {detalleComision.AdministradorId} no encontrado o inactivo");
                        }
                    }
                    else
                    {
                        Console.WriteLine($"[LIQUIDACIONES] *** Contrato {contrato.Id}: ComisionAdministrador es 0 o negativa");
                    }
                }
                
                // Restar decomisiones del colaborador principal
                if (usuariosConComision.ContainsKey(usuarioDb.Id))
                {
                    var actual = usuariosConComision[usuarioDb.Id];
                    usuariosConComision[usuarioDb.Id] = (actual.usuario, actual.totalComision - totalDecomisiones);
                }
                
                Console.WriteLine($"[LIQUIDACIONES] ===== RESUMEN DE USUARIOS CON COMISIÓN =====");
                Console.WriteLine($"[LIQUIDACIONES] Total usuarios: {usuariosConComision.Count}");
                foreach (var kvp in usuariosConComision)
                {
                    var usr = kvp.Value.usuario;
                    var total = kvp.Value.totalComision;
                    Console.WriteLine($"[LIQUIDACIONES]   - {usr.NombreUsuario} (ID: {usr.Id}, Rol: {usr.Rol}): {total:N2}€");
                }
                Console.WriteLine($"[LIQUIDACIONES] ==========================================");
                
                Console.WriteLine($"[LIQUIDACIONES] Creando liquidaciones históricas para {usuariosConComision.Count} usuarios");
                
                // ===== CREAR LIQUIDACIÓN HISTÓRICA PARA CADA USUARIO =====
                var liquidacionesCreadas = new Dictionary<int, int>(); // usuarioId -> liquidacionId
                
                foreach (var kvp in usuariosConComision)
                {
                    var usuarioLiq = kvp.Value.usuario;
                    var totalComision = kvp.Value.totalComision;
                    
                    // TODAS las liquidaciones se crean en estado "Pendiente"
                    // Cada usuario deberá aceptar su propia liquidación individualmente
                    var historico = new HistoricoLiquidacion
                    {
                        UsuarioId = usuarioLiq.Id,
                        UsuarioNombre = usuarioLiq.NombreUsuario,
                        UsuarioEmail = usuarioLiq.Email,
                        CantidadContratos = contratos.Count,
                        ContratosEnergia = contratosEnergia,
                        ContratosTelefonia = contratosTelefonia,
                        ContratosAlarmas = contratosAlarmas,
                        FechaAprobacion = DateTime.Now,
                        AprobadoPorId = AuthService.UsuarioActual!.Id,
                        AprobadoPorNombre = AuthService.UsuarioActual.NombreUsuario,
                        Estado = "Pendiente",
                        FechaAceptada = null,
                        TotalComisiones = totalComision
                    };
                    
                    context.HistoricoLiquidaciones.Add(historico);
                    await context.SaveChangesAsync();
                    
                    liquidacionesCreadas[usuarioLiq.Id] = historico.Id;
                    
                    Console.WriteLine($"[LIQUIDACIONES] Creada liquidación {historico.Id} para {usuarioLiq.NombreUsuario} (Rol: {usuarioLiq.Rol}): {totalComision:N2}€ - Estado: Pendiente");
                }
                
                // ===== CREAR DETALLES DE COMISIÓN Y VINCULAR CONTRATOS =====
                var liquidacionPrincipalId = liquidacionesCreadas[usuarioDb.Id];
                
                foreach (var contrato in contratos)
                {
                    // Calcular distribución de comisiones
                    var detalleComision = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, liquidacionPrincipalId);
                    await ComisionService.GuardarDetalleComisionAsync(detalleComision);
                    
                    // Vincular contrato a la liquidación principal (del colaborador)
                    // IMPORTANTE: NO cambiar el estado a "Liquidado" aún, solo cuando el colaborador acepte su liquidación
                    contrato.HistoricoLiquidacionId = liquidacionPrincipalId;
                }
                
                // Vincular decomisiones pendientes a la liquidación del colaborador
                foreach (var decomision in decomisionesPendientes)
                {
                    decomision.LiquidacionDecomisionId = liquidacionPrincipalId;
                    context.Decomisiones.Update(decomision);
                }
                
                if (decomisionesPendientes.Any())
                {
                    Console.WriteLine($"[LIQUIDACIONES] Vinculadas {decomisionesPendientes.Count} decomisiones a liquidación {liquidacionPrincipalId}");
                }
                
                await context.SaveChangesAsync();
                
                Console.WriteLine($"[LIQUIDACIONES] Liquidaciones creadas exitosamente para {liquidacionesCreadas.Count} usuarios");
            }
            else
            {
                // Cambiar el estado de todos los contratos a Liquidado (superadmin sin histórico)
                foreach (var contrato in contratos)
                {
                    contrato.Estado = "Liquidado";
                }
                
                await context.SaveChangesAsync();
                Console.WriteLine($"[Liquidaciones] SUPERADMIN - Histórico NO registrado (modo invisible)");
            }

            // Recargar la lista de usuarios con contratos
            await CargarUsuariosConContratos();
            await CargarLiquidacionesPorEstado();

            Console.WriteLine($"[LIQUIDACIONES] Aprobada liquidación del usuario {usuarioDb.NombreUsuario}: {contratos.Count} contratos cambiados a Liquidado y guardados en histórico");
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al aprobar liquidación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al aprobar liquidación: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
            
            var usuario = usuariosConContratos.FirstOrDefault(u => u.Usuario.Id == usuarioId);
            if (usuario != null)
            {
                usuario.Aprobando = false;
            }
        }
        finally
        {
            StateHasChanged();
        }
    }

