    private async Task ReactivarLiquidacion(int historicoId)
    {
        try
        {
            var historico = historicoLiquidaciones.FirstOrDefault(h => h.Id == historicoId);
            if (historico == null) return;

            historico.Reactivando = true;
            StateHasChanged();

            await using var context = DbContextProvider.CreateDbContext();

            var historicoDb = await context.HistoricoLiquidaciones.FindAsync(historicoId);
            if (historicoDb == null)
            {
                mensajeError = "Registro de histórico no encontrado";
                return;
            }

            // Obtener el usuario
            var usuario = await context.Usuarios.FindAsync(historicoDb.UsuarioId);
            if (usuario == null)
            {
                mensajeError = "Usuario no encontrado";
                historico.Reactivando = false;
                StateHasChanged();
                return;
            }

            // Buscar solo los contratos vinculados a esta liquidación específica
            var contratos = await context.Contratos
                .Where(c => c.HistoricoLiquidacionId == historicoId
                    && c.Estado == "Liquidado")
                .ToListAsync();

            if (!contratos.Any())
            {
                mensajeError = "No hay contratos liquidados para reactivar";
                historico.Reactivando = false;
                StateHasChanged();
                return;
            }

            // Cambiar el estado de los contratos a Act/Facturable y limpiar vínculo
            foreach (var contrato in contratos)
            {
                contrato.Estado = "Act/Facturable";
                contrato.HistoricoLiquidacionId = null;
            }

            // Eliminar el registro del histórico
            context.HistoricoLiquidaciones.Remove(historicoDb);

            await context.SaveChangesAsync();

            // Recargar el histórico
            historicoLiquidaciones = await context.HistoricoLiquidaciones
                .OrderByDescending(h => h.FechaAprobacion)
                .ToListAsync();

            // Recargar la lista de liquidaciones pendientes
            await CargarUsuariosConContratos();

            Console.WriteLine($"[LIQUIDACIONES] Liquidación reactivada: {contratos.Count} contratos vueltos a Act/Facturable");
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al reactivar liquidación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al reactivar liquidación: {ex.Message}");

            var historico = historicoLiquidaciones.FirstOrDefault(h => h.Id == historicoId);
            if (historico != null)
            {
                historico.Reactivando = false;
            }
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task CargarLiquidacionesPorEstado()
    {
        try
        {
            await using var context = DbContextProvider.CreateDbContext();
            
            // Determinar si se debe filtrar por usuario
            // Admin y Backoffice con permisos ven todas las liquidaciones
            // Colaboradores y Gestores solo ven las suyas
            var filtrarPorUsuario = !AuthService.PuedeGestionarLiquidaciones && AuthService.UsuarioActual != null;
            var usuarioActualId = AuthService.UsuarioActual?.Id ?? 0;
            
            Console.WriteLine($"[LIQUIDACIONES] CargarLiquidacionesPorEstado - Usuario: {AuthService.UsuarioActual?.NombreUsuario}, Rol: {AuthService.UsuarioActual?.Rol}, FiltrarPorUsuario: {filtrarPorUsuario}");
            
            // Liquidaciones en incidencia
            var queryIncidencia = context.HistoricoLiquidaciones
                .Where(h => h.Estado == "En incidencia");
            if (filtrarPorUsuario)
            {
                queryIncidencia = queryIncidencia.Where(h => h.UsuarioId == usuarioActualId);
            }
            liquidacionesEnIncidencia = await queryIncidencia
                .OrderByDescending(h => h.FechaEnIncidencia ?? h.FechaAprobacion)
                .ToListAsync();
            
            Console.WriteLine($"[LIQUIDACIONES] Cargadas {liquidacionesEnIncidencia.Count} liquidaciones en incidencia");
            
            // Liquidaciones aceptadas
            var queryAceptadas = context.HistoricoLiquidaciones
                .Where(h => h.Estado == "Aceptada");
            if (filtrarPorUsuario)
            {
                queryAceptadas = queryAceptadas.Where(h => h.UsuarioId == usuarioActualId);
            }
            liquidacionesAceptadas = await queryAceptadas
                .OrderByDescending(h => h.FechaAceptada ?? h.FechaAprobacion)
                .ToListAsync();
            
            Console.WriteLine($"[LIQUIDACIONES] Cargadas {liquidacionesAceptadas.Count} liquidaciones aceptadas");
            
            // Liquidaciones liquidadas
            var queryLiquidadas = context.HistoricoLiquidaciones
                .Where(h => h.Estado == "Liquidada");
            if (filtrarPorUsuario)
            {
                queryLiquidadas = queryLiquidadas.Where(h => h.UsuarioId == usuarioActualId);
            }
            liquidacionesLiquidadas = await queryLiquidadas
                .OrderByDescending(h => h.FechaLiquidada ?? h.FechaAprobacion)
                .ToListAsync();
            
            Console.WriteLine($"[LIQUIDACIONES] Cargadas {liquidacionesLiquidadas.Count} liquidaciones liquidadas");
            
            // Recalcular totales si están en NULL o 0
            var todasLiquidaciones = liquidacionesEnIncidencia
                .Concat(liquidacionesAceptadas)
                .Concat(liquidacionesLiquidadas)
                .Where(l => !l.TotalComisiones.HasValue || l.TotalComisiones == 0)
                .ToList();
            
            foreach (var liq in todasLiquidaciones)
            {
                var usuario = await context.Usuarios.FindAsync(liq.UsuarioId);
                if (usuario != null)
                {
                    // Calcular total de comisiones SOLO de los contratos vinculados a esta liquidación específica
                    var totalComisiones = await context.Contratos
                        .Where(c => c.HistoricoLiquidacionId == liq.Id)
                        .SumAsync(c => c.Comision ?? 0);
                    
                    // Restar decomisiones asociadas a esta liquidación
                    var totalDecomisiones = await context.Decomisiones
                        .Where(d => d.LiquidacionDecomisionId == liq.Id)
                        .SumAsync(d => d.ImporteDecomision);
                    
                    liq.TotalComisiones = totalComisiones - totalDecomisiones;
                    context.HistoricoLiquidaciones.Update(liq);
                }
            }
            
            if (todasLiquidaciones.Any())
            {
                await context.SaveChangesAsync();
            }
                
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar liquidaciones: {ex.Message}";
        }
    }

