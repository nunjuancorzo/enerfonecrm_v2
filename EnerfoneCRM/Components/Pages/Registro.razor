                        .container {{ max-width: 600px; margin: 0 auto; padding: 20px; }}
                        .header {{ background-color: #4CAF50; color: white; padding: 20px; text-align: center; }}
                        .content {{ background-color: #f9f9f9; padding: 20px; border: 1px solid #ddd; }}
                        .info-row {{ margin: 10px 0; }}
                        .label {{ font-weight: bold; color: #555; }}
                        .footer {{ margin-top: 20px; padding-top: 20px; border-top: 1px solid #ddd; font-size: 12px; color: #777; }}
                    </style>
                </head>
                <body>
                    <div class='container'>
                        <div class='header'>
                            <h2>Nuevo Colaborador Registrado</h2>
                        </div>
                        <div class='content'>
                            <p>Se ha registrado un nuevo colaborador en el sistema. Por favor, revisa y aprueba su cuenta.</p>
                            
                            <div class='info-row'>
                                <span class='label'>Nombre completo:</span> {nuevoColaborador.Nombre} {nuevoColaborador.Apellidos}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Email:</span> {nuevoColaborador.Email}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Usuario:</span> {nuevoColaborador.NombreUsuario}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Tipo de Entidad:</span> {nuevoColaborador.TipoEntidad}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Dirección:</span> {nuevoColaborador.Direccion}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Código Postal:</span> {nuevoColaborador.CodigoPostal}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Localidad:</span> {nuevoColaborador.Localidad}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Número de Cuenta:</span> {nuevoColaborador.NumeroCuenta}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Fecha de Registro:</span> {nuevoColaborador.FechaCreacion:dd/MM/yyyy HH:mm}
                            </div>
                            <div class='info-row'>
                                <span class='label'>Estado:</span> <span style='color: orange;'>Pendiente de activación</span>
                            </div>
                        </div>
                        <div class='footer'>
                            <p>Este es un mensaje automático del sistema Enerfone CRM. Por favor, accede al panel de administración para activar la cuenta del nuevo colaborador.</p>
                        </div>
                    </div>
                </body>
                </html>
            ";

            // Enviar email a cada administrador
            foreach (var admin in administradores)
            {
                if (!string.IsNullOrWhiteSpace(admin.Email))
                {
                    var (exito, mensaje) = await EmailService.EnviarEmailSimpleAsync(
                        admin.Email,
                        "Nuevo Colaborador Registrado - Requiere Aprobación",
                        cuerpoHtml
                    );

                    if (exito)
                    {
                        Console.WriteLine($"[REGISTRO] Notificación enviada a {admin.Email}");
                    }
                    else
                    {
                        Console.WriteLine($"[REGISTRO] Error al enviar email a {admin.Email}: {mensaje}");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[REGISTRO] Error al enviar notificación a administradores: {ex.Message}");
            // No lanzar excepción para que no afecte el registro
        }
    }
}
