                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Escalera <small class="text-muted">(opcional)</small></label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.EscaleraInstalacion" placeholder="Esc." />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Piso <small class="text-muted">(opcional)</small></label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.PisoInstalacion" placeholder="Piso" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Puerta <small class="text-muted">(opcional)</small></label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.PuertaInstalacion" placeholder="Puerta" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-bold">Código Postal</label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.CodigoPostalInstalacion" placeholder="CP" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold">Aclarador <small class="text-muted">(opcional)</small></label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.AclaradorInstalacion" placeholder="Información adicional de la dirección" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold">Localidad</label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.LocalidadInstalacion" placeholder="Localidad" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold">Provincia</label>
                                            <InputText class="form-control" @bind-Value="nuevoContrato.ProvinciaInstalacion" placeholder="Provincia" />
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <label class="form-label fw-bold">Observaciones</label>
                                            <InputTextArea @bind-Value="nuevoContrato.ObservacionesEstado" class="form-control" rows="3" />
                                        </div>
                                        
                                        <!-- Documentos Adjuntos -->
                                        <div class="col-12 mt-3">
                                            <hr />
                                            <h6 class="border-bottom pb-2 mb-3"><i class="bi bi-paperclip me-2"></i>Documentos Adjuntos del Contrato</h6>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Factura de Energía</label>
                                            <small class="text-muted d-block mb-1">(PDF, JPG, PNG, DOC o DOCX - máx. 10MB)</small>
                                            <InputFile OnChange="CargarFacturaEnergia" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" multiple />
                                            @if (facturasPendientes.Any())
                                            {
                                                <div class="mt-2">
                                                    @for (int i = 0; i < facturasPendientes.Count; i++)
                                                    {
                                                        int index = i;
                                                        var archivo = facturasPendientes[i];
                                                        <div class="d-inline-flex align-items-center badge bg-success me-2 mb-1 p-2">
                                                            <i class="bi bi-file-earmark-check me-1"></i>
                                                            <span class="me-2">@archivo.nombreArchivo</span>
                                                            <button type="button" class="btn btn-sm btn-link text-white p-0" @onclick="() => EliminarFacturaPendiente(index)">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    }
                </div>

                <!-- Footer con botones de navegación -->
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarWizard" disabled="@guardando">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </button>
                    
                    @if (pasoActual > 1)
                    {
                        <button type="button" class="btn btn-outline-warning" @onclick="Anterior" disabled="@guardando">
                            <i class="bi bi-arrow-left me-2"></i>Anterior
                        </button>
                    }
                    
                    @if (pasoActual < 3)
                    {
                        <button type="button" class="btn btn-warning" @onclick="Siguiente" disabled="@(!PuedeAvanzar() || guardando)">
                            Siguiente<i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-success" @onclick="GuardarContrato" disabled="@guardando">
                            @if (guardando)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <i class="bi bi-save me-2"></i>
                            }
                            Guardar Contrato
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnContratoCreado { get; set; }
    [Parameter] public EventCallback OnCerrar { get; set; }

    private bool mostrarWizard = false;
    private int pasoActual = 1;
    private bool guardando = false;
    private string mensajeError = string.Empty;

    // Paso 1: Cliente
    private bool modoCrearCliente = false;
    private string busquedaCliente = string.Empty;
    private List<Cliente> todosLosClientes = new();
    private List<Cliente> clientesFiltrados = new();
    private Cliente? clienteSeleccionado = null;
    private Cliente? nuevoCliente = null;

    // Paso 2: Comercializadora
    private List<Comercializadora> comercializadorasDisponibles = new();
    private Comercializadora? comercializadoraSeleccionada = null;

    // Paso 3: Datos del contrato
    private Contrato? nuevoContrato = null;
    private List<TarifaEnergia> tarifasEnergia = new();
    private List<TarifaEnergia> tarifasBase = new();
    private List<TarifaEnergia> todasLasTarifas = new();
    private List<Servicio> serviciosDisponibles = new();
    private string peajeLuzSeleccionado = string.Empty;
    private string peajeGasSeleccionado = string.Empty;

    // Archivos adjuntos
    private Dictionary<string, List<(string nombreArchivo, byte[] contenido)>> archivosPendientesCliente = new();
    private List<FicheroCliente> ficherosCliente = new();
    private List<(string nombreArchivo, byte[] contenido)> facturasPendientes = new();

    public async Task Abrir()
    {
        pasoActual = 1;
        modoCrearCliente = false;
        busquedaCliente = string.Empty;
        clienteSeleccionado = null;
        comercializadoraSeleccionada = null;
        mensajeError = string.Empty;
        archivosPendientesCliente.Clear();
        
        // Cargar datos iniciales
        await CargarClientes();
        await CargarComercializadoras();
        await CargarTarifas();
        await CargarServicios();
        
        InicializarNuevoCliente();
        
        mostrarWizard = true;
        StateHasChanged();
    }

    private async Task CargarClientes()
    {
        try
        {
            // Si es administrador, cargar todos los clientes
            // Si no es administrador, cargar solo los clientes de su usuario
            if (AuthService.UsuarioActual?.Rol == "Administrador")
            {
                todosLosClientes = await ClienteService.ObtenerTodosAsync();
            }
            else if (AuthService.UsuarioActual?.Id != null)
            {
                todosLosClientes = await ClienteService.ObtenerPorUsuarioAsync(AuthService.UsuarioActual.Id);
            }
            else
            {
                todosLosClientes = new();
            }
            
            clientesFiltrados = new();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar clientes: {ex.Message}";
        }
    }

    private async Task CargarComercializadoras()
    {
        try
        {
            var usuarioId = AuthService.UsuarioActual?.Id;
            var rol = AuthService.UsuarioActual?.Rol;

            if (usuarioId != null)
            {
                comercializadorasDisponibles = await ComercializadoraService.ObtenerPermitidasPorUsuarioAsync(
                    usuarioId.Value,
                    rol
                );
            }
            else
            {
                comercializadorasDisponibles = await ComercializadoraService.ObtenerActivasAsync();
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar comercializadoras: {ex.Message}";
        }
    }

    private async Task CargarTarifas()
    {
        try
        {
            todasLasTarifas = await TarifaEnergiaService.ObtenerTodasAsync();
            tarifasEnergia = todasLasTarifas;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar tarifas: {ex.Message}";
        }
    }

    private async Task CargarServicios()
    {
        try
        {
            serviciosDisponibles = await ServicioService.ObtenerTodosAsync();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar servicios: {ex.Message}";
        }
    }

    private void InicializarNuevoCliente()
    {
        nuevoCliente = new Cliente { TipoCliente = "Particular" };
    }

    private void FiltrarClientes()
    {
        if (string.IsNullOrWhiteSpace(busquedaCliente))
        {
            clientesFiltrados = new();
            return;
        }

        var busqueda = busquedaCliente.ToLower();
        clientesFiltrados = todosLosClientes
            .Where(c =>
                (c.Nombre != null && c.Nombre.ToLower().Contains(busqueda)) ||
                (c.DniCif != null && c.DniCif.ToLower().Contains(busqueda)) ||
                (c.Telefono != null && c.Telefono.Contains(busqueda))
            )
            .OrderBy(c => c.Nombre)
            .ToList();
    }

    private void SeleccionarCliente(Cliente cliente)
    {
        clienteSeleccionado = cliente;
        modoCrearCliente = false;
    }

    private async Task CrearNuevoCliente()
    {
        if (nuevoCliente == null) return;

        try
        {
            guardando = true;
            mensajeError = string.Empty;

            var (exito, mensaje) = await ClienteService.CrearAsync(nuevoCliente);
            if (!exito)
            {
                mensajeError = mensaje;
                StateHasChanged();
                return;
            }
            
            // Si hay archivos pendientes, guardarlos
            if (archivosPendientesCliente.Any() && nuevoCliente.Id > 0)
            {
                foreach (var tipoArchivos in archivosPendientesCliente)
                {
                    foreach (var archivo in tipoArchivos.Value)
                    {
                        await FicheroClienteService.GuardarArchivoAsync(
                            nuevoCliente.Id,
                            tipoArchivos.Key,
                            archivo.nombreArchivo,
                            archivo.contenido
                        );
                    }
                }
                // Limpiar archivos pendientes
                archivosPendientesCliente.Clear();
            }
            
            // Recargar clientes y seleccionar el recién creado
            await CargarClientes();
            clienteSeleccionado = todosLosClientes.OrderByDescending(c => c.Id).FirstOrDefault();
            
            // Avanzar al siguiente paso automáticamente
            pasoActual = 2;
            modoCrearCliente = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al crear cliente: {ex.Message}";
            StateHasChanged();
        }
        finally
        {
            guardando = false;
        }
    }

    private void SeleccionarComercializadora(Comercializadora comercializadora)
    {
        comercializadoraSeleccionada = comercializadora;
        StateHasChanged();
    }

    private bool PuedeAvanzar()
    {
        return pasoActual switch
        {
            1 => clienteSeleccionado != null || (modoCrearCliente && nuevoCliente != null && !string.IsNullOrWhiteSpace(nuevoCliente.Nombre) && !string.IsNullOrWhiteSpace(nuevoCliente.DniCif)),
            2 => comercializadoraSeleccionada != null,
            _ => false
        };
    }

    private async Task Siguiente()
    {
        if (pasoActual == 1 && modoCrearCliente && nuevoCliente != null)
        {
            // Si estamos creando un nuevo cliente, guardarlo primero
            await CrearNuevoCliente();
            return; // No incrementar pasoActual aquí, CrearNuevoCliente() ya lo establece a 2
        }
        
        if (pasoActual == 2)
        {
            // Inicializar el contrato al pasar al paso 3
            InicializarNuevoContrato();
            // Filtrar tarifas por la comercializadora seleccionada
            FiltrarTarifasPorComercializadora();
        }

        pasoActual++;
    }

    private void Anterior()
    {
        if (pasoActual > 1)
        {
            pasoActual--;
        }
    }

    private void InicializarNuevoContrato()
    {
        nuevoContrato = new Contrato
        {
            Tipo = "energia",
            IdCliente = clienteSeleccionado?.Id ?? 0,
            NombreCliente = clienteSeleccionado?.Nombre,
            Dni = clienteSeleccionado?.DniCif,
            Direccion = clienteSeleccionado?.Direccion,
            Iban = clienteSeleccionado?.Iban,
            EnComercializadora = comercializadoraSeleccionada?.Nombre,
            Estado = "Pte Carga",
            EstadoServicio = "No quiere",
            Comision = 0,
            FechaCreacion = DateTime.Now,
            FechaModificacion = DateTime.Now,
            FechaAlta = DateTime.Now,
            Comercial = AuthService.UsuarioActual?.NombreUsuario ?? "",
            TitularIbanDiferente = false,
            TitularIbanDni = "",
            TitularIbanNombre = "",
            TitularIbanNumero = ""
        };
    }

    private void FiltrarTarifasPorComercializadora()
    {
        if (comercializadoraSeleccionada == null)
        {
            tarifasBase = new();
            tarifasEnergia = new();
            StateHasChanged();
            return;
        }

        // Filtrar por comercializadora
        var tarifasFiltradas = todasLasTarifas
            .Where(t => t.Empresa != null && 
                        t.Empresa.Equals(comercializadoraSeleccionada.Nombre, StringComparison.OrdinalIgnoreCase))
            .ToList();

        // Filtrar por tipo de cliente si hay uno seleccionado
        if (clienteSeleccionado != null && !string.IsNullOrEmpty(clienteSeleccionado.TipoCliente))
        {
            string tipoTarifa = clienteSeleccionado.TipoCliente == "Particular" ? "Residencial" : "Pyme";
            tarifasFiltradas = tarifasFiltradas.Where(t => t.TipoCliente == tipoTarifa).ToList();
        }

        // Guardar las tarifas base (sin filtro de peaje)
        tarifasBase = tarifasFiltradas;
        
        // Aplicar filtros de peaje si los hay (esto actualiza tarifasEnergia)
        OnPeajeWizardChanged();
        
        StateHasChanged();
    }

    private void OnPeajeWizardChanged()
    {
        if (tarifasBase == null || !tarifasBase.Any())
        {
            tarifasEnergia = new();
            StateHasChanged();
            return;
        }

        var tarifasFiltradas = tarifasBase.AsEnumerable();
        bool hayFiltrosPeaje = !string.IsNullOrEmpty(peajeLuzSeleccionado) || !string.IsNullOrEmpty(peajeGasSeleccionado);

        // Si no hay filtros de peaje seleccionados, mostrar todas las de la base
        if (!hayFiltrosPeaje)
        {
            tarifasEnergia = tarifasBase.ToList();
            StateHasChanged();
            return;
        }

        // Filtrar por Peaje Luz si está seleccionado
        if (!string.IsNullOrEmpty(peajeLuzSeleccionado))
        {
            tarifasFiltradas = tarifasFiltradas.Where(t => 
                t.Peaje != null && t.Peaje.Equals(peajeLuzSeleccionado, StringComparison.OrdinalIgnoreCase)
            );
        }

        // Filtrar por Peaje Gas si está seleccionado
        if (!string.IsNullOrEmpty(peajeGasSeleccionado))
        {
            tarifasFiltradas = tarifasFiltradas.Where(t => 
                t.PeajeGas != null && t.PeajeGas.Equals(peajeGasSeleccionado, StringComparison.OrdinalIgnoreCase)
            );
        }

        tarifasEnergia = tarifasFiltradas.ToList();

        // Limpiar la tarifa si no está en la lista filtrada
        if (nuevoContrato != null && !string.IsNullOrEmpty(nuevoContrato.EnTarifa))
        {
            if (!tarifasEnergia.Any(t => t.Nombre == nuevoContrato.EnTarifa))
            {
                nuevoContrato.EnTarifa = string.Empty;
            }
        }
        
        StateHasChanged();
    }

    private async Task GuardarContrato()
    {
        if (nuevoContrato == null) return;

        try
        {
            guardando = true;
            mensajeError = string.Empty;

            // Asignar peajes al contrato
            nuevoContrato.PeajeLuz = peajeLuzSeleccionado;
            nuevoContrato.PeajeGas = peajeGasSeleccionado;

            var exito = await ContratoService.CrearAsync(nuevoContrato);
            if (!exito)
            {
                mensajeError = "Error al guardar el contrato";
                return;
            }

            // Guardar facturas pendientes si existen
            if (nuevoContrato.Id > 0 && facturasPendientes.Any())
            {
                foreach (var factura in facturasPendientes)
                {
                    await FicheroContratoService.GuardarFacturaAsync(
                        nuevoContrato.Id,
                        factura.nombreArchivo,
                        factura.contenido
                    );
                }
            }
            
            await OnContratoCreado.InvokeAsync();
            await CerrarWizard();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al guardar contrato: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task CerrarWizard()
    {
        mostrarWizard = false;
        pasoActual = 1;
        clienteSeleccionado = null;
        comercializadoraSeleccionada = null;
        nuevoContrato = null;
        archivosPendientesCliente.Clear();
        facturasPendientes.Clear();
        await OnCerrar.InvokeAsync();
    }

    private string ObtenerMimeType(string? nombreArchivo)
    {
        if (string.IsNullOrEmpty(nombreArchivo))
            return "image/png";

        var extension = Path.GetExtension(nombreArchivo).ToLowerInvariant();
        return extension switch
        {
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".svg" => "image/svg+xml",
            ".webp" => "image/webp",
            _ => "image/png"
        };
    }

    private void LimpiarCamposTitularIbanSiNoMarcado()
    {
        if (nuevoContrato != null && !nuevoContrato.TitularIbanDiferente)
        {
            nuevoContrato.TitularIbanDni = "";
            nuevoContrato.TitularIbanNombre = "";
            nuevoContrato.TitularIbanNumero = "";
        }
    }

    // Métodos para manejo de archivos adjuntos
    private async Task SubirArchivo(InputFileChangeEventArgs e, string tipoFichero)
    {
        try
        {
            var archivo = e.File;
            
            // Validar tamaño (máx 10MB)
            if (archivo.Size > 10 * 1024 * 1024)
            {
                mensajeError = "El archivo no puede superar los 10 MB";
                return;
            }

            // Leer contenido del archivo
            using var ms = new MemoryStream();
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            var contenido = ms.ToArray();

            // Guardar en lista temporal (se guardará al crear el cliente)
            if (!archivosPendientesCliente.ContainsKey(tipoFichero))
            {
                archivosPendientesCliente[tipoFichero] = new List<(string, byte[])>();
            }
            archivosPendientesCliente[tipoFichero].Add((archivo.Name, contenido));
            
            mensajeError = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al subir archivo: {ex.Message}";
        }
    }

    private void EliminarArchivoPendiente(string tipoFichero, int index)
    {
        if (archivosPendientesCliente.ContainsKey(tipoFichero) && 
            index >= 0 && 
            index < archivosPendientesCliente[tipoFichero].Count)
        {
            var nombreArchivo = archivosPendientesCliente[tipoFichero][index].nombreArchivo;
            archivosPendientesCliente[tipoFichero].RemoveAt(index);
            
            // Si ya no hay archivos de este tipo, eliminar la clave del diccionario
            if (!archivosPendientesCliente[tipoFichero].Any())
            {
                archivosPendientesCliente.Remove(tipoFichero);
            }
            
            StateHasChanged();
        }
    }

    private async Task CargarFacturaEnergia(InputFileChangeEventArgs e)
    {
        try
        {
            var archivo = e.File;
            if (archivo.Size > 10 * 1024 * 1024)
            {
                mensajeError = "El archivo no debe superar los 10MB";
                return;
            }

            using var ms = new MemoryStream();
            await archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            var contenido = ms.ToArray();

            facturasPendientes.Add((archivo.Name, contenido));
            mensajeError = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar el archivo: {ex.Message}";
        }
    }

    private void EliminarFacturaPendiente(int index)
    {
        if (index >= 0 && index < facturasPendientes.Count)
        {
            var nombreArchivo = facturasPendientes[index].nombreArchivo;
            facturasPendientes.RemoveAt(index);
            StateHasChanged();
        }
    }
