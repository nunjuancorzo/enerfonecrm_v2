@page "/comparador/analizar-factura"
@inject NavigationManager Navigation

<PageTitle>Redirigiendo al Mapeo Manual...</PageTitle>

<div class="container mt-5 text-center">
    <div class="alert alert-info">
        <h4><i class="bi bi-info-circle me-2"></i>Sistema Actualizado</h4>
        <p>El análisis automático de facturas ha sido sustituido por el nuevo <strong>Sistema de Mapeo Manual</strong>.</p>
        <p>Redirigiendo...</p>
        <div class="spinner-border text-primary mt-3" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Redirigir automáticamente al nuevo sistema de mapeo manual
        Navigation.NavigateTo("/comparador/mapeo-manual", forceLoad: false);
    }
}
