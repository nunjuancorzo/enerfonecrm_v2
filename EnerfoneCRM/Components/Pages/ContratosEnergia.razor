            Console.WriteLine($"[DEBUG ContratosEnergia] Contratos cargados: {contratos.Count}");
            
            await CargarConteoObservaciones();
            contratosConFicheros = await FicheroContratoService.ObtenerIdsContratosConFicherosAsync();
            AplicarFiltros();
            
            Console.WriteLine($"[DEBUG ContratosEnergia] Contratos después de filtros: {contratosFiltrados.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR ContratosEnergia] Error al cargar contratos: {ex.Message}");
            Console.WriteLine($"[ERROR ContratosEnergia] StackTrace: {ex.StackTrace}");
            mensajeError = $"Error al cargar contratos: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

