                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="() => mostrarModalContacto = false">
                                Cerrar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Wizard para crear nuevo contrato -->
        <WizardCrearContratoEnergia @ref="wizardNuevoContrato" 
