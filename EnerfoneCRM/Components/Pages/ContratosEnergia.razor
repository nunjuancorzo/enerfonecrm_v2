    private async Task MostrarModalBaja()
    {
        if (contratoSeleccionado == null) return;

        contratoParaBaja = contratoSeleccionado;
        mostrarModalBaja = true;
        cargandoInfoBaja = true;
        observacionesBaja = string.Empty;
        StateHasChanged();

        try
        {
            infoBaja = await ContratoService.VerificarPenalizacionBajaAsync(
                contratoParaBaja.Id,
                ComisionService
            );
            Console.WriteLine($"[DEBUG] Resultado penalización - puedeRechazar: {infoBaja.puedeRechazar}, diasPendientes: {infoBaja.diasPendientes}, importePenalizacion: {infoBaja.importePenalizacion}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al verificar penalización: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            infoBaja = (true, 0, 0);
        }
        finally
        {
            cargandoInfoBaja = false;
            StateHasChanged();
        }
    }

    private void CerrarModalBaja()
    {
        mostrarModalBaja = false;
        contratoParaBaja = null;
        observacionesBaja = string.Empty;
        infoBaja = (false, null, null);
        StateHasChanged();
    }

    private async Task ConfirmarBajaContrato()
    {
        if (contratoParaBaja == null) return;

        procesandoBaja = true;
        StateHasChanged();

        try
        {
            var (exito, decomision) = await ContratoService.DarDeBajaContratoAsync(
                contratoParaBaja.Id,
                ComisionService,
                AuthService.UsuarioActual?.Id,
                DateTime.Now,
                observacionesBaja
            );

            if (exito)
            {
                mensajeExito = $"Contrato #{contratoParaBaja.Id} dado de baja correctamente.";
                
                if (decomision != null)
                {
                    mensajeExito += $" Se ha registrado una decomisión de {decomision.ImporteDecomision:N2}€.";
                }

                CerrarModalBaja();
                CerrarModal();
                await CargarContratos();
            }
            else
            {
                mensajeError = "Error al dar de baja el contrato. Por favor, inténtelo de nuevo.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al procesar la baja: {ex.Message}";
            Console.WriteLine($"Error en ConfirmarBajaContrato: {ex}");
        }
        finally
        {
            procesandoBaja = false;
            StateHasChanged();
        }
    }
