    private void ToggleSeleccionContrato(int contratoId)
    {
        if (contratosSeleccionados.Contains(contratoId))
        {
            contratosSeleccionados.Remove(contratoId);
        }
        else
        {
            contratosSeleccionados.Add(contratoId);
