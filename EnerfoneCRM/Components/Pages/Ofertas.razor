                            }
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.FotovoltaicaObservaciones))
                            {
                                <p><strong>Observaciones:</strong><br />@solicitudSeleccionada.FotovoltaicaObservaciones</p>
                            }
