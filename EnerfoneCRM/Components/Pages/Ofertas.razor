                    @if (solicitudSeleccionada.TipoFibra || solicitudSeleccionada.TipoMovil || solicitudSeleccionada.TipoFibraMovil || solicitudSeleccionada.TipoFibraMovilTv)
                    {
                        <h6 class="text-primary mt-4">Telefonía:</h6>
                        <div class="ps-3">
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.TelefoniaTipoSolicitud))
                            {
                                <p><strong>Tipo:</strong> @solicitudSeleccionada.TelefoniaTipoSolicitud</p>
                            }
                            <p>
                                <strong>Factura:</strong> 
                                @if (string.IsNullOrEmpty(solicitudSeleccionada.TelefoniaRutaFactura))
                                {
                                    <span>No adjuntada</span>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary ms-2" @onclick="() => DescargarArchivo(solicitudSeleccionada.TelefoniaRutaFactura)">
                                        <i class="bi bi-download me-1"></i>Descargar
                                    </button>
                                }
                            </p>
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.TelefoniaContratoActual))
                            {
                                <p><strong>Contrato actual:</strong><br />@solicitudSeleccionada.TelefoniaContratoActual</p>
                            }
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.TelefoniaObservaciones))
                            {
                                <p><strong>Observaciones:</strong><br />@solicitudSeleccionada.TelefoniaObservaciones</p>
                            }
                        </div>
                    }

                    @if (solicitudSeleccionada.TipoAlarma)
                    {
                        <h6 class="text-primary mt-4">Alarma:</h6>
                        <div class="ps-3">
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.AlarmaTipo))
                            {
                                <p><strong>Tipo:</strong> @solicitudSeleccionada.AlarmaTipo</p>
                            }
                            @if (solicitudSeleccionada.AlarmaTieneActual.HasValue)
