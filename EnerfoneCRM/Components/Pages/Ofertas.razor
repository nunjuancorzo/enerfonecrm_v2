<!-- Modal para editar estado y comentarios -->
@if (mostrarModalEdicion && solicitudEditar != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar Solicitud</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalEdicion"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Solicitud #@solicitudEditar.Id</label>
                        <div class="text-muted small">@solicitudEditar.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="estadoSelect" class="form-label fw-bold">Estado</label>
                        <select id="estadoSelect" class="form-select" @bind="solicitudEditar.Estado">
                            <option value="Pendiente">Pendiente</option>
                            <option value="En Proceso">En Proceso</option>
                            <option value="Completada">Completada</option>
                            <option value="Rechazada">Rechazada</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="observacionesAdmin" class="form-label fw-bold">Observaciones del Administrador</label>
                        <textarea id="observacionesAdmin" class="form-control" rows="4" @bind="solicitudEditar.ObservacionesAdmin" placeholder="Añade comentarios o notas sobre esta solicitud..."></textarea>
                        <small class="text-muted">Estos comentarios serán visibles para el comercial</small>
                    </div>

                    <div class="mb-3">
                        <label for="archivoRespuesta" class="form-label fw-bold">
                            <i class="bi bi-paperclip me-2"></i>Archivo Adjunto para el Cliente
                        </label>
                        <InputFile id="archivoRespuesta" class="form-control" OnChange="@CargarArchivoRespuesta" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />
                        <small class="text-muted">
                            El archivo se enviará como adjunto en el email al cliente. Máximo 50MB.
                        </small>
                        @if (archivoRespuestaCargado != null)
                        {
                            <div class="mt-2 alert alert-success d-flex justify-content-between align-items-center py-2">
                                <span>
                                    <i class="bi bi-file-earmark-check me-2"></i>@archivoRespuestaCargado
                                </span>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="EliminarArchivoRespuesta">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(solicitudEditar.RutaArchivoRespuesta))
                        {
                            <div class="mt-2 alert alert-info py-2">
                                <i class="bi bi-file-earmark me-2"></i>
                                Archivo anterior: @Path.GetFileName(solicitudEditar.RutaArchivoRespuesta)
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(mensajeErrorEdicion))
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>@mensajeErrorEdicion
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModalEdicion" disabled="@guardandoEdicion">
                        <i class="bi bi-x-circle me-1"></i>Cancelar
                    </button>
                    <button type="button" class="btn btn-success" @onclick="GuardarEdicion" disabled="@guardandoEdicion">
                        @if (guardandoEdicion)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Guardar Cambios</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    window.descargarArchivo = function(nombreArchivo, dataUrl) {
        const link = document.createElement('a');
        link.href = dataUrl;
        link.download = nombreArchivo;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };
</script>

@code {
    private bool cargado = false;
    private bool cargandoSolicitudes = false;
    private bool mostrarFormulario = false;
    private bool mostrarModalDetalle = false;
    private bool mostrarModalEdicion = false;
    private bool enviando = false;
    private bool guardandoEdicion = false;
    private string mensajeError = string.Empty;
    private string mensajeExito = string.Empty;
    private string mensajeErrorEdicion = string.Empty;

    private SolicitudOferta nuevaSolicitud = new();
    private List<SolicitudOferta> solicitudes = new();
    private SolicitudOferta? solicitudSeleccionada;
    private SolicitudOferta? solicitudEditar;

    // Paginación
    private int paginaActual = 1;
    private int itemsPorPagina = 10;
    private int TotalPaginas => (int)Math.Ceiling((double)solicitudes.Count / itemsPorPagina);

    // Archivos cargados
    private IBrowserFile? facturaLuzGas;
    private string facturaLuzGasNombre = string.Empty;
    private IBrowserFile? facturaFotovoltaica;
    private string facturaFotovoltaicaNombre = string.Empty;
    private IBrowserFile? facturaTelefonia;
    private string facturaTelefoniaNombre = string.Empty;
    
    // Archivo de respuesta para el modal de edición
    private IBrowserFile? archivoRespuesta;
    private byte[]? archivoRespuestaContenido;
    private string? archivoRespuestaCargado;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            cargado = true;
            if (AuthService.EstaAutenticado)
            {
                InicializarNuevaSolicitud();
                await CargarSolicitudes();
            }
            StateHasChanged();
        }
    }

    private void InicializarNuevaSolicitud()
    {
        if (AuthService.UsuarioActual != null)
        {
            nuevaSolicitud = new SolicitudOferta
            {
                UsuarioId = AuthService.UsuarioActual.Id,
                NombreComercial = AuthService.UsuarioActual.NombreUsuario,
                EmailComercial = AuthService.UsuarioActual.Email,
                TelefoniaTipoSolicitud = "Alta Nueva",
                AlarmaTipo = "Residencial",
                LuzGasTipoCliente = "Residencial"
            };
        }
    }

    private async Task CargarSolicitudes()
    {
        try
        {
            cargandoSolicitudes = true;
            if (AuthService.UsuarioActual != null)
            {
                if (AuthService.PuedeGestionarOfertas)
                {
                    // Admin y Backoffice con permisos ven todas las ofertas
                    solicitudes = await OfertaService.ObtenerTodasAsync();
                }
                else
                {
                    solicitudes = await OfertaService.ObtenerPorUsuarioAsync(AuthService.UsuarioActual.Id);
                }
            }
            // Resetear a la primera página cuando se recargan las solicitudes
            paginaActual = 1;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar solicitudes: {ex.Message}";
        }
        finally
        {
            cargandoSolicitudes = false;
        }
    }

    private List<SolicitudOferta> ObtenerSolicitudesPaginadas()
    {
        return solicitudes
            .Skip((paginaActual - 1) * itemsPorPagina)
            .Take(itemsPorPagina)
            .ToList();
    }

    private void CambiarElementosPorPaginaEvento(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad))
        {
            itemsPorPagina = nuevaCantidad;
            paginaActual = 1;
        }
    }

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= TotalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void MostrarFormularioNuevaSolicitud()
    {
        InicializarNuevaSolicitud();
        facturaLuzGas = null;
        facturaLuzGasNombre = string.Empty;
        facturaFotovoltaica = null;
        facturaFotovoltaicaNombre = string.Empty;
        facturaTelefonia = null;
        facturaTelefoniaNombre = string.Empty;
        mostrarFormulario = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void CancelarFormulario()
    {
        mostrarFormulario = false;
        InicializarNuevaSolicitud();
    }

    private void CargarFacturaLuzGas(InputFileChangeEventArgs e)
    {
        facturaLuzGas = e.File;
        facturaLuzGasNombre = e.File.Name;
    }

    private void CargarFacturaFotovoltaica(InputFileChangeEventArgs e)
    {
        facturaFotovoltaica = e.File;
        facturaFotovoltaicaNombre = e.File.Name;
    }

    private void CargarFacturaTelefonia(InputFileChangeEventArgs e)
    {
        facturaTelefonia = e.File;
        facturaTelefoniaNombre = e.File.Name;
    }

    private async Task CargarArchivoRespuesta(InputFileChangeEventArgs e)
    {
        try
        {
            archivoRespuesta = e.File;
            
            if (archivoRespuesta.Size > 50 * 1024 * 1024)
            {
                mensajeErrorEdicion = "El archivo no debe superar los 50MB";
                archivoRespuesta = null;
                archivoRespuestaCargado = null;
                return;
            }

            using var ms = new MemoryStream();
            await archivoRespuesta.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
            archivoRespuestaContenido = ms.ToArray();
            archivoRespuestaCargado = archivoRespuesta.Name;
            mensajeErrorEdicion = string.Empty;
        }
        catch (Exception ex)
        {
            mensajeErrorEdicion = $"Error al cargar el archivo: {ex.Message}";
            archivoRespuesta = null;
            archivoRespuestaCargado = null;
        }
    }

    private void EliminarArchivoRespuesta()
    {
        archivoRespuesta = null;
        archivoRespuestaContenido = null;
        archivoRespuestaCargado = null;
    }

    private async Task<string?> GuardarArchivo(IBrowserFile archivo, string carpeta)
    {
        try
        {
            var timestamp = DateTime.Now.ToString("yyyyMMddHHmmss");
            var extension = Path.GetExtension(archivo.Name);
            var nombreArchivo = $"{timestamp}_{Path.GetFileNameWithoutExtension(archivo.Name)}{extension}";
            var storagePath = Path.Combine(Directory.GetCurrentDirectory(), "storage");
            var rutaCarpeta = Path.Combine(storagePath, "ofertas", carpeta);
            
            Directory.CreateDirectory(rutaCarpeta);
            
            var rutaCompleta = Path.Combine(rutaCarpeta, nombreArchivo);

            await using var stream = archivo.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50MB
            await using var fileStream = File.Create(rutaCompleta);
            await stream.CopyToAsync(fileStream);

            return rutaCompleta;
        }
        catch
        {
            return null;
        }
    }

    private async Task EnviarSolicitud()
    {
        try
        {
            mensajeError = string.Empty;
            mensajeExito = string.Empty;

            // Validar que se haya seleccionado al menos un tipo
            if (!nuevaSolicitud.TipoLuz && !nuevaSolicitud.TipoGas && !nuevaSolicitud.TipoFotovoltaica &&
                !nuevaSolicitud.TipoFibra && !nuevaSolicitud.TipoMovil && !nuevaSolicitud.TipoFibraMovil &&
                !nuevaSolicitud.TipoFibraMovilTv && !nuevaSolicitud.TipoAlarma)
            {
                mensajeError = "Debes seleccionar al menos un tipo de oferta";
                return;
            }

            // Validar datos del interesado
            if (string.IsNullOrWhiteSpace(nuevaSolicitud.NombreInteresado) || 
                string.IsNullOrWhiteSpace(nuevaSolicitud.TelefonoInteresado) || 
                string.IsNullOrWhiteSpace(nuevaSolicitud.EmailInteresado))
            {
                mensajeError = "Debes completar los datos del interesado (Nombre, Teléfono y Email)";
                return;
            }

            // Validar tipo de cliente para Luz/Gas
            if ((nuevaSolicitud.TipoLuz || nuevaSolicitud.TipoGas) && string.IsNullOrWhiteSpace(nuevaSolicitud.LuzGasTipoCliente))
            {
                mensajeError = "Debes seleccionar el tipo de cliente (Residencial o PYME) para Luz/Gas";
                return;
            }

            enviando = true;

            // Guardar archivos
            if (facturaLuzGas != null)
            {
                nuevaSolicitud.LuzGasRutaFactura = await GuardarArchivo(facturaLuzGas, "luz-gas");
            }

            if (facturaFotovoltaica != null)
            {
                nuevaSolicitud.FotovoltaicaRutaFactura = await GuardarArchivo(facturaFotovoltaica, "fotovoltaica");
            }

            if (facturaTelefonia != null)
            {
                nuevaSolicitud.TelefoniaRutaFactura = await GuardarArchivo(facturaTelefonia, "telefonia");
            }

            // Guardar en base de datos
            var exito = await OfertaService.CrearAsync(nuevaSolicitud);

            if (exito)
            {
                // Obtener emails de todos los administradores
                var emailsAdmin = await ObtenerEmailsAdministradores();
                
                // Enviar email a todos los administradores
                if (emailsAdmin.Any())
                {
                    foreach (var emailAdmin in emailsAdmin)
                    {
                        var (exitoEmail, mensajeEmail) = await OfertaService.EnviarEmailSolicitudAsync(nuevaSolicitud, emailAdmin);
                        if (!exitoEmail)
                        {
                            Console.WriteLine($"Error al enviar email a {emailAdmin}: {mensajeEmail}");
                        }
                    }
                }

                // Enviar email de confirmación al comercial
                var (exitoConfirmacion, _) = await OfertaService.EnviarEmailConfirmacionComercialAsync(nuevaSolicitud);
                if (!exitoConfirmacion)
                {
                    Console.WriteLine("Error al enviar email de confirmación al comercial");
                }

                mensajeExito = "Solicitud enviada correctamente. Recibirás un email de confirmación y el administrador revisará tu solicitud.";
                mostrarFormulario = false;
                await CargarSolicitudes();
                InicializarNuevaSolicitud();
            }
            else
            {
                mensajeError = "Error al enviar la solicitud. Inténtalo de nuevo.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            enviando = false;
        }
    }

    private async Task EnviarSolicitudFromModal()
    {
        await EnviarSolicitud();
    }

    private async Task<string?> ObtenerEmailAdministrador()
    {
        try
        {
            await using var context = DbContextProvider.CreateDbContext();
            var admin = await context.Usuarios
                .Where(u => u.Rol == "Administrador" && u.Activo)
                .FirstOrDefaultAsync();
            return admin?.Email;
        }
        catch
        {
            return null;
        }
    }

    private async Task<List<string>> ObtenerEmailsAdministradores()
    {
        try
        {
            await using var context = DbContextProvider.CreateDbContext();
            var emails = await context.Usuarios
                .Where(u => u.Rol == "Administrador" && u.Activo && !string.IsNullOrEmpty(u.Email))
                .Select(u => u.Email)
                .ToListAsync();
            return emails!;
        }
        catch
        {
            return new List<string>();
        }
    }

    private void VerDetalleSolicitud(SolicitudOferta solicitud)
    {
        solicitudSeleccionada = solicitud;
        mostrarModalDetalle = true;
    }

    private void CerrarModalDetalle()
    {
        mostrarModalDetalle = false;
    }

    private void AbrirModalEdicion(SolicitudOferta? solicitud)
    {
        if (solicitud == null) return;
        
        // Crear una copia para editar
        solicitudEditar = new SolicitudOferta
        {
            Id = solicitud.Id,
            UsuarioId = solicitud.UsuarioId,
            NombreComercial = solicitud.NombreComercial,
            EmailComercial = solicitud.EmailComercial,
            NombreInteresado = solicitud.NombreInteresado,
            TelefonoInteresado = solicitud.TelefonoInteresado,
            EmailInteresado = solicitud.EmailInteresado,
            TipoLuz = solicitud.TipoLuz,
            TipoGas = solicitud.TipoGas,
            TipoFotovoltaica = solicitud.TipoFotovoltaica,
            TipoFibra = solicitud.TipoFibra,
            TipoMovil = solicitud.TipoMovil,
            TipoFibraMovil = solicitud.TipoFibraMovil,
            TipoFibraMovilTv = solicitud.TipoFibraMovilTv,
            TipoAlarma = solicitud.TipoAlarma,
            LuzGasTipoCliente = solicitud.LuzGasTipoCliente,
            LuzGasRutaFactura = solicitud.LuzGasRutaFactura,
            LuzGasObservaciones = solicitud.LuzGasObservaciones,
            FotovoltaicaRutaFactura = solicitud.FotovoltaicaRutaFactura,
            FotovoltaicaEnlaceMaps = solicitud.FotovoltaicaEnlaceMaps,
            FotovoltaicaObservaciones = solicitud.FotovoltaicaObservaciones,
            TelefoniaTipoSolicitud = solicitud.TelefoniaTipoSolicitud,
            TelefoniaRutaFactura = solicitud.TelefoniaRutaFactura,
            TelefoniaContratoActual = solicitud.TelefoniaContratoActual,
            TelefoniaObservaciones = solicitud.TelefoniaObservaciones,
            AlarmaTipo = solicitud.AlarmaTipo,
            AlarmaTieneActual = solicitud.AlarmaTieneActual,
            AlarmaObservaciones = solicitud.AlarmaObservaciones,
            FechaCreacion = solicitud.FechaCreacion,
            Estado = solicitud.Estado,
            ObservacionesAdmin = solicitud.ObservacionesAdmin,
            RutaArchivoRespuesta = solicitud.RutaArchivoRespuesta,
            FechaProcesado = solicitud.FechaProcesado
        };
        
        // Limpiar archivo de respuesta previo
        archivoRespuesta = null;
        archivoRespuestaContenido = null;
        archivoRespuestaCargado = null;
        
        mensajeErrorEdicion = string.Empty;
        mostrarModalDetalle = false;
        mostrarModalEdicion = true;
    }

    private void CerrarModalEdicion()
    {
        mostrarModalEdicion = false;
        solicitudEditar = null;
        archivoRespuesta = null;
        archivoRespuestaContenido = null;
        archivoRespuestaCargado = null;
        mensajeErrorEdicion = string.Empty;
    }

    private async Task GuardarEdicion()
    {
        if (solicitudEditar == null) return;

        try
        {
            guardandoEdicion = true;
            mensajeErrorEdicion = string.Empty;

            // Actualizar fecha de procesado si cambió a Completada o En Proceso
            if (solicitudEditar.Estado != "Pendiente" && !solicitudEditar.FechaProcesado.HasValue)
            {
                solicitudEditar.FechaProcesado = DateTime.Now;
            }

            // Guardar archivo de respuesta si existe
            if (archivoRespuesta != null && archivoRespuestaContenido != null)
            {
                try
                {
                    var storagePath = Path.Combine(Directory.GetCurrentDirectory(), "storage");
                    var carpetaRespuestas = Path.Combine(storagePath, "ofertas", "respuestas");
                    if (!Directory.Exists(carpetaRespuestas))
                    {
                        Directory.CreateDirectory(carpetaRespuestas);
                    }

                    var nombreArchivo = $"respuesta_{solicitudEditar.Id}_{DateTime.Now:yyyyMMddHHmmss}_{archivoRespuesta.Name}";
                    var rutaCompleta = Path.Combine(carpetaRespuestas, nombreArchivo);

                    await File.WriteAllBytesAsync(rutaCompleta, archivoRespuestaContenido);
                    solicitudEditar.RutaArchivoRespuesta = rutaCompleta;
                }
                catch (Exception exArchivo)
                {
                    mensajeErrorEdicion = $"Error al guardar el archivo: {exArchivo.Message}";
                    guardandoEdicion = false;
                    return;
                }
            }

            var exito = await OfertaService.ActualizarAsync(solicitudEditar);

            if (exito)
            {
                // Notificar al comercial sobre el cambio con el archivo adjunto si existe
                var (exitoNotificacion, _) = await OfertaService.EnviarEmailCambioEstadoAsync(solicitudEditar);
                if (!exitoNotificacion)
                {
                    Console.WriteLine("Error al enviar notificación al comercial");
                }

                mensajeExito = "Solicitud actualizada correctamente. El comercial ha sido notificado.";
                await CargarSolicitudes();
                CerrarModalEdicion();
            }
            else
            {
                mensajeErrorEdicion = "Error al actualizar la solicitud";
            }
        }
        catch (Exception ex)
        {
            mensajeErrorEdicion = $"Error: {ex.Message}";
        }
        finally
        {
            guardandoEdicion = false;
        }
    }

    private async Task DescargarArchivo(string? rutaArchivo)
    {
        if (string.IsNullOrEmpty(rutaArchivo))
        {
            mensajeError = "No se encontró el archivo";
            return;
        }

        try
        {
            var (exito, contenido, nombreArchivo, mimeType) = await OfertaService.DescargarArchivoAsync(rutaArchivo);
            
            if (exito && contenido != null && !string.IsNullOrEmpty(nombreArchivo))
            {
                // Convertir a base64 y descargar en el navegador
                var base64 = Convert.ToBase64String(contenido);
                var dataUrl = $"data:{mimeType};base64,{base64}";
                
                // Usar JavaScript para descargar el archivo
                await JSRuntime.InvokeVoidAsync("descargarArchivo", nombreArchivo, dataUrl);
            }
            else
            {
                mensajeError = "No se pudo descargar el archivo. Puede que haya sido eliminado.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al descargar archivo: {ex.Message}";
        }
    }

    // Mapear estados a colores distintivos
    private string ObtenerColorEstado(string? estado)
    {
        return estado?.ToLower() switch
        {
            "pendiente" => "bg-warning text-dark",
            "en proceso" => "bg-primary",
            "completada" => "bg-success",
            "rechazada" => "bg-danger",
            "cancelada" => "bg-danger",
            "archivada" => "bg-secondary",
            _ => "bg-info"
        };
    }

