@page "/administracion/codigos-postales"
@using EnerfoneCRM.Models
@using EnerfoneCRM.Services
@rendermode InteractiveServer
@inject CodigoPostalService CodigoPostalService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Gestión de Códigos Postales</PageTitle>

@if (cargandoSesion)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    @if (!AuthService.EstaAutenticado || AuthService.UsuarioActual?.Rol != "Administrador")
    {
        <div class="alert alert-warning m-4">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No tienes acceso a esta página. Se requiere rol de Administrador.
        </div>
    }
    else
    {
        <div class="container-fluid mt-4">
            <div class="row">
                <div class="col-12">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">
                                <i class="bi bi-geo-alt"></i> Maestro de Códigos Postales
                            </h4>
                            <button class="btn btn-light btn-sm" @onclick="AbrirModalNuevo">
                                <i class="bi bi-plus-circle"></i> Nuevo Código Postal
                            </button>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(mensajeExito))
                            {
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    <i class="bi bi-check-circle me-2"></i>@mensajeExito
                                    <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(mensajeError))
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>@mensajeError
                                    <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                                </div>
                            }

                            <!-- Filtros de búsqueda -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                                        <input type="text" class="form-control" placeholder="Buscar por código postal, ciudad o provincia..." 
                                               @bind="textoBusqueda" @bind:event="oninput" @onkeyup="Buscar" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select" @bind="filtroActivo" @bind:after="CargarCodigosPostales">
                                        <option value="">Todos los estados</option>
                                        <option value="true">Solo activos</option>
                                        <option value="false">Solo inactivos</option>
                                    </select>
                                </div>
                                <div class="col-md-3 text-end">
                                    <span class="badge bg-info fs-6">Total: @totalElementos</span>
                                </div>
                            </div>

                            @if (cargando)
                            {
                                <div class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Cargando...</span>
                                    </div>
                                    <p class="mt-2">Cargando códigos postales...</p>
                                </div>
                            }
                            else if (codigosPostalesFiltrados.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm">
                                        <thead>
                                            <tr>
                                                <th style="width: 10%">CP</th>
                                                <th style="width: 30%">Ciudad</th>
                                                <th style="width: 25%">Provincia</th>
                                                <th style="width: 10%">Estado</th>
                                                <th style="width: 15%">Fecha Creación</th>
                                                <th style="width: 10%">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var cp in codigosPostalesFiltrados)
                                            {
                                                <tr>
                                                    <td><strong>@cp.CodigoPostalValor</strong></td>
                                                    <td>@cp.Ciudad</td>
                                                    <td>@cp.Provincia</td>
                                                    <td>
                                                        @if (cp.Activo)
                                                        {
                                                            <span class="badge bg-success">Activo</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">Inactivo</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <small>@(cp.FechaCreacion?.ToString("dd/MM/yyyy") ?? "-")</small>
                                                    </td>
                                                    <td>
                                                        <div class="btn-group btn-group-sm">
                                                            <button class="btn btn-outline-primary" 
                                                                    @onclick="() => AbrirModalEditar(cp)"
                                                                    title="Editar">
                                                                <i class="bi bi-pencil"></i>
                                                            </button>
                                                            <button class="btn btn-outline-danger" 
                                                                    @onclick="() => ConfirmarEliminar(cp)"
                                                                    title="Eliminar">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                @* Paginación *@
                                <div class="d-flex justify-content-between align-items-center mt-3 px-3 pb-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <small class="text-muted">
                                            Mostrando @((paginaActual - 1) * elementosPorPagina + 1) - @(Math.Min(paginaActual * elementosPorPagina, totalElementos)) de @totalElementos códigos postales
                                        </small>
                                        <div class="d-flex align-items-center gap-2">
                                            <small class="text-muted">Mostrar:</small>
                                            <select class="form-select form-select-sm" style="width: auto;" @onchange="CambiarElementosPorPaginaEvento">
                                                <option value="10" selected="@(elementosPorPagina == 10)">10</option>
                                                <option value="25" selected="@(elementosPorPagina == 25)">25</option>
                                                <option value="50" selected="@(elementosPorPagina == 50)">50</option>
                                            </select>
                                        </div>
                                    </div>
                                    @if (totalPaginas > 1)
                                    {
                                        <nav>
                                            <ul class="pagination pagination-sm mb-0">
                                                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                                    <button class="page-link" @onclick="() => CambiarPagina(1)" disabled="@(paginaActual == 1)">
                                                        <i class="bi bi-chevron-double-left"></i>
                                                    </button>
                                                </li>
                                                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)" disabled="@(paginaActual == 1)">
                                                        <i class="bi bi-chevron-left"></i>
                                                    </button>
                                                </li>
                                                @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
                                                {
                                                    var pagina = i;
                                                    <li class="page-item @(paginaActual == pagina ? "active" : "")">
                                                        <button class="page-link" @onclick="() => CambiarPagina(pagina)">@pagina</button>
                                                    </li>
                                                }
                                                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                                    <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)" disabled="@(paginaActual == totalPaginas)">
                                                        <i class="bi bi-chevron-right"></i>
                                                    </button>
                                                </li>
                                                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                                    <button class="page-link" @onclick="() => CambiarPagina(totalPaginas)" disabled="@(paginaActual == totalPaginas)">
                                                        <i class="bi bi-chevron-double-right"></i>
                                                    </button>
                                                </li>
                                            </ul>
                                        </nav>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <h5><i class="bi bi-info-circle"></i> No hay códigos postales</h5>
                                    <p>Comienza agregando códigos postales para facilitar la carga de datos en clientes y contratos.</p>
                                    <button class="btn btn-primary" @onclick="AbrirModalNuevo">
                                        <i class="bi bi-plus-circle"></i> Agregar Primer Código Postal
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Crear/Editar -->
        @if (mostrarModal)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="bi bi-geo-alt"></i> @(codigoPostalEditando?.Id > 0 ? "Editar" : "Nuevo") Código Postal
                            </h5>
                            <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Código Postal <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" maxlength="5" 
                                       @bind="codigoPostalEditando.CodigoPostalValor"
                                       placeholder="Ej: 28001"
                                       disabled="@(codigoPostalEditando.Id > 0)" />
                                <small class="text-muted">5 dígitos numéricos</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ciudad <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="codigoPostalEditando.Ciudad"
                                       placeholder="Ej: Madrid" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Provincia <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="codigoPostalEditando.Provincia"
                                       placeholder="Ej: Madrid" />
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="codigoPostalEditando.Activo" id="checkActivo" />
                                <label class="form-check-label" for="checkActivo">
                                    Activo
                                </label>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="button" class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                                @if (guardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-save me-2"></i> Guardar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Modal Confirmación Eliminar -->
        @if (mostrarModalEliminar)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle"></i> Confirmar Eliminación
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalEliminar"></button>
                        </div>
                        <div class="modal-body">
                            <p>¿Estás seguro de que deseas eliminar el código postal <strong>@codigoPostalAEliminar?.CodigoPostalValor</strong> (@codigoPostalAEliminar?.Ciudad, @codigoPostalAEliminar?.Provincia)?</p>
                            <p class="text-danger"><i class="bi bi-exclamation-circle"></i> Esta acción no se puede deshacer.</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModalEliminar">Cancelar</button>
                            <button type="button" class="btn btn-danger" @onclick="EliminarConfirmado" disabled="@eliminando">
                                @if (eliminando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-trash me-2"></i> Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private bool cargandoSesion = true;
    private bool cargando = true;
    private bool guardando = false;
    private bool eliminando = false;
    private bool mostrarModal = false;
    private bool mostrarModalEliminar = false;

    private List<CodigoPostal> codigosPostales = new();
    private List<CodigoPostal> codigosPostalesFiltrados = new();
    private CodigoPostal codigoPostalEditando = new();
    private CodigoPostal? codigoPostalAEliminar;

    private string textoBusqueda = string.Empty;
    private string filtroActivo = "true";
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    // Variables de paginación
    private int paginaActual = 1;
    private int elementosPorPagina = 25;
    private int totalElementos = 0;
    private int totalPaginas = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.CargarSesionAsync();
            cargandoSesion = false;

            if (!AuthService.EstaAutenticado || AuthService.UsuarioActual?.Rol != "Administrador")
            {
                Navigation.NavigateTo("/", true);
                return;
            }

            await CargarCodigosPostales();
            StateHasChanged();
        }
    }

    private async Task CargarCodigosPostales()
    {
        try
        {
            cargando = true;
            codigosPostales = await CodigoPostalService.ObtenerTodosAsync();
            AplicarFiltros();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar códigos postales: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private void AplicarFiltros()
    {
        var codigosParaPaginar = codigosPostales;

        // Filtro por activo/inactivo
        if (!string.IsNullOrEmpty(filtroActivo))
        {
            var esActivo = bool.Parse(filtroActivo);
            codigosParaPaginar = codigosParaPaginar.Where(cp => cp.Activo == esActivo).ToList();
        }

        // Filtro por búsqueda
        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var busqueda = textoBusqueda.Trim().ToLower();
            codigosParaPaginar = codigosParaPaginar
                .Where(cp => 
                    cp.CodigoPostalValor.Contains(busqueda) ||
                    cp.Ciudad.ToLower().Contains(busqueda) ||
                    cp.Provincia.ToLower().Contains(busqueda))
                .ToList();
        }

        // Calcular paginación
        totalElementos = codigosParaPaginar.Count;
        totalPaginas = totalElementos > 0 ? (int)Math.Ceiling(totalElementos / (double)elementosPorPagina) : 0;
        
        // Asegurar que la página actual esté dentro del rango
        if (totalPaginas == 0)
            paginaActual = 1;
        else if (paginaActual > totalPaginas)
            paginaActual = totalPaginas;
        else if (paginaActual < 1)
            paginaActual = 1;

        // Aplicar paginación
        codigosPostalesFiltrados = codigosParaPaginar
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina)
            .ToList();
    }

    private void Buscar()
    {
        paginaActual = 1;
        AplicarFiltros();
    }

    private void CambiarElementosPorPaginaEvento(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad))
        {
            elementosPorPagina = nuevaCantidad;
            paginaActual = 1;
            AplicarFiltros();
        }
    }

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
            AplicarFiltros();
            StateHasChanged();
        }
    }

    private void AbrirModalNuevo()
    {
        codigoPostalEditando = new CodigoPostal { Activo = true };
        mostrarModal = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void AbrirModalEditar(CodigoPostal cp)
    {
        codigoPostalEditando = new CodigoPostal
        {
            Id = cp.Id,
            CodigoPostalValor = cp.CodigoPostalValor,
            Ciudad = cp.Ciudad,
            Provincia = cp.Provincia,
            Activo = cp.Activo
        };
        mostrarModal = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        codigoPostalEditando = new();
    }

    private async Task Guardar()
    {
        try
        {
            guardando = true;
            mensajeError = string.Empty;
            mensajeExito = string.Empty;

            // Validar
            if (string.IsNullOrWhiteSpace(codigoPostalEditando.CodigoPostalValor) || 
                codigoPostalEditando.CodigoPostalValor.Length != 5)
            {
                mensajeError = "El código postal debe tener 5 dígitos";
                return;
            }

            if (string.IsNullOrWhiteSpace(codigoPostalEditando.Ciudad))
            {
                mensajeError = "La ciudad es obligatoria";
                return;
            }

            if (string.IsNullOrWhiteSpace(codigoPostalEditando.Provincia))
            {
                mensajeError = "La provincia es obligatoria";
                return;
            }

            bool exito;
            if (codigoPostalEditando.Id > 0)
            {
                exito = await CodigoPostalService.ActualizarAsync(codigoPostalEditando);
                mensajeExito = exito ? "Código postal actualizado correctamente" : "No se pudo actualizar el código postal";
            }
            else
            {
                exito = await CodigoPostalService.CrearAsync(codigoPostalEditando);
                mensajeExito = exito ? "Código postal creado correctamente" : "No se pudo crear el código postal";
            }

            if (exito)
            {
                CerrarModal();
                await CargarCodigosPostales();
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private void ConfirmarEliminar(CodigoPostal cp)
    {
        codigoPostalAEliminar = cp;
        mostrarModalEliminar = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void CerrarModalEliminar()
    {
        mostrarModalEliminar = false;
        codigoPostalAEliminar = null;
    }

    private async Task EliminarConfirmado()
    {
        if (codigoPostalAEliminar == null) return;

        try
        {
            eliminando = true;
            var exito = await CodigoPostalService.EliminarAsync(codigoPostalAEliminar.Id);
            
            if (exito)
            {
                mensajeExito = $"Código postal {codigoPostalAEliminar.CodigoPostalValor} eliminado correctamente";
                CerrarModalEliminar();
                await CargarCodigosPostales();
            }
            else
            {
                mensajeError = "No se pudo eliminar el código postal";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al eliminar: {ex.Message}";
        }
        finally
        {
            eliminando = false;
        }
    }
}
