    private ResultadoImportacion ParsearResultado(string salida)
    {
        var resultado = new ResultadoImportacion();
        var lineas = salida.Split('\n');
        var erroresLista = new List<string>();

        foreach (var linea in lineas)
        {
            if (linea.Contains("importados:", StringComparison.OrdinalIgnoreCase) || linea.Contains("Importados:", StringComparison.OrdinalIgnoreCase))
            {
                var partes = linea.Split(':');
                if (partes.Length > 1 && int.TryParse(partes[1].Trim(), out int importados))
                {
                    resultado.Importados = importados;
                }
            }
            else if (linea.Contains("errores:", StringComparison.OrdinalIgnoreCase) || linea.Contains("Errores:", StringComparison.OrdinalIgnoreCase))
            {
                var partes = linea.Split(':');
                if (partes.Length > 1 && int.TryParse(partes[1].Trim(), out int errores))
                {
                    resultado.Errores = errores;
                }
            }
            else if (linea.Contains("[ERROR]"))
            {
                erroresLista.Add(linea.Replace("[ERROR]", "").Trim());
            }
        }

        resultado.DetalleErrores = erroresLista;
        return resultado;
    }

    private async Task ExportarTarifasEnergia()
    {
        try
        {
            procesando = true;
            tipoImportacion = "exportar-energia";
            mensajeError = string.Empty;
            mensajeExito = string.Empty;
            StateHasChanged();

            var directorioActual = Directory.GetCurrentDirectory();
            var scriptPath = Path.Combine(directorioActual, "exportar_tarifas_energia.py");
            var directorioTrabajo = directorioActual;
            
            // Si el script no está en el directorio actual, buscar en el directorio padre (desarrollo)
            if (!File.Exists(scriptPath))
            {
                directorioTrabajo = Path.Combine(directorioActual, "..");
                scriptPath = Path.Combine(directorioTrabajo, "exportar_tarifas_energia.py");
            }

            // Verificar que el script existe
            if (!File.Exists(scriptPath))
            {
                throw new Exception($"No se encontró el script exportar_tarifas_energia.py");
            }

            // Obtener nombre de base de datos según entorno
            var databaseName = EnvironmentService.GetDatabaseName();
            var dbUser = EnvironmentService.GetDatabaseUser();
            var dbPassword = EnvironmentService.GetDatabasePassword();

            // Ejecutar script de Python
            var proceso = new System.Diagnostics.Process
            {
                StartInfo = new System.Diagnostics.ProcessStartInfo
                {
                    FileName = ObtenerRutaPython(),
                    Arguments = $"exportar_tarifas_energia.py \"{databaseName}\" \"{dbUser}\" \"{dbPassword}\"",
                    WorkingDirectory = directorioTrabajo,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                }
            };

            proceso.Start();
            string salida = await proceso.StandardOutput.ReadToEndAsync();
            string errores = await proceso.StandardError.ReadToEndAsync();
            await proceso.WaitForExitAsync();

            // Debug: Mostrar toda la salida
            Console.WriteLine($"[EXPORTAR ENERGIA] Salida completa del script: {salida}");
            Console.WriteLine($"[EXPORTAR ENERGIA] Errores: {errores}");
            Console.WriteLine($"[EXPORTAR ENERGIA] Código de salida: {proceso.ExitCode}");

            if (!string.IsNullOrWhiteSpace(errores))
            {
                mensajeError = $"Error al exportar: {errores}";
                return;
            }

            // Buscar el nombre del archivo generado en la salida
            var lineas = salida.Split('\n');
            string? nombreArchivo = null;
            foreach (var linea in lineas)
            {
                Console.WriteLine($"[EXPORTAR ENERGIA] Procesando línea: '{linea}'");
                if (linea.Contains("tarifas_energia_exportacion_") && linea.Contains(".xlsx"))
                {
                    var inicio = linea.IndexOf("tarifas_energia_exportacion_");
                    var fin = linea.IndexOf(".xlsx", inicio);
                    Console.WriteLine($"[EXPORTAR ENERGIA] Encontrado en línea - inicio: {inicio}, fin: {fin}");
                    if (inicio >= 0 && fin > inicio)
                    {
                        nombreArchivo = linea.Substring(inicio, fin - inicio + 5);
                        Console.WriteLine($"[EXPORTAR ENERGIA] Nombre extraído: {nombreArchivo}");
                        break;
                    }
                }
            }

            // Si no se encontró, intentar buscar en todo el directorio
            if (nombreArchivo == null)
            {
                Console.WriteLine($"[EXPORTAR ENERGIA] Buscando archivos en: {directorioTrabajo}");
                var archivos = Directory.GetFiles(directorioTrabajo, "tarifas_energia_exportacion_*.xlsx")
                    .OrderByDescending(f => File.GetCreationTime(f))
                    .ToList();
                Console.WriteLine($"[EXPORTAR ENERGIA] Archivos encontrados: {archivos.Count}");
                if (archivos.Any())
                {
                    nombreArchivo = Path.GetFileName(archivos.First());
                    Console.WriteLine($"[EXPORTAR ENERGIA] Usando archivo: {nombreArchivo}");
                }
            }

            if (nombreArchivo != null)
            {
                // El archivo se genera en el directorio de trabajo
                var rutaArchivo = Path.Combine(directorioTrabajo, nombreArchivo);
                
                if (File.Exists(rutaArchivo))
                {
                    // Descargar archivo
                    var bytes = await File.ReadAllBytesAsync(rutaArchivo);
                    await JS.InvokeVoidAsync("descargarArchivo", nombreArchivo, Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
                    
                    mensajeExito = $"Tarifas de energía exportadas correctamente: {nombreArchivo}";
                    
                    // Opcional: eliminar el archivo temporal del servidor
                    File.Delete(rutaArchivo);
                }
                else
                {
                    mensajeError = $"Archivo generado pero no encontrado: {rutaArchivo}";
                }
            }
            else
            {
                mensajeError = "No se pudo determinar el nombre del archivo exportado";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error durante la exportación: {ex.Message}";
        }
        finally
        {
            procesando = false;
            tipoImportacion = string.Empty;
        }
    }

