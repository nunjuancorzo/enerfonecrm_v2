                                    <div class="mt-2">
                                        <small class="text-muted">
                                            <i class="bi bi-file-earmark me-1"></i>Actual: @Path.GetFileName(usuario.ArchivoCif)
                                            <a href="/storage/@usuario.ArchivoCif" target="_blank" class="ms-2"><i class="bi bi-download"></i></a>
                                        </small>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(archivoCifNombre))
                                {
                                    <div class="mt-2">
                                        <small class="text-success">
                                            <i class="bi bi-check-circle me-1"></i>Nuevo: @archivoCifNombre
                                        </small>
                                    </div>
