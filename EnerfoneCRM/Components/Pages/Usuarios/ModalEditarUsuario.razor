    private void OnRolChanged()
    {
        // Limpiar comercializadora si cambia el rol y no es Comercializadora
        if (usuario.Rol != "Comercializadora")
        {
            usuario.Comercializadora = null;
        }
    }

    private async Task HandleSubmit()
    {
        // Validar comercializadora obligatoria para rol Comercializadora
        if (usuario.Rol == "Comercializadora" && string.IsNullOrEmpty(usuario.Comercializadora))
        {
            return; // No enviar si falta comercializadora
        }

        // Validar que solo puede haber un administrador
        if (usuario.Rol == "Administrador" && rolOriginal != "Administrador")
        {
            // Verificar si ya existe un administrador
            var todosUsuarios = await UsuarioService.ObtenerTodosAsync();
            var existeAdministrador = todosUsuarios.Any(u => u.Rol == "Administrador" && u.Id != usuario.Id);
            
            if (existeAdministrador)
            {
                mensajeError = "Ya existe un usuario con rol Administrador. Solo puede haber un administrador por sistema.";
                return;
            }
        }

        // Guardar archivos si se seleccionaron nuevos
        try
        {
            if (archivoDni != null)
            {
                usuario.ArchivoDni = await GuardarArchivo(archivoDni, "dni");
            }
            if (archivoCif != null)
            {
                usuario.ArchivoCif = await GuardarArchivo(archivoCif, "cif");
            }
            if (archivoPoder != null)
            {
                usuario.ArchivoPoder = await GuardarArchivo(archivoPoder, "poder");
            }
            if (archivoContrato != null)
            {
                usuario.ArchivoContrato = await GuardarArchivo(archivoContrato, "contrato");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar archivos: {ex.Message}");
            return;
        }

        // Si se proporcionó una nueva contraseña, actualizarla
        if (!string.IsNullOrWhiteSpace(nuevaPassword))
        {
            usuario.PasswordHash = nuevaPassword;
        }
        
        // Actualizar la jerarquía basándose en las selecciones de los checkboxes
        // Esto asegura que los campos *Id de los subordinados se actualicen correctamente
        
        // Si es Gestor: actualizar GestorId de los colaboradores seleccionados
        if (usuario.Rol == "Gestor")
        {
            Console.WriteLine($"[JERARQUÍA] Gestor {usuario.Id} - {colaboradoresSeleccionados.Count} colaboradores seleccionados");
        }
        
        // Si es Jefe de Ventas: actualizar JefeVentasId de gestores y colaboradores seleccionados
        if (usuario.Rol == "Jefe de ventas")
        {
            Console.WriteLine($"[JERARQUÍA] Jefe de Ventas {usuario.Id} - {gestoresSeleccionados.Count} gestores y {colaboradoresSeleccionados.Count} colaboradores seleccionados");
        }
        
        // Si es Director Comercial: actualizar DirectorComercialId de jefes, gestores y colaboradores
        if (usuario.Rol == "Director comercial")
        {
            Console.WriteLine($"[JERARQUÍA] Director Comercial {usuario.Id} - {jefesVentasSeleccionados.Count} jefes, {gestoresSeleccionados.Count} gestores y {colaboradoresSeleccionados.Count} colaboradores seleccionados");
        }
        
        // Invocar OnGuardar con todos los datos necesarios
        await OnGuardar.InvokeAsync((
            usuario,
            comercializadorasSeleccionadas.ToList(),
            operadorasSeleccionadas.ToList(),
            empresasAlarmasSeleccionadas.ToList(),
            colaboradoresSeleccionados.ToList(),
            gestoresSeleccionados.ToList(),
            jefesVentasSeleccionados.ToList()
        ));
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e, string tipoArchivo)
    {
        var file = e.File;
        if (file != null)
        {
            switch (tipoArchivo)
            {
                case "dni":
                    archivoDni = file;
                    archivoDniNombre = file.Name;
                    break;
                case "cif":
                    archivoCif = file;
                    archivoCifNombre = file.Name;
                    break;
                case "poder":
                    archivoPoder = file;
                    archivoPoderNombre = file.Name;
                    break;
                case "contrato":
                    archivoContrato = file;
                    archivoContratoNombre = file.Name;
                    break;
            }
        }
    }

    private async Task<string> GuardarArchivo(IBrowserFile file, string tipoDocumento)
    {
        var timestamp = DateTime.Now.ToString("yyyyMMddHHmmss");
        var nombreArchivo = $"{timestamp}_{tipoDocumento}_{file.Name}";
        var rutaStorage = Path.Combine("storage", "usuarios");
        
        // Crear directorio si no existe
        Directory.CreateDirectory(rutaStorage);
        
        var rutaCompleta = Path.Combine(rutaStorage, nombreArchivo);
        
        await using var stream = file.OpenReadStream(maxAllowedSize: 10485760); // 10 MB máximo
        await using var fileStream = File.Create(rutaCompleta);
        await stream.CopyToAsync(fileStream);
        
        return $"usuarios/{nombreArchivo}"; // Ruta relativa para la BD
    }

    private async Task EnviarCredencialesEmail()
    {
        try
        {
            // Verificar permisos
            if (!AuthService.EsAdministrador && !AuthService.EsSuperAdmin)
            {
                mensajeError = "No tienes permisos para enviar credenciales por email.";
                return;
            }

            // Validar que el usuario tenga email
            if (string.IsNullOrWhiteSpace(usuario.Email))
            {
                mensajeError = "El usuario no tiene una dirección de email configurada.";
                return;
            }

            enviandoEmail = true;
            StateHasChanged();

            // Preparar el contenido del email
            string nombreCompleto = $"{usuario.Nombre} {usuario.Apellidos}".Trim();
            if (string.IsNullOrEmpty(nombreCompleto))
            {
                nombreCompleto = usuario.NombreUsuario;
            }

            string subject = "Credenciales de Acceso - Enerfone CRM";
            
            string cuerpoHtml = $@"
                <html>
                <head>
                    <style>
                        body {{ font-family: Arial, sans-serif; line-height: 1.6; color: #333; }}
                        .container {{ max-width: 600px; margin: 0 auto; padding: 20px; }}
