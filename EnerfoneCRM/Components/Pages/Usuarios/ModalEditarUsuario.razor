                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Copia Poder / Escrituras de la Empresa</label>
                                <InputFile OnChange="@((e) => HandleFileSelected(e, "poder"))" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
