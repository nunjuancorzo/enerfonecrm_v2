            ";

            // Enviar el email
            await EmailService.EnviarEmailSimpleAsync(usuario.Email, subject, cuerpoHtml);

            // Limpiar mensaje de error en caso de que hubiera alguno previo
            mensajeError = string.Empty;

            // Nota: No mostramos mensaje de éxito aquí porque estamos en un modal
            // El mensaje de éxito se mostrará desde el componente padre
        }
        catch (Exception ex)
