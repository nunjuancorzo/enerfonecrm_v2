                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerContratos" class="form-check-input" @bind-Value="usuario.PuedeVerContratos" />
                                    <label class="form-check-label" for="puedeVerContratos">
                                        <i class="bi bi-file-text me-1"></i>Ver Contratos
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerTarifas" class="form-check-input" @bind-Value="usuario.PuedeVerTarifas" />
                                    <label class="form-check-label" for="puedeVerTarifas">
                                        <i class="bi bi-cash-stack me-1"></i>Ver Tarifas
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerLiquidaciones" class="form-check-input" @bind-Value="usuario.PuedeVerLiquidaciones" />
                                    <label class="form-check-label" for="puedeVerLiquidaciones">
                                        <i class="bi bi-calculator me-1"></i>Ver Liquidaciones
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerSips" class="form-check-input" @bind-Value="usuario.PuedeVerSips" />
                                    <label class="form-check-label" for="puedeVerSips">
                                        <i class="bi bi-diagram-3 me-1"></i>Ver SIPS
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerIncidencias" class="form-check-input" @bind-Value="usuario.PuedeVerIncidencias" />
                                    <label class="form-check-label" for="puedeVerIncidencias">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Ver Incidencias
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerOfertas" class="form-check-input" @bind-Value="usuario.PuedeVerOfertas" />
                                    <label class="form-check-label" for="puedeVerOfertas">
                                        <i class="bi bi-gift me-1"></i>Ver Ofertas
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="puedeVerUsuarios" class="form-check-input" @bind-Value="usuario.PuedeVerUsuarios" />
                                    <label class="form-check-label" for="puedeVerUsuarios">
                                        <i class="bi bi-person-badge me-1"></i>Ver Usuarios
                                    </label>
                                </div>
                            </div>
