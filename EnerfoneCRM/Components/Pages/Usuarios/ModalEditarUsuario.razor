                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Contrato de Colaboración</label>
                                <InputFile OnChange="@((e) => HandleFileSelected(e, "contrato"))" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                                @if (!string.IsNullOrEmpty(usuario.ArchivoContrato))
                                {
