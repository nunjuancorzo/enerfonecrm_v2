@page "/usuarios"
@layout Layout.MainLayout
@using EnerfoneCRM.Models
@using EnerfoneCRM.Services
@using EnerfoneCRM.Components.Pages.Usuarios
@using Microsoft.JSInterop
@inject AuthService AuthService
@inject UsuarioService UsuarioService
@inject EmailService EmailService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Enerfone CRM</PageTitle>

@if (cargandoSesion)
{
    <div class="text-center mt-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!AuthService.EstaAutenticado)
{
    <div class="text-center mt-5">
        <p>Redirigiendo al login...</p>
    </div>
}
else if (!AuthService.EsAdministrador)
{
    <div class="container mt-5">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Acceso Denegado</h4>
            <p>No tienes permisos para acceder a esta sección. Solo los administradores pueden gestionar usuarios.</p>
            <hr>
            <a href="/" class="btn btn-primary">Volver al Inicio</a>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <div class="row mb-3">
            <div class="col">
                <h2>Gestión de Usuarios</h2>
            </div>
            <div class="col text-end">
                <button class="btn btn-success me-2" @onclick="ExportarExcel">
                    <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
                </button>
                <button class="btn btn-info me-2" @onclick="IrALogAccesos">
                    <i class="bi bi-clock-history"></i> Accesos
                </button>
                <button class="btn btn-primary" @onclick="MostrarModalCrear">
                    <span class="bi bi-plus-circle"></span> Nuevo Usuario
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @mensajeExito
                <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @mensajeError
                <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
            </div>
        }

        @if (cargando)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body">
                    <!-- Filtro de búsqueda -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Buscar por nombre, usuario, email o teléfono..." 
                                       @bind="textoBusqueda" 
                                       @bind:event="oninput"
                                       @onkeyup="FiltrarUsuarios" />
                                @if (!string.IsNullOrEmpty(textoBusqueda))
                                {
                                    <button class="btn btn-outline-secondary" type="button" @onclick="LimpiarBusqueda">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-md-6 text-end">
                            <small class="text-muted">
                                Mostrando @usuariosFiltrados.Count de @usuarios.Count usuario(s)
                            </small>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("NombreUsuario")'>
                                        Usuario
                                        @if (columnaOrden == "NombreUsuario")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Email")'>
                                        Email
                                        @if (columnaOrden == "Email")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Telefono")'>
                                        Teléfono
                                        @if (columnaOrden == "Telefono")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Rol")'>
                                        Rol
                                        @if (columnaOrden == "Rol")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Comision")'>
                                        Comisión
                                        @if (columnaOrden == "Comision")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Activo")'>
                                        Activo
                                        @if (columnaOrden == "Activo")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th style="cursor: pointer;" @onclick='() => OrdenarPor("Contratos")'>
                                        Contratos
                                        @if (columnaOrden == "Contratos")
                                        {
                                            <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                        }
                                    </th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var usuario in usuariosFiltrados)
                                {
                                    <tr>
                                        <td><strong>@usuario.NombreUsuario</strong></td>
                                        <td>@usuario.Email</td>
                                        <td>@(string.IsNullOrEmpty(usuario.Telefono) ? "-" : usuario.Telefono)</td>
                                        <td>
                                            <span class="badge bg-@ObtenerColorRol(usuario.Rol)">@usuario.Rol</span>
                                        </td>
                                        <td>@usuario.Comision.ToString("F2")%</td>
                                        <td>
                                            @if (usuario.Activo)
                                            {
                                                <span class="badge bg-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-@(usuario.TotalContratos > 0 ? "primary" : "secondary")">
                                                @usuario.TotalContratos
                                            </span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="async () => await MostrarModalEditar(usuario)" title="Editar">
                                                <span class="bi bi-pencil"></span>
                                            </button>
                                            @if (AuthService.EsAdministrador || AuthService.EsSuperAdmin)
                                            {
                                                <button class="btn btn-sm btn-outline-info me-1" @onclick="() => EnviarCredencialesEmail(usuario)" title="Enviar credenciales por email" disabled="@enviandoEmail">
                                                    <span class="bi bi-envelope"></span>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(usuario)" title="Eliminar">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Paginación -->
                    @if (usuarios.Any() && totalPaginas > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center p-3 border-top">
                            <div class="d-flex align-items-center gap-3">
                                <div class="text-muted">
                                    Mostrando @((paginaActual - 1) * elementosPorPagina + 1) - @(Math.Min(paginaActual * elementosPorPagina, totalElementos)) de @totalElementos usuarios
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted">Mostrar:</small>
                                    <select class="form-select form-select-sm" style="width: auto;" @onchange="CambiarElementosPorPaginaEvento">
                                        <option value="10" selected="@(elementosPorPagina == 10)">10</option>
                                        <option value="25" selected="@(elementosPorPagina == 25)">25</option>
                                        <option value="50" selected="@(elementosPorPagina == 50)">50</option>
                                    </select>
                                </div>
                            </div>
                            <nav>
                                <ul class="pagination mb-0">
                                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => CambiarPagina(1)" disabled="@(paginaActual == 1)">
                                            <i class="bi bi-chevron-double-left"></i>
                                        </button>
                                    </li>
                                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)" disabled="@(paginaActual == 1)">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                    </li>
                                    @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
                                    {
                                        var pagina = i;
                                        <li class="page-item @(paginaActual == pagina ? "active" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(pagina)">@pagina</button>
                                        </li>
                                    }
                                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)" disabled="@(paginaActual == totalPaginas)">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </li>
                                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => CambiarPagina(totalPaginas)" disabled="@(paginaActual == totalPaginas)">
                                            <i class="bi bi-chevron-double-right"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (mostrarModalEditar)
    {
        <ModalEditarUsuario 
            Usuario="usuarioSeleccionado" 
            MensajeError="@mensajeError"
            OnGuardar="GuardarUsuario" 
            OnCancelar="CerrarModal" />
    }

    @if (mostrarModalCrear)
    {
        <ModalCrearUsuario 
            OnGuardar="CrearUsuario" 
            OnCancelar="CerrarModal" />
    }

    @if (mostrarModalEliminar)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirmar Eliminación</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <div class="modal-body">
                        <p>¿Estás seguro de que deseas eliminar al usuario <strong>@usuarioSeleccionado?.NombreUsuario</strong>?</p>
                        <p class="text-danger">Esta acción no se puede deshacer.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="button" class="btn btn-danger" @onclick="EliminarUsuario">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<Usuario> usuarios = new();
    private List<Usuario> usuariosFiltrados = new();
    private List<Usuario> usuariosCompletos = new(); // Todos los usuarios filtrados sin paginación
    private string textoBusqueda = string.Empty;
    
    // Ordenamiento
    private string columnaOrden = "NombreUsuario";
    private bool ordenAscendente = true;
    
    // Paginación
    private int paginaActual = 1;
    private int elementosPorPagina = 10;
    private int totalElementos = 0;
    private int totalPaginas = 0;
    
    private Usuario? usuarioSeleccionado;
    private bool cargando = true;
    private bool cargandoSesion = true;
    private bool mostrarModalEditar = false;
    private bool mostrarModalCrear = false;
    private bool mostrarModalEliminar = false;
    private bool enviandoEmail = false;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.CargarSesionAsync();
            
            if (!AuthService.EstaAutenticado)
            {
                Navigation.NavigateTo("/login", false);
                return;
            }
            
            if (!AuthService.EsAdministrador)
            {
                cargandoSesion = false;
                StateHasChanged();
                return;
            }
            
            cargandoSesion = false;
            await CargarUsuarios();
            StateHasChanged();
        }
    }

    private async Task CargarUsuarios()
    {
        cargando = true;
        try
        {
            usuarios = await UsuarioService.ObtenerTodosAsync();
            AplicarOrdenamiento();
        }
        catch
        {
            mensajeError = "Error al cargar los usuarios";
        }
        finally
        {
            cargando = false;
        }
    }

    private void OrdenarPor(string columna)
    {
        paginaActual = 1;
        if (columnaOrden == columna)
        {
            ordenAscendente = !ordenAscendente;
        }
        else
        {
            columnaOrden = columna;
            ordenAscendente = true;
        }
        
        AplicarOrdenamiento();
    }

    private void AplicarOrdenamiento()
    {
        // Primero filtrar por texto de búsqueda
        var usuariosFiltradosPorBusqueda = string.IsNullOrWhiteSpace(textoBusqueda)
            ? usuarios
            : usuarios.Where(u => 
                (u.NombreUsuario?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Email?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Telefono?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Nombre?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Apellidos?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Rol?.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();

        // Luego ordenar
        var usuariosParaPaginar = columnaOrden switch
        {
            "NombreUsuario" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.NombreUsuario).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.NombreUsuario).ToList(),
            "Email" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.Email).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.Email).ToList(),
            "Telefono" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.Telefono).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.Telefono).ToList(),
            "Rol" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.Rol).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.Rol).ToList(),
            "Comision" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.Comision).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.Comision).ToList(),
            "Activo" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.Activo).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.Activo).ToList(),
            "Contratos" => ordenAscendente
                ? usuariosFiltradosPorBusqueda.OrderBy(u => u.TotalContratos).ToList()
                : usuariosFiltradosPorBusqueda.OrderByDescending(u => u.TotalContratos).ToList(),
            _ => usuariosFiltradosPorBusqueda
        };
        
        totalElementos = usuariosParaPaginar.Count;
        totalPaginas = (int)Math.Ceiling((double)totalElementos / elementosPorPagina);
        
        // Guardar todos los usuarios filtrados para exportación
        usuariosCompletos = usuariosParaPaginar;
        
        // Aplicar paginación solo para la vista
        usuariosFiltrados = usuariosParaPaginar
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina)
            .ToList();
        
        StateHasChanged();
    }

    private void FiltrarUsuarios()
    {
        paginaActual = 1;
        AplicarOrdenamiento();
    }

    private void LimpiarBusqueda()
    {
        textoBusqueda = string.Empty;
        FiltrarUsuarios();
    }
    
    private void CambiarElementosPorPaginaEvento(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nuevaCantidad))
        {
            elementosPorPagina = nuevaCantidad;
            paginaActual = 1;
            AplicarOrdenamiento();
        }
    }

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
            AplicarOrdenamiento();
        }
    }

    private async Task MostrarModalEditar(Usuario usuario)
    {
        // Recargar el usuario desde la base de datos para obtener todos los campos actualizados
        var usuarioCompleto = await UsuarioService.ObtenerPorIdAsync(usuario.Id);
        if (usuarioCompleto != null)
        {
            usuarioSeleccionado = usuarioCompleto;
            mostrarModalEditar = true;
        }
    }

    private void MostrarModalCrear()
    {
        mostrarModalCrear = true;
    }

    private void IrALogAccesos()
    {
        Navigation.NavigateTo("/usuarios/log-accesos");
    }

    private void ConfirmarEliminar(Usuario usuario)
    {
        usuarioSeleccionado = usuario;
        mostrarModalEliminar = true;
    }

    private async Task EnviarCredencialesEmail(Usuario usuario)
    {
        // Verificar que solo Admin o SuperAdmin puedan enviar credenciales
        if (!AuthService.EsAdministrador && !AuthService.EsSuperAdmin)
        {
            mensajeError = "No tienes permisos para enviar credenciales";
            return;
        }

        if (string.IsNullOrWhiteSpace(usuario.Email))
        {
            mensajeError = "El usuario no tiene un email configurado";
            return;
        }

        enviandoEmail = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
        StateHasChanged();

        try
        {
            string nombreCompleto = string.IsNullOrWhiteSpace(usuario.Nombre) 
                ? usuario.NombreUsuario 
                : $"{usuario.Nombre} {usuario.Apellidos}";

            string cuerpoHtml = $@"
                <html>
                <head>
                    <style>
                        body {{ font-family: Arial, sans-serif; line-height: 1.6; color: #333; }}
                        .container {{ max-width: 600px; margin: 0 auto; padding: 20px; }}
                        .header {{ background-color: #007bff; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }}
                        .content {{ background-color: #f8f9fa; padding: 30px; border-radius: 0 0 5px 5px; }}
                        .credentials {{ background-color: white; padding: 20px; margin: 20px 0; border-left: 4px solid #007bff; border-radius: 4px; }}
                        .credential-item {{ margin: 10px 0; }}
                        .credential-label {{ font-weight: bold; color: #555; }}
                        .credential-value {{ color: #007bff; font-size: 18px; font-family: 'Courier New', monospace; }}
                        .instructions {{ background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0; border-radius: 4px; }}
                        .footer {{ text-align: center; margin-top: 20px; color: #666; font-size: 12px; }}
                    </style>
                </head>
                <body>
                    <div class='container'>
                        <div class='header'>
                            <h2>Credenciales de Acceso - Enerfone CRM</h2>
                        </div>
                        <div class='content'>
                            <p>Hola <strong>{nombreCompleto}</strong>,</p>
                            <p>A continuaci&oacute;n encontrar&aacute;s tus credenciales de acceso al sistema Enerfone CRM:</p>
                            
                            <div class='credentials'>
                                <div class='credential-item'>
                                    <span class='credential-label'>Usuario:</span><br>
                                    <span class='credential-value'>{usuario.NombreUsuario}</span>
                                </div>
                                <div class='credential-item'>
                                    <span class='credential-label'>Contrase&ntilde;a provisional:</span><br>
                                    <span class='credential-value'>{usuario.PasswordHash}</span>
                                </div>
                            </div>

                            <div class='instructions'>
                                <h4 style='margin-top: 0; color: #856404;'>&#9888; Importante - Cambio de Contrase&ntilde;a</h4>
                                <p style='margin-bottom: 10px;'><strong>Se recomienda cambiar tu contrase&ntilde;a al iniciar sesi&oacute;n por primera vez.</strong></p>
                                <p style='margin-bottom: 5px;'>Para cambiar tu contrase&ntilde;a:</p>
                                <ol style='margin: 10px 0;'>
                                    <li>Inicia sesi&oacute;n en la aplicaci&oacute;n con las credenciales proporcionadas</li>
                                    <li>Haz clic en tu nombre de usuario en la esquina superior derecha</li>
                                    <li>Selecciona <strong>Mi Perfil</strong></li>
                                    <li>En la secci&oacute;n de perfil, encontrar&aacute;s la opci&oacute;n para <strong>Cambiar Contrase&ntilde;a</strong></li>
                                    <li>Introduce tu contrase&ntilde;a actual y define una nueva contrase&ntilde;a segura</li>
                                </ol>
                            </div>

                            <p style='margin-top: 20px;'><strong>Nota de seguridad:</strong> No compartas tus credenciales con nadie y aseg&uacute;rate de cambiar tu contrase&ntilde;a regularmente.</p>
                        </div>
                        <div class='footer'>
                            <p>Este es un mensaje autom&aacute;tico. Por favor, no respondas a este correo.</p>
                            <p>&copy; {DateTime.Now.Year} Enerfone CRM - Sistema de Gesti&oacute;n</p>
                        </div>
                    </div>
                </body>
                </html>
            ";

            var (exito, mensaje) = await EmailService.EnviarEmailSimpleAsync(
                usuario.Email,
                "Credenciales de Acceso - Enerfone CRM",
                cuerpoHtml
            );

            if (exito)
            {
                mensajeExito = $"Credenciales enviadas correctamente a {usuario.Email}";
            }
            else
            {
                mensajeError = $"Error al enviar el email: {mensaje}";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al enviar credenciales: {ex.Message}";
        }
        finally
        {
            enviandoEmail = false;
            StateHasChanged();
        }
    }

    private void CerrarModal()
    {
        mostrarModalEditar = false;
        mostrarModalCrear = false;
        mostrarModalEliminar = false;
        usuarioSeleccionado = null;
        mensajeError = string.Empty;
    }

    private async Task GuardarUsuario((Usuario usuario, List<int> comercializadorasIds, List<int> operadorasIds, List<int> empresasAlarmasIds, List<int> colaboradoresIds, List<int> gestoresIds) datos)
    {
        try
        {
            mensajeError = string.Empty;
            mensajeExito = string.Empty;
            
            Console.WriteLine($"[ListaUsuarios] Iniciando actualización de usuario ID: {datos.usuario.Id}, Nombre: '{datos.usuario.NombreUsuario}'");
            
            var (exito, mensaje) = await UsuarioService.ActualizarAsync(datos.usuario);
            if (exito)
            {
                // Actualizar comercializadoras permitidas
                await UsuarioService.ActualizarComercializadorasPermitidasAsync(datos.usuario.Id, datos.comercializadorasIds);
                
                // Actualizar operadoras permitidas
                await UsuarioService.ActualizarOperadorasPermitidasAsync(datos.usuario.Id, datos.operadorasIds);
                
                // Actualizar empresas de alarmas permitidas
                await UsuarioService.ActualizarEmpresasAlarmasPermitidasAsync(datos.usuario.Id, datos.empresasAlarmasIds);
                
                // Si es gestor, actualizar colaboradores asignados
                if (datos.usuario.Rol == "Gestor")
                {
                    await UsuarioService.ActualizarColaboradoresDeGestorAsync(datos.usuario.Id, datos.colaboradoresIds);
                }
                
                // Si es jefe de ventas, actualizar gestores y colaboradores asignados
                if (datos.usuario.Rol == "Jefe de ventas")
                {
                    await UsuarioService.ActualizarGestoresDeJefeVentasAsync(datos.usuario.Id, datos.gestoresIds);
                    await UsuarioService.ActualizarColaboradoresDeJefeVentasAsync(datos.usuario.Id, datos.colaboradoresIds);
                }
                
                mensajeExito = mensaje;
                Console.WriteLine($"[ListaUsuarios] Usuario actualizado correctamente: {mensaje}");
                
                await CargarUsuarios();
                CerrarModal();
            }
            else
            {
                mensajeError = mensaje;
                Console.WriteLine($"[ListaUsuarios] Error al actualizar usuario: {mensaje}");
                // NO cerramos el modal para que el usuario vea el error
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error inesperado al guardar el usuario: {ex.Message}";
            Console.WriteLine($"[ListaUsuarios] EXCEPCIÓN al guardar usuario: {ex.Message}");
            Console.WriteLine($"[ListaUsuarios] StackTrace: {ex.StackTrace}");
            StateHasChanged();
        }
    }

    private async Task CrearUsuario((Usuario usuario, string password, List<int> comercializadorasIds, List<int> operadorasIds, List<int> empresasAlarmasIds, List<int> colaboradoresIds, List<int> gestoresIds) datos)
    {
        var (exito, mensaje) = await UsuarioService.CrearAsync(datos.usuario, datos.password);
        if (exito)
        {
            // Obtener el ID del usuario recién creado
            var usuarioCreado = await UsuarioService.ObtenerPorNombreUsuarioAsync(datos.usuario.NombreUsuario);
            
            if (usuarioCreado != null)
            {
                // Actualizar comercializadoras permitidas
                if (datos.comercializadorasIds.Any())
                {
                    await UsuarioService.ActualizarComercializadorasPermitidasAsync(usuarioCreado.Id, datos.comercializadorasIds);
                }
                
                // Actualizar operadoras permitidas
                if (datos.operadorasIds.Any())
                {
                    await UsuarioService.ActualizarOperadorasPermitidasAsync(usuarioCreado.Id, datos.operadorasIds);
                }
                
                // Actualizar empresas de alarmas permitidas
                if (datos.empresasAlarmasIds.Any())
                {
                    await UsuarioService.ActualizarEmpresasAlarmasPermitidasAsync(usuarioCreado.Id, datos.empresasAlarmasIds);
                }
                
                // Si es gestor y tiene colaboradores asignados, actualizarlos
                if (usuarioCreado.Rol == "Gestor" && datos.colaboradoresIds.Any())
                {
                    await UsuarioService.ActualizarColaboradoresDeGestorAsync(usuarioCreado.Id, datos.colaboradoresIds);
                }
                
                // Si es jefe de ventas, actualizar gestores y colaboradores asignados
                if (usuarioCreado.Rol == "Jefe de ventas")
                {
                    if (datos.gestoresIds.Any())
                    {
                        await UsuarioService.ActualizarGestoresDeJefeVentasAsync(usuarioCreado.Id, datos.gestoresIds);
                    }
                    if (datos.colaboradoresIds.Any())
                    {
                        await UsuarioService.ActualizarColaboradoresDeJefeVentasAsync(usuarioCreado.Id, datos.colaboradoresIds);
                    }
                }
            }
            
            mensajeExito = mensaje;
            await CargarUsuarios();
            StateHasChanged();
            CerrarModal();
        }
        else
        {
            mensajeError = mensaje;
        }
    }

    private async Task EliminarUsuario()
    {
        if (usuarioSeleccionado != null)
        {
            var (exito, mensaje) = await UsuarioService.EliminarAsync(usuarioSeleccionado.Id);
            if (exito)
            {
                mensajeExito = mensaje;
                await CargarUsuarios();
                StateHasChanged();
            }
            else
            {
                mensajeError = mensaje;
            }
            CerrarModal();
        }
    }

    private void ExportarExcel()
    {
        try
        {
            using var workbook = new ClosedXML.Excel.XLWorkbook();
            var worksheet = workbook.Worksheets.Add("Usuarios");

            // Encabezados - TODA la información del usuario
            worksheet.Cell(1, 1).Value = "ID";
            worksheet.Cell(1, 2).Value = "Usuario";
            worksheet.Cell(1, 3).Value = "Nombre";
            worksheet.Cell(1, 4).Value = "Apellidos";
            worksheet.Cell(1, 5).Value = "Email";
            worksheet.Cell(1, 6).Value = "Teléfono";
            worksheet.Cell(1, 7).Value = "Dirección";
            worksheet.Cell(1, 8).Value = "Código Postal";
            worksheet.Cell(1, 9).Value = "Localidad";
            worksheet.Cell(1, 10).Value = "Rol";
            worksheet.Cell(1, 11).Value = "Comisión (%)";
            worksheet.Cell(1, 12).Value = "Activo";
            worksheet.Cell(1, 13).Value = "Recibir Notificaciones";
            worksheet.Cell(1, 14).Value = "Excluir Log Acceso";
            worksheet.Cell(1, 15).Value = "Comercializadora";
            worksheet.Cell(1, 16).Value = "Gestor ID";
            worksheet.Cell(1, 17).Value = "Jefe Ventas ID";
            worksheet.Cell(1, 18).Value = "Director Comercial ID";
            worksheet.Cell(1, 19).Value = "Número Cuenta";
            worksheet.Cell(1, 20).Value = "Tipo Entidad";
            worksheet.Cell(1, 21).Value = "Archivo DNI";
            worksheet.Cell(1, 22).Value = "Archivo CIF";
            worksheet.Cell(1, 23).Value = "Archivo Poder";
            worksheet.Cell(1, 24).Value = "Archivo Contrato";
            worksheet.Cell(1, 25).Value = "Total Contratos";
            worksheet.Cell(1, 26).Value = "Fecha Creación";
            worksheet.Cell(1, 27).Value = "Último Acceso";

            // Estilo de encabezados
            var headerRange = worksheet.Range(1, 1, 1, 27);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.LightGray;
            headerRange.Style.Alignment.Horizontal = ClosedXML.Excel.XLAlignmentHorizontalValues.Center;

            // Datos - usar usuariosCompletos para exportar TODOS los usuarios filtrados (sin paginación)
            int row = 2;
            foreach (var usuario in usuariosCompletos)
            {
                worksheet.Cell(row, 1).Value = usuario.Id;
                worksheet.Cell(row, 2).Value = usuario.NombreUsuario ?? "";
                worksheet.Cell(row, 3).Value = usuario.Nombre ?? "";
                worksheet.Cell(row, 4).Value = usuario.Apellidos ?? "";
                worksheet.Cell(row, 5).Value = usuario.Email ?? "";
                worksheet.Cell(row, 6).Value = usuario.Telefono ?? "";
                worksheet.Cell(row, 7).Value = usuario.Direccion ?? "";
                worksheet.Cell(row, 8).Value = usuario.CodigoPostal ?? "";
                worksheet.Cell(row, 9).Value = usuario.Localidad ?? "";
                worksheet.Cell(row, 10).Value = usuario.Rol ?? "";
                worksheet.Cell(row, 11).Value = usuario.Comision.ToString("F2");
                worksheet.Cell(row, 12).Value = usuario.Activo ? "Sí" : "No";
                worksheet.Cell(row, 13).Value = usuario.RecibirNotificaciones ? "Sí" : "No";
                worksheet.Cell(row, 14).Value = usuario.ExcluirLogAcceso ? "Sí" : "No";
                worksheet.Cell(row, 15).Value = usuario.Comercializadora ?? "";
                worksheet.Cell(row, 16).Value = usuario.GestorId?.ToString() ?? "";
                worksheet.Cell(row, 17).Value = usuario.JefeVentasId?.ToString() ?? "";
                worksheet.Cell(row, 18).Value = usuario.DirectorComercialId?.ToString() ?? "";
                worksheet.Cell(row, 19).Value = usuario.NumeroCuenta ?? "";
                worksheet.Cell(row, 20).Value = usuario.TipoEntidad ?? "";
                worksheet.Cell(row, 21).Value = usuario.ArchivoDni ?? "";
                worksheet.Cell(row, 22).Value = usuario.ArchivoCif ?? "";
                worksheet.Cell(row, 23).Value = usuario.ArchivoPoder ?? "";
                worksheet.Cell(row, 24).Value = usuario.ArchivoContrato ?? "";
                worksheet.Cell(row, 25).Value = usuario.TotalContratos;
                worksheet.Cell(row, 26).Value = usuario.FechaCreacion.ToString("dd/MM/yyyy HH:mm");
                worksheet.Cell(row, 27).Value = usuario.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "";
                row++;
            }

            // Ajustar ancho de columnas
            worksheet.Columns().AdjustToContents();

            // Guardar en memoria y descargar
            using var stream = new System.IO.MemoryStream();
            workbook.SaveAs(stream);
            var bytes = stream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"usuarios_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            // Descargar usando JavaScript
            JS.InvokeVoidAsync("eval", $@"
                const link = document.createElement('a');
                link.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';
                link.download = '{fileName}';
                link.click();
            ");

            mensajeExito = $"Exportados {usuariosCompletos.Count} usuarios a Excel (XLSX)";
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al exportar: {ex.Message}";
        }
    }

    private string ObtenerColorRol(string rol) => rol switch
    {
        "Administrador" => "danger",
        "Gestor" => "warning",
        "Comercializadora" => "info",
        "Colaborador" => "secondary",
        _ => "secondary"
    };
