    private async Task VerContratosHistorico(HistoricoLiquidacion historico)
    {
        try
        {
            historicoSeleccionado = historico;
            mensajeError = string.Empty;

            await using var context = DbContextProvider.CreateDbContext();

            Console.WriteLine($"[LIQUIDACIONES] ===== VER CONTRATOS HISTÓRICO =====");
            Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {historico.Id}");
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {historico.UsuarioNombre}");
            Console.WriteLine($"[LIQUIDACIONES] Estado: {historico.Estado}");

            // Buscar contratos vinculados a esta liquidación a través de DetallesComisionLiquidacion
            var idsContratos = await context.DetallesComisionLiquidacion
                .Where(d => d.HistoricoLiquidacionId == historico.Id)
                .Select(d => d.ContratoId)
                .Distinct()
                .ToListAsync();

            Console.WriteLine($"[LIQUIDACIONES] IDs de contratos en DetallesComisionLiquidacion: {idsContratos.Count}");
            if (idsContratos.Any())
            {
                Console.WriteLine($"[LIQUIDACIONES] IDs: {string.Join(", ", idsContratos)}");
            }

            // Si no hay contratos en DetallesComisionLiquidacion, usar el campo directo en Contratos (para liquidaciones antiguas)
            if (!idsContratos.Any())
            {
                Console.WriteLine($"[LIQUIDACIONES] No se encontraron registros en DetallesComisionLiquidacion, usando fallback con HistoricoLiquidacionId");
                contratosHistorico = await context.Contratos
                    .Where(c => c.HistoricoLiquidacionId == historico.Id)
                    .OrderByDescending(c => c.FechaModificacion)
                    .ToListAsync();
            }
            else
            {
                Console.WriteLine($"[LIQUIDACIONES] Buscando contratos con IDs: {string.Join(", ", idsContratos)}");
                contratosHistorico = await context.Contratos
                    .Where(c => idsContratos.Contains(c.Id))
                    .OrderByDescending(c => c.FechaModificacion)
                    .ToListAsync();
            }

            // Cargar decomisiones asociadas a esta liquidación
            decomisionesVisibles = await context.Decomisiones
                .Where(d => d.LiquidacionDecomisionId == historico.Id)
                .ToListAsync();

            // Cargar las comisiones específicas de cada contrato para este usuario
            comisionesPorContrato = new Dictionary<int, decimal>();
            var detallesComision = await context.DetallesComisionLiquidacion
                .Where(d => d.HistoricoLiquidacionId == historico.Id)
                .ToListAsync();

            Console.WriteLine($"[LIQUIDACIONES] Detalles de comisión encontrados: {detallesComision.Count}");

            foreach (var detalle in detallesComision)
            {
                decimal comisionUsuario = 0;

                // Determinar qué comisión corresponde al usuario de esta liquidación
                if (detalle.ColaboradorId == historico.UsuarioId)
                    comisionUsuario = detalle.ComisionColaborador;
                else if (detalle.GestorId == historico.UsuarioId)
                    comisionUsuario = detalle.ComisionGestor ?? 0;
                else if (detalle.JefeVentasId == historico.UsuarioId)
                    comisionUsuario = detalle.ComisionJefeVentas ?? 0;
                else if (detalle.DirectorComercialId == historico.UsuarioId)
                    comisionUsuario = detalle.ComisionDirectorComercial ?? 0;
                else if (detalle.AdministradorId == historico.UsuarioId)
                    comisionUsuario = detalle.ComisionAdministrador;

                if (comisionUsuario > 0)
                {
                    comisionesPorContrato[detalle.ContratoId] = comisionUsuario;
                    Console.WriteLine($"[LIQUIDACIONES]   Contrato {detalle.ContratoId}: {comisionUsuario:N2}€");
                }
            }

            Console.WriteLine($"[LIQUIDACIONES] Contratos del histórico: {contratosHistorico.Count}, Decomisiones: {decomisionesVisibles.Count}");
            Console.WriteLine($"[LIQUIDACIONES] =======================================");

            mostrarContratosHistorico = true;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar contratos del histórico: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al cargar contratos del histórico: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
        }
    }

