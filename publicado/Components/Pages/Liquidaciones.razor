        Console.WriteLine($"[LIQUIDACIONES] Usuario canceló la eliminación");
    }

    private async Task ConfirmarEliminacion()
    {
        // Guardar variables ANTES de hacer cualquier cosa
        var liquidacionId = usuarioIdEliminar; // Ahora contiene el ID de la liquidación
        var nombreUsuario = mensajeConfirmacionEliminar;
        var numeroContratos = contratosADesvincular;
        
        try
        {
            Console.WriteLine($"[LIQUIDACIONES] ===== RECHAZANDO/ELIMINANDO LIQUIDACIÓN PENDIENTE =====");
            Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {liquidacionId}");
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {nombreUsuario}");

            using var context = DbContextProvider.CreateDbContext();
            
            // Obtener la liquidación pendiente directamente por ID
            var liquidacion = await context.HistoricoLiquidaciones
                .Include(l => l.Detalles)
                .FirstOrDefaultAsync(l => l.Id == liquidacionId && l.Estado == "Pendiente");
            
            if (liquidacion == null)
            {
                mensajeError = "No se encontró la liquidación pendiente.";
                Console.WriteLine($"[LIQUIDACIONES] ERROR: No se encontró liquidación pendiente ID: {liquidacionId}");
                
                // Cerrar modal y limpiar
                mostrarModalConfirmacionEliminar = false;
                usuarioIdEliminar = 0;
                mensajeConfirmacionEliminar = string.Empty;
                contratosADesvincular = 0;
                StateHasChanged();
                return;
            }

            Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {liquidacion.Id}, Usuario: {liquidacion.UsuarioNombre}");

            // Contar contratos vinculados a esta liquidación
            var idsContratos = await context.DetallesComisionLiquidacion
                .Where(d => d.HistoricoLiquidacionId == liquidacionId)
                .Select(d => d.ContratoId)
                .Distinct()
                .ToListAsync();
            
            var contratos = await context.Contratos
                .Where(c => idsContratos.Contains(c.Id))
                .ToListAsync();

            Console.WriteLine($"[LIQUIDACIONES] Contratos vinculados: {contratos.Count}");

            // Desvincular contratos
            foreach (var contrato in contratos)
            {
                contrato.HistoricoLiquidacionId = null;
                Console.WriteLine($"[LIQUIDACIONES] Desvinculado contrato ID: {contrato.Id}");
            }
            
            // Desvincular decomisiones
            var decomisiones = await context.Decomisiones
                .Where(d => d.LiquidacionDecomisionId == liquidacionId)
                .ToListAsync();
            
            foreach (var decomision in decomisiones)
            {
                decomision.LiquidacionDecomisionId = null;
                Console.WriteLine($"[LIQUIDACIONES] Desvinculada decomisión ID: {decomision.Id}");
            }
            
            if (decomisiones.Any())
            {
                Console.WriteLine($"[LIQUIDACIONES] Total decomisiones desvinculadas: {decomisiones.Count}");
            }

            // Eliminar detalles de comisión
            if (liquidacion.Detalles != null && liquidacion.Detalles.Any())
            {
                context.DetallesComisionLiquidacion.RemoveRange(liquidacion.Detalles);
                Console.WriteLine($"[LIQUIDACIONES] Eliminando {liquidacion.Detalles.Count} detalles de comisión");
            }

            // Eliminar la liquidación
            Console.WriteLine($"[LIQUIDACIONES] Eliminando liquidación ID: {liquidacionId}");
            context.HistoricoLiquidaciones.Remove(liquidacion);
            
            // Guardar cambios
            Console.WriteLine($"[LIQUIDACIONES] Guardando cambios en la base de datos...");
            var cambiosGuardados = await context.SaveChangesAsync();
            Console.WriteLine($"[LIQUIDACIONES] SaveChangesAsync completado. Registros afectados: {cambiosGuardados}");
            
            if (cambiosGuardados > 0)
            {
                Console.WriteLine($"[LIQUIDACIONES] ✓ Liquidación {liquidacionId} eliminada exitosamente");
                Console.WriteLine($"[LIQUIDACIONES] ✓ {contratos.Count} contratos desvinculados y disponibles para nueva liquidación");
                Console.WriteLine($"[LIQUIDACIONES] ====================================================");
                
                // Recargar datos
                await CargarUsuariosConContratos();
                await CargarLiquidacionesPorEstado();
                
                mensajeError = string.Empty;
                mensajeExito = $"Liquidación de {nombreUsuario} eliminada exitosamente. {contratos.Count} contrato(s) disponible(s) para nueva liquidación.";
                Console.WriteLine($"[LIQUIDACIONES] Mensaje de éxito configurado");
            }
            else
            {
                Console.WriteLine($"[LIQUIDACIONES] ⚠ ADVERTENCIA: SaveChangesAsync no guardó ningún cambio");
                mensajeError = "No se pudo eliminar la liquidación. No se guardaron cambios en la base de datos.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            Console.WriteLine($"[LIQUIDACIONES] ✗ ERROR AL ELIMINAR LIQUIDACIÓN");
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            Console.WriteLine($"[LIQUIDACIONES] Error: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"[LIQUIDACIONES] Inner exception: {ex.InnerException.Message}");
                Console.WriteLine($"[LIQUIDACIONES] Inner stack trace: {ex.InnerException.StackTrace}");
            }
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            
            mensajeError = $"Error al eliminar la liquidación: {ex.Message}";
            if (ex.InnerException != null)
            {
                mensajeError += $" | Detalle: {ex.InnerException.Message}";
            }
        }
        finally
        {
            // Cerrar modal y limpiar variables
            mostrarModalConfirmacionEliminar = false;
            usuarioIdEliminar = 0;
            mensajeConfirmacionEliminar = string.Empty;
            contratosADesvincular = 0;
            StateHasChanged();
        }
    }

