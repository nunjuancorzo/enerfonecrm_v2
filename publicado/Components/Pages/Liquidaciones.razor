    private async Task AprobarLiquidacion(int usuarioId)
    {
        Console.WriteLine($"[LIQUIDACIONES] ===== MÉTODO LLAMADO =====");
        Console.WriteLine($"[LIQUIDACIONES] Usuario a aprobar ID: {usuarioId}");
        
        try
        {
            Console.WriteLine($"[LIQUIDACIONES] ===== INICIO APROBAR LIQUIDACIÓN =====");
            Console.WriteLine($"[LIQUIDACIONES] Usuario actual: {AuthService.UsuarioActual?.NombreUsuario} (ID: {AuthService.UsuarioActual?.Id})");
            Console.WriteLine($"[LIQUIDACIONES] PuedeGestionarLiquidaciones: {AuthService.PuedeGestionarLiquidaciones}");
            Console.WriteLine($"[LIQUIDACIONES] EsAdministrador: {AuthService.EsAdministrador}");
            
            var usuario = usuariosConContratos.FirstOrDefault(u => u.Usuario.Id == usuarioId);
            if (usuario == null)
            {
                Console.WriteLine($"[LIQUIDACIONES] ERROR: Usuario no encontrado en la lista");
                mensajeError = "Usuario no encontrado en la lista";
                StateHasChanged();
                return;
            }

            // Validación de seguridad: colaboradores solo pueden aprobar su propia liquidación
            // Administradores y superadmin pueden aprobar cualquier liquidación
            if (!AuthService.PuedeGestionarLiquidaciones && 
                !AuthService.EsSuperAdmin && 
                AuthService.UsuarioActual?.Id != usuarioId)
            {
                Console.WriteLine($"[LIQUIDACIONES] ERROR: No tienes permisos para aprobar esta liquidación");
                mensajeError = "No tienes permisos para aprobar esta liquidación";
                StateHasChanged();
                return;
            }

            Console.WriteLine($"[LIQUIDACIONES] Validación de permisos OK, iniciando aprobación...");
            usuario.Aprobando = true;
            StateHasChanged();

            await using var context = DbContextProvider.CreateDbContext();
            
            var usuarioDb = await context.Usuarios.FindAsync(usuarioId);
            if (usuarioDb == null)
            {
                Console.WriteLine($"[LIQUIDACIONES] ERROR: Usuario no encontrado en BD");
                mensajeError = "Usuario no encontrado";
                usuario.Aprobando = false;
                StateHasChanged();
                return;
            }

            Console.WriteLine($"[LIQUIDACIONES] ===== APROBANDO LIQUIDACIÓN =====");
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {usuarioDb.NombreUsuario} (ID: {usuarioDb.Id}, Rol: {usuarioDb.Rol})");
            Console.WriteLine($"[LIQUIDACIONES] Jerarquía:");
            Console.WriteLine($"[LIQUIDACIONES]   - GestorId: {usuarioDb.GestorId}");
            Console.WriteLine($"[LIQUIDACIONES]   - JefeVentasId: {usuarioDb.JefeVentasId}");
            Console.WriteLine($"[LIQUIDACIONES]   - DirectorComercialId: {usuarioDb.DirectorComercialId}");
            Console.WriteLine($"[LIQUIDACIONES] =====================================");

            // Obtener todos los contratos facturables del usuario
            var contratos = await context.Contratos
                .Where(c => c.Comercial == usuarioDb.NombreUsuario
                    && (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .ToListAsync();

            if (!contratos.Any())
            {
                mensajeError = "No hay contratos facturables para aprobar";
                usuario.Aprobando = false;
                StateHasChanged();
                return;
            }

            // Contar contratos por tipo
            var contratosEnergia = contratos.Count(c => c.Tipo == "energia" || c.Tipo == "Energía");
            var contratosTelefonia = contratos.Count(c => c.Tipo == "telefonia" || c.Tipo == "Telefonía");
            var contratosAlarmas = contratos.Count(c => c.Tipo == "alarma" || c.Tipo == "Alarma");
            
            // Calcular total base de comisiones (antes de aplicar distribución jerárquica)
            var totalComisionesBase = contratos.Sum(c => c.Comision ?? 0);
            
            // Obtener decomisiones pendientes del usuario (no asignadas a ninguna liquidación)
            var decomisionesPendientes = await context.Decomisiones
                .Where(d => d.UsuarioId == usuarioId && d.LiquidacionDecomisionId == null)
                .ToListAsync();
            
            var totalDecomisiones = decomisionesPendientes.Sum(d => d.ImporteDecomision);
            
            // ===== CALCULAR LA COMISIÓN QUE LE CORRESPONDE AL COLABORADOR =====
            decimal totalComisionesColaborador;
            
            // Si el usuario es Backoffice, no recibe comisiones (todo va al Administrador)
            if (usuarioDb.Rol == "Backoffice")
            {
                totalComisionesColaborador = 0;
            }
            else
            {
                // Obtener la configuración de comisiones del usuario
                // Aquí debemos calcular el porcentaje promedio ponderado según los contratos
                decimal totalConPorcentaje = 0;
                
                foreach (var contrato in contratos)
                {
                    // Calcular la distribución para este contrato
                    var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, null);
                    Console.WriteLine($"[LIQUIDACIONES] Contrato {contrato.Id}: Base={detalle.ComisionBase}€, %Colaborador={detalle.PorcentajeColaborador}%, Colaborador={detalle.ComisionColaborador}€");
                    totalConPorcentaje += detalle.ComisionColaborador;
                }
                
                totalComisionesColaborador = totalConPorcentaje;
                Console.WriteLine($"[LIQUIDACIONES] Total calculado para colaborador: {totalComisionesColaborador}€");
            }
            
            // Restar decomisiones del total del colaborador
            totalComisionesColaborador -= totalDecomisiones;
            
            Console.WriteLine($"[LIQUIDACIONES] Total base: {totalComisionesBase}€, Comisión colaborador: {totalComisionesColaborador}€, Decomisiones: {totalDecomisiones}€");

            // Guardar en el histórico (excepto si es superadmin)
            if (AuthService.UsuarioActual?.NombreUsuario != "superadmin")
            {
                // ===== CREAR SOLO LA LIQUIDACIÓN DEL COLABORADOR EN ESTADO "PENDIENTE" =====
                // Las liquidaciones de la jerarquía se crearán cuando el colaborador acepte su liquidación
                
                Console.WriteLine($"[LIQUIDACIONES] Creando liquidación SOLO para el colaborador {usuarioDb.NombreUsuario}");
                
                // Calcular la comisión que le corresponde al colaborador
                decimal totalComisionColaborador = 0;
                foreach (var contrato in contratos)
                {
                    var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, null);
                    totalComisionColaborador += detalle.ComisionColaborador;
                }
                
                // Restar decomisiones
                totalComisionColaborador -= totalDecomisiones;
                
                Console.WriteLine($"[LIQUIDACIONES] Comisión calculada para colaborador: {totalComisionColaborador:N2}€ (Decomisiones: {totalDecomisiones:N2}€)");
                
                // Crear liquidación del colaborador en estado "Pendiente"
                var historico = new HistoricoLiquidacion
                {
                    UsuarioId = usuarioDb.Id,
                    UsuarioNombre = usuarioDb.NombreUsuario,
                    UsuarioEmail = usuarioDb.Email,
                    CantidadContratos = contratos.Count,
                    ContratosEnergia = contratosEnergia,
                    ContratosTelefonia = contratosTelefonia,
                    ContratosAlarmas = contratosAlarmas,
                    FechaAprobacion = DateTime.Now,
                    AprobadoPorId = AuthService.UsuarioActual!.Id,
                    AprobadoPorNombre = AuthService.UsuarioActual.NombreUsuario,
                    Estado = "Pendiente",
                    FechaAceptada = null,
                    TotalComisiones = totalComisionColaborador
                };
                
                context.HistoricoLiquidaciones.Add(historico);
                await context.SaveChangesAsync();
                
                var liquidacionId = historico.Id;
                Console.WriteLine($"[LIQUIDACIONES] Creada liquidación {liquidacionId} para {usuarioDb.NombreUsuario}: {totalComisionColaborador:N2}€ - Estado: Pendiente");
                
                // Vincular contratos a la liquidación del colaborador
                // IMPORTANTE: NO cambiar el estado de los contratos, se mantienen en "Act/Facturable"
                foreach (var contrato in contratos)
                {
                    contrato.HistoricoLiquidacionId = liquidacionId;
                    // NO cambiar contrato.Estado - se mantiene en "Act/Facturable"
                    
                    // Crear registro en DetallesComisionLiquidacion
                    var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, usuarioDb, null);
                    var detalleComision = new DetalleComisionLiquidacion
                    {
                        HistoricoLiquidacionId = liquidacionId,
                        ContratoId = contrato.Id,
                        ComisionColaborador = detalle.ComisionColaborador,
                        ComisionGestor = 0, // Se creará cuando el gestor tenga su liquidación
                        ComisionJefeVentas = 0,
                        ComisionDirectorComercial = 0
                    };
                    context.DetallesComisionLiquidacion.Add(detalleComision);
                }
                
                await context.SaveChangesAsync();
                Console.WriteLine($"[LIQUIDACIONES] Vinculados {contratos.Count} contratos a liquidación {liquidacionId} con DetallesComisionLiquidacion");
                
                // Vincular decomisiones a la liquidación del colaborador
                foreach (var decomision in decomisionesPendientes)
                {
                    decomision.LiquidacionDecomisionId = liquidacionId;
                    context.Decomisiones.Update(decomision);
                }
                
                if (decomisionesPendientes.Any())
                {
                    Console.WriteLine($"[LIQUIDACIONES] Vinculadas {decomisionesPendientes.Count} decomisiones a liquidación {liquidacionId}");
                }
                
                await context.SaveChangesAsync();
                
                Console.WriteLine($"[LIQUIDACIONES] ===== LIQUIDACIÓN CREADA EXITOSAMENTE =====");
                Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {liquidacionId}");
                Console.WriteLine($"[LIQUIDACIONES] Estado: Pendiente");
                Console.WriteLine($"[LIQUIDACIONES] Contratos vinculados: {contratos.Count}");
                Console.WriteLine($"[LIQUIDACIONES] Contratos mantienen estado: Act/Facturable");
                Console.WriteLine($"[LIQUIDACIONES] La jerarquía se creará cuando el colaborador acepte su liquidación");
                Console.WriteLine($"[LIQUIDACIONES] ==========================================");
            }
            else
            {
                // Cambiar el estado de todos los contratos a Liquidado (superadmin sin histórico)
                foreach (var contrato in contratos)
                {
                    contrato.Estado = "Liquidado";
                }
                
                await context.SaveChangesAsync();
                Console.WriteLine($"[Liquidaciones] SUPERADMIN - Histórico NO registrado (modo invisible)");
            }

            // Recargar la lista de usuarios con contratos
            await CargarUsuariosConContratos();
            await CargarLiquidacionesPorEstado();

            Console.WriteLine($"[LIQUIDACIONES] Liquidación aprobada para el usuario {usuarioDb.NombreUsuario}: {contratos.Count} contratos vinculados (mantienen estado Act/Facturable)");
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al aprobar liquidación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            Console.WriteLine($"[LIQUIDACIONES] ERROR AL APROBAR LIQUIDACIÓN");
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            Console.WriteLine($"[LIQUIDACIONES] Error: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
            Console.WriteLine($"[LIQUIDACIONES] Inner exception: {ex.InnerException?.Message}");
            Console.WriteLine($"[LIQUIDACIONES] ========================================");
            
            var usuario = usuariosConContratos.FirstOrDefault(u => u.Usuario.Id == usuarioId);
            if (usuario != null)
            {
                usuario.Aprobando = false;
            }
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task AceptarLiquidacionPendiente(int liquidacionId)
    {
        try
        {
            Console.WriteLine($"[LIQUIDACIONES] ===== ACEPTAR LIQUIDACIÓN PENDIENTE =====");
            Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {liquidacionId}");
            
            await using var context = DbContextProvider.CreateDbContext();
            
            // Buscar la liquidación pendiente
            var liquidacionColaborador = await context.HistoricoLiquidaciones
                .FirstOrDefaultAsync(l => l.Id == liquidacionId && l.Estado == "Pendiente");
            
            if (liquidacionColaborador == null)
            {
                mensajeError = "No se encontró la liquidación pendiente.";
                return;
            }
            
            // Validación de seguridad: colaboradores solo pueden aceptar su propia liquidación
            if (!AuthService.PuedeGestionarLiquidaciones && 
                !AuthService.EsSuperAdmin && 
                AuthService.UsuarioActual?.Id != liquidacionColaborador.UsuarioId)
            {
                mensajeError = "No tienes permisos para aceptar esta liquidación";
                return;
            }
            
            // Obtener el usuario
            var usuarioDb = await context.Usuarios.FindAsync(liquidacionColaborador.UsuarioId);
            if (usuarioDb == null)
            {
                mensajeError = "Usuario no encontrado";
                return;
            }
            
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {usuarioDb.NombreUsuario}, Rol: {usuarioDb.Rol}");
            
            // Cambiar estado de la liquidación del colaborador a "Aceptada"
            liquidacionColaborador.Estado = "Aceptada";
            liquidacionColaborador.FechaAceptada = DateTime.Now;
            context.HistoricoLiquidaciones.Update(liquidacionColaborador);
            
            // Obtener contratos vinculados (pero NO cambiarlos a Liquidado aún)
            var contratos = await context.Contratos
                .Where(c => c.HistoricoLiquidacionId == liquidacionId)
                .ToListAsync();
            
            await context.SaveChangesAsync();
            
            // ===== GENERAR LIQUIDACIONES PENDIENTES PARA ROLES ADICIONALES =====
            try
            {
                var liquidacionesGeneradas = await LiquidacionService.GenerarLiquidacionesRolesAdicionalesAsync(liquidacionId);
                
                if (liquidacionesGeneradas)
                {
                    mensajeExito = $"Liquidación aceptada exitosamente para {usuarioDb.NombreUsuario}. Se han generado liquidaciones pendientes para los roles adicionales.";
                }
                else
                {
                    mensajeExito = $"Liquidación aceptada exitosamente para {usuarioDb.NombreUsuario}. No se generaron liquidaciones adicionales (verifica los logs del servidor).";
                }
            }
            catch (Exception exLiquidacion)
            {
                mensajeExito = $"Liquidación aceptada exitosamente para {usuarioDb.NombreUsuario}. Error al generar liquidaciones adicionales: {exLiquidacion.Message}";
            }
            
            // Recargar datos
            await CargarUsuariosConContratos();
            await CargarLiquidacionesPorEstado();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al aceptar liquidación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al aceptar liquidación: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
        }
        finally
        {
            StateHasChanged();
        }
    }

