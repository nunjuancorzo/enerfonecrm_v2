    }

    /// <summary>
    /// Verifica si un contrato tiene una decomisión asociada
    /// </summary>
    private bool TieneDecomision(int contratoId)
    {
        return decomisionesVisibles.Any(d => d.ContratoId == contratoId);
    }

    /// <summary>
    /// Obtiene la comisión que le corresponde al usuario actual para un contrato específico
    /// </summary>
    private decimal ObtenerComisionUsuario(int contratoId)
    {
        if (comisionesPorContrato.TryGetValue(contratoId, out decimal comision))
        {
            return comision;
        }
        // Si no está en el diccionario, devolver 0
        return 0;
    }

    /// <summary>
    /// Obtiene el importe de decomisión de un contrato
    /// </summary>
    private async Task<decimal?> ObtenerComisionUsuarioContrato(int contratoId, int usuarioId)
    {
        try
        {
            await using var context = DbContextProvider.CreateDbContext();
            
            // Buscar el detalle de comisión para este contrato
            var detalle = await context.DetallesComisionLiquidacion
                .FirstOrDefaultAsync(d => d.ContratoId == contratoId);
            
            if (detalle == null)
            {
                Console.WriteLine($"[LIQUIDACIONES] No se encontró detalle de comisión para contrato {contratoId}");
                return null;
            }
            
            // Determinar qué comisión corresponde a este usuario
            if (detalle.ColaboradorId == usuarioId)
                return detalle.ComisionColaborador;
            
            if (detalle.GestorId == usuarioId)
                return detalle.ComisionGestor;
            
            if (detalle.JefeVentasId == usuarioId)
                return detalle.ComisionJefeVentas;
            
            if (detalle.DirectorComercialId == usuarioId)
                return detalle.ComisionDirectorComercial;
            
            if (detalle.AdministradorId == usuarioId)
                return detalle.ComisionAdministrador;
            
            Console.WriteLine($"[LIQUIDACIONES] Usuario {usuarioId} no encontrado en la distribución de comisión del contrato {contratoId}");
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LIQUIDACIONES] Error al obtener comisión: {ex.Message}");
            return null;
        }
    }

    private decimal? ObtenerImporteDecomision(int contratoId)
    {
        var decomision = decomisionesVisibles.FirstOrDefault(d => d.ContratoId == contratoId);
        return decomision?.ImporteDecomision;
    }

    /// <summary>
    /// Filtra la lista de usuarios según la jerarquía del usuario actual
    /// </summary>
    private async Task<List<UsuarioConContratos>> FiltrarUsuariosPorJerarquiaAsync(
        List<UsuarioConContratos> todosLosUsuarios)
    {
        var usuarioActual = AuthService.UsuarioActual;
        if (usuarioActual == null) return new List<UsuarioConContratos>();

        // Administrador o con permisos de gestión: ve todos
        if (AuthService.PuedeGestionarLiquidaciones || usuarioActual.Rol == "Administrador")
        {
            Console.WriteLine($"[LIQUIDACIONES] Usuario {usuarioActual.NombreUsuario} puede ver TODOS los usuarios (Administrador o permisos)");
            return todosLosUsuarios;
        }

        // Obtener todos los usuarios activos para construir la jerarquía
        await using var context = DbContextProvider.CreateDbContext();
        var todosUsuarios = await context.Usuarios.Where(u => u.Activo).ToListAsync();
        var idsVisibles = new HashSet<int> { usuarioActual.Id }; // Siempre se ve a sí mismo

        Console.WriteLine($"[LIQUIDACIONES] Filtrando jerarquía para {usuarioActual.NombreUsuario} (Rol: {usuarioActual.Rol})");

        if (usuarioActual.Rol == "Director comercial")
        {
            // Director ve: sus jefes de ventas + los gestores de esos jefes + los colaboradores de esos gestores
            var jefesDeVentas = todosUsuarios.Where(u => u.DirectorComercialId == usuarioActual.Id).ToList();
            Console.WriteLine($"[LIQUIDACIONES] Director tiene {jefesDeVentas.Count} jefes de ventas");
            
            foreach (var jefe in jefesDeVentas)
            {
                idsVisibles.Add(jefe.Id);
                Console.WriteLine($"[LIQUIDACIONES]   - Jefe: {jefe.NombreUsuario} (ID: {jefe.Id})");
                
                // Gestores de este jefe
                var gestores = todosUsuarios.Where(u => u.JefeVentasId == jefe.Id).ToList();
                Console.WriteLine($"[LIQUIDACIONES]     - Tiene {gestores.Count} gestores");
                
                foreach (var gestor in gestores)
                {
                    idsVisibles.Add(gestor.Id);
                    Console.WriteLine($"[LIQUIDACIONES]       - Gestor: {gestor.NombreUsuario} (ID: {gestor.Id})");
                    
                    // Colaboradores de este gestor
                    var colaboradores = todosUsuarios.Where(u => u.GestorId == gestor.Id).ToList();
                    Console.WriteLine($"[LIQUIDACIONES]         - Tiene {colaboradores.Count} colaboradores");
                    
                    foreach (var colab in colaboradores)
                    {
                        idsVisibles.Add(colab.Id);
                        Console.WriteLine($"[LIQUIDACIONES]           - Colaborador: {colab.NombreUsuario} (ID: {colab.Id})");
                    }
                }
            }
        }
        else if (usuarioActual.Rol == "Jefe de ventas")
        {
            // Jefe ve: sus gestores + los colaboradores de esos gestores
            var gestores = todosUsuarios.Where(u => u.JefeVentasId == usuarioActual.Id).ToList();
            Console.WriteLine($"[LIQUIDACIONES] Jefe tiene {gestores.Count} gestores");
            
            foreach (var gestor in gestores)
            {
                idsVisibles.Add(gestor.Id);
                Console.WriteLine($"[LIQUIDACIONES]   - Gestor: {gestor.NombreUsuario} (ID: {gestor.Id})");
                
                // Colaboradores de este gestor
                var colaboradores = todosUsuarios.Where(u => u.GestorId == gestor.Id).ToList();
                Console.WriteLine($"[LIQUIDACIONES]     - Tiene {colaboradores.Count} colaboradores");
                
                foreach (var colab in colaboradores)
                {
                    idsVisibles.Add(colab.Id);
                    Console.WriteLine($"[LIQUIDACIONES]       - Colaborador: {colab.NombreUsuario} (ID: {colab.Id})");
                }
            }
        }
        else if (usuarioActual.Rol == "Gestor")
        {
            // Gestor ve: sus colaboradores
            var colaboradores = todosUsuarios.Where(u => u.GestorId == usuarioActual.Id).ToList();
            Console.WriteLine($"[LIQUIDACIONES] Gestor tiene {colaboradores.Count} colaboradores");
            
            foreach (var colab in colaboradores)
            {
                idsVisibles.Add(colab.Id);
                Console.WriteLine($"[LIQUIDACIONES]   - Colaborador: {colab.NombreUsuario} (ID: {colab.Id})");
            }
        }
        else // Colaborador u otros roles
        {
            // Solo ve sus propias liquidaciones
            Console.WriteLine($"[LIQUIDACIONES] Colaborador solo ve sus propias liquidaciones");
        }

        // Filtrar la lista original
        var usuariosFiltrados = todosLosUsuarios.Where(u => idsVisibles.Contains(u.Usuario.Id)).ToList();
        Console.WriteLine($"[LIQUIDACIONES] Total usuarios visibles después del filtro: {usuariosFiltrados.Count}");
        
        return usuariosFiltrados;
    }

    private class UsuarioConContratos
    {
        public Usuario Usuario { get; set; } = null!;
        public int CantidadContratos { get; set; }
        public decimal TotalComisiones { get; set; }
        public int CantidadIncidenciasPendientes { get; set; }
        public int CantidadIncidenciasTotal { get; set; }
        public bool TieneIncidenciasPendientes => CantidadIncidenciasPendientes > 0;
        public bool Aprobando { get; set; }
        public bool Enviando { get; set; }
    }
}

<script>
    window.printLiquidacion = function (htmlContent) {
        var iframe = document.createElement('iframe');
        iframe.style.display = 'none';
        document.body.appendChild(iframe);
        
        var doc = iframe.contentWindow.document;
        doc.open();
        doc.write(htmlContent);
        doc.close();
        
        setTimeout(function () {
            iframe.contentWindow.print();
            setTimeout(function () {
                document.body.removeChild(iframe);
            }, 500);
        }, 250);
    };
</script>
