    private bool mostrarModalConfirmacionEliminar = false;
    private string mensajeConfirmacionEliminar = string.Empty;
    private int usuarioIdEliminar = 0;
    private int contratosADesvincular = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !verificado)
        {
            verificado = true;
            
            // Verificar autenticación
            await AuthService.CargarSesionAsync();
            if (!AuthService.EstaAutenticado)
            {
                NavigationManager.NavigateTo("/login", true);
                return;
            }

            // Control de visibilidad de liquidaciones:
            // - Admin y Backoffice con permisos: Ven y gestionan TODAS las liquidaciones
            // - Colaboradores y Gestores: Solo ven y gestionan SUS PROPIAS liquidaciones
            if (!AuthService.PuedeVerLiquidaciones)
            {
                NavigationManager.NavigateTo("/", true);
                return;
            }

            // Verificar si el módulo de liquidaciones está activo
            await using var contextConfig = DbContextProvider.CreateDbContext();
            var configuracionEmpresa = await contextConfig.ConfiguracionesEmpresa.FirstOrDefaultAsync();
            if (configuracionEmpresa != null && !configuracionEmpresa.ModuloLiquidacionesActivo)
            {
                moduloActivo = false;
                cargando = false;
                StateHasChanged();
                return;
            }
            
            await CargarUsuariosConContratos();
            await CargarLiquidacionesPorEstado();

            StateHasChanged();
        }
    }

    private async Task CargarUsuariosConContratos()
    {
        try
        {
            cargando = true;
            mensajeError = string.Empty;

            await using var context = DbContextProvider.CreateDbContext();

            // Diccionario para acumular comisiones por usuario
            // Key: usuarioId, Value: (usuario, totalComision, cantidadContratos)
            var comisionesPorUsuario = new Dictionary<int, (Usuario usuario, decimal totalComision, int cantidadContratos, int incidenciasPendientes, int incidenciasTotal)>();

            // Obtener TODOS los contratos facturables del sistema
            var todosContratosFacturables = await context.Contratos
                .Where(c => (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .ToListAsync();

            Console.WriteLine($"[LIQUIDACIONES] Total contratos facturables en el sistema: {todosContratosFacturables.Count}");

            // Para cada contrato, calcular la distribución y acumular comisiones
            foreach (var contrato in todosContratosFacturables)
            {
                // Obtener el comercial (colaborador) del contrato
                var comercial = await context.Usuarios
                    .FirstOrDefaultAsync(u => u.NombreUsuario == contrato.Comercial && u.Activo);
                
                if (comercial == null)
                {
                    Console.WriteLine($"[LIQUIDACIONES] Comercial '{contrato.Comercial}' no encontrado o inactivo para contrato {contrato.Id}");
                    continue;
                }

                // Calcular distribución de comisiones para este contrato
                var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, comercial, null);

                // Acumular comisión del colaborador
                if (detalle.ComisionColaborador > 0)
                {
                    if (!comisionesPorUsuario.ContainsKey(comercial.Id))
                    {
                        var incidenciasPendientes = await context.IncidenciasLiquidacion
                            .Where(i => i.UsuarioColaboradorId == comercial.Id && i.Estado == "Pendiente")
                            .CountAsync();
                        var incidenciasTotal = await context.IncidenciasLiquidacion
                            .Where(i => i.UsuarioColaboradorId == comercial.Id)
                            .CountAsync();
                        
                        comisionesPorUsuario[comercial.Id] = (comercial, 0, 0, incidenciasPendientes, incidenciasTotal);
                    }
                    
                    var actual = comisionesPorUsuario[comercial.Id];
                    comisionesPorUsuario[comercial.Id] = (actual.usuario, actual.totalComision + detalle.ComisionColaborador, actual.cantidadContratos + 1, actual.incidenciasPendientes, actual.incidenciasTotal);
                }

                // Acumular comisión del gestor
                if (detalle.GestorId.HasValue && detalle.ComisionGestor.HasValue && detalle.ComisionGestor.Value > 0)
                {
                    var gestor = await context.Usuarios.FindAsync(detalle.GestorId.Value);
                    if (gestor != null && gestor.Activo)
                    {
                        if (!comisionesPorUsuario.ContainsKey(gestor.Id))
                        {
                            comisionesPorUsuario[gestor.Id] = (gestor, 0, 0, 0, 0);
                        }
                        
                        var actual = comisionesPorUsuario[gestor.Id];
                        comisionesPorUsuario[gestor.Id] = (actual.usuario, actual.totalComision + detalle.ComisionGestor.Value, actual.cantidadContratos + 1, actual.incidenciasPendientes, actual.incidenciasTotal);
                    }
                }

                // Acumular comisión del jefe de ventas
                if (detalle.JefeVentasId.HasValue && detalle.ComisionJefeVentas.HasValue && detalle.ComisionJefeVentas.Value > 0)
                {
                    var jefeVentas = await context.Usuarios.FindAsync(detalle.JefeVentasId.Value);
                    if (jefeVentas != null && jefeVentas.Activo)
                    {
                        if (!comisionesPorUsuario.ContainsKey(jefeVentas.Id))
                        {
                            comisionesPorUsuario[jefeVentas.Id] = (jefeVentas, 0, 0, 0, 0);
                        }
                        
                        var actual = comisionesPorUsuario[jefeVentas.Id];
                        comisionesPorUsuario[jefeVentas.Id] = (actual.usuario, actual.totalComision + detalle.ComisionJefeVentas.Value, actual.cantidadContratos + 1, actual.incidenciasPendientes, actual.incidenciasTotal);
                    }
                }

                // Acumular comisión del director comercial
                if (detalle.DirectorComercialId.HasValue && detalle.ComisionDirectorComercial.HasValue && detalle.ComisionDirectorComercial.Value > 0)
                {
                    var directorComercial = await context.Usuarios.FindAsync(detalle.DirectorComercialId.Value);
                    if (directorComercial != null && directorComercial.Activo)
                    {
                        if (!comisionesPorUsuario.ContainsKey(directorComercial.Id))
                        {
                            comisionesPorUsuario[directorComercial.Id] = (directorComercial, 0, 0, 0, 0);
                        }
                        
                        var actual = comisionesPorUsuario[directorComercial.Id];
                        comisionesPorUsuario[directorComercial.Id] = (actual.usuario, actual.totalComision + detalle.ComisionDirectorComercial.Value, actual.cantidadContratos + 1, actual.incidenciasPendientes, actual.incidenciasTotal);
                    }
                }

                // Acumular comisión del administrador
                if (detalle.ComisionAdministrador > 0)
                {
                    var administrador = await context.Usuarios.FindAsync(detalle.AdministradorId);
                    if (administrador != null && administrador.Activo)
                    {
                        if (!comisionesPorUsuario.ContainsKey(administrador.Id))
                        {
                            comisionesPorUsuario[administrador.Id] = (administrador, 0, 0, 0, 0);
                        }
                        
                        var actual = comisionesPorUsuario[administrador.Id];
                        comisionesPorUsuario[administrador.Id] = (actual.usuario, actual.totalComision + detalle.ComisionAdministrador, actual.cantidadContratos + 1, actual.incidenciasPendientes, actual.incidenciasTotal);
                    }
                }
            }

            // Restar decomisiones pendientes a cada usuario
            foreach (var kvp in comisionesPorUsuario.ToList())
            {
                var decomisiones = await context.Decomisiones
                    .Where(d => d.UsuarioId == kvp.Key && d.LiquidacionDecomisionId == null)
                    .ToListAsync();
                
                var totalDecomisiones = decomisiones.Sum(d => d.ImporteDecomision);
                
                if (totalDecomisiones > 0)
                {
                    var actual = kvp.Value;
                    comisionesPorUsuario[kvp.Key] = (actual.usuario, actual.totalComision - totalDecomisiones, actual.cantidadContratos, actual.incidenciasPendientes, actual.incidenciasTotal);
                }
            }

            // Convertir el diccionario a lista de UsuarioConContratos
            usuariosConContratos = comisionesPorUsuario
                .Where(kvp => kvp.Value.totalComision > 0) // Solo mostrar usuarios con comisiones positivas
                .Select(kvp => new UsuarioConContratos
                {
                    Usuario = kvp.Value.usuario,
                    CantidadContratos = kvp.Value.cantidadContratos,
                    TotalComisiones = kvp.Value.totalComision,
                    CantidadIncidenciasPendientes = kvp.Value.incidenciasPendientes,
                    CantidadIncidenciasTotal = kvp.Value.incidenciasTotal
                })
                .OrderByDescending(u => u.TotalComisiones)
                .ToList();

            // Filtrar por jerarquía según el rol del usuario actual
            if (AuthService.UsuarioActual != null)
            {
                usuariosConContratos = await FiltrarUsuariosPorJerarquiaAsync(usuariosConContratos);
            }

            Console.WriteLine($"[LIQUIDACIONES] Total usuarios con comisiones pendientes: {usuariosConContratos.Count}");
            foreach (var u in usuariosConContratos)
            {
                Console.WriteLine($"[LIQUIDACIONES] {u.Usuario.NombreUsuario} ({u.Usuario.Rol}): {u.TotalComisiones:N2}€ de {u.CantidadContratos} contratos");
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar usuarios: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task VerDetalleUsuario(int usuarioId)
    {
        try
        {
            await using var context = DbContextProvider.CreateDbContext();
            
            // Obtener el usuario
            usuarioSeleccionado = await context.Usuarios.FindAsync(usuarioId);
            
            if (usuarioSeleccionado == null)
            {
                mensajeError = "Usuario no encontrado";
                return;
            }
            
            Console.WriteLine($"=== VER DETALLE USUARIO ===");
            Console.WriteLine($"Usuario ID: {usuarioId}");
            Console.WriteLine($"Usuario Nombre: {usuarioSeleccionado.NombreUsuario}");
            
            // Obtener TODOS los contratos facturables de los cuales este usuario recibirá comisión
            // Esto incluye contratos propios y contratos de subordinados si es gestor/jefe/director/admin
            var todosContratosFacturables = await context.Contratos
                .Where(c => (c.Tipo == "energia" || c.Tipo == "Energía" || c.Tipo == "telefonia" || c.Tipo == "Telefonía" || c.Tipo == "alarma" || c.Tipo == "Alarma")
                    && c.Estado == "Act/Facturable")
                .OrderByDescending(c => c.FechaCreacion)
                .ToListAsync();
            
            // Filtrar contratos donde este usuario recibirá comisión
            contratosFacurables = new List<Contrato>();
            comisionesPorContrato = new Dictionary<int, decimal>(); // Limpiar el diccionario
            
            foreach (var contrato in todosContratosFacturables)
            {
                var comercial = await context.Usuarios
                    .FirstOrDefaultAsync(u => u.NombreUsuario == contrato.Comercial && u.Activo);
                
                if (comercial == null) continue;

                var detalle = await ComisionService.CalcularDistribucionComisionAsync(contrato, comercial, null);
                
                // Verificar si este usuario recibe comisión de este contrato
                // y guardar la comisión específica que le corresponde
                bool recibeComision = false;
                decimal comisionUsuario = 0;
                
                if (detalle.ColaboradorId == usuarioId && detalle.ComisionColaborador > 0)
                {
                    recibeComision = true;
                    comisionUsuario = detalle.ComisionColaborador;
                }
                else if (detalle.GestorId == usuarioId && detalle.ComisionGestor > 0)
                {
                    recibeComision = true;
                    comisionUsuario = detalle.ComisionGestor ?? 0;
                }
                else if (detalle.JefeVentasId == usuarioId && detalle.ComisionJefeVentas > 0)
                {
                    recibeComision = true;
                    comisionUsuario = detalle.ComisionJefeVentas ?? 0;
                }
                else if (detalle.DirectorComercialId == usuarioId && detalle.ComisionDirectorComercial > 0)
                {
                    recibeComision = true;
                    comisionUsuario = detalle.ComisionDirectorComercial ?? 0;
                }
                else if (detalle.AdministradorId == usuarioId && detalle.ComisionAdministrador > 0)
                {
                    recibeComision = true;
                    comisionUsuario = detalle.ComisionAdministrador;
                }
                
                if (recibeComision)
                {
                    contratosFacurables.Add(contrato);
                    comisionesPorContrato[contrato.Id] = comisionUsuario;
                }
            }
            
            Console.WriteLine($"Contratos donde el usuario recibirá comisión: {contratosFacurables.Count}");

            // Cargar decomisiones pendientes (no asignadas a ninguna liquidación) del usuario
            // IMPORTANTE: No filtrar por idsContratos porque los contratos dados de baja
            // ya no están en estado "Act/Facturable" pero sus decomisiones deben aparecer
            decomisionesVisibles = await context.Decomisiones
                .Where(d => d.UsuarioId == usuarioId && d.LiquidacionDecomisionId == null)
                .ToListAsync();
            
            Console.WriteLine($"Decomisiones pendientes encontradas: {decomisionesVisibles.Count}");
            foreach (var dec in decomisionesVisibles)
            {
                Console.WriteLine($"  Decomisión ID {dec.Id}: ContratoId={dec.ContratoId}, Importe={dec.ImporteDecomision}, LiquidacionId={dec.LiquidacionDecomisionId}");
            }
            
            // Obtener los contratos que tienen decomisión para mostrarlos aunque estén dados de baja
            var idsContratosConDecomision = decomisionesVisibles.Select(d => d.ContratoId).ToList();
            if (idsContratosConDecomision.Any())
            {
                // Obtener IDs de contratos ya en la lista de facturables
                var idsContratosFacturables = contratosFacurables.Select(c => c.Id).ToList();
                
                // Buscar contratos con decomisión que NO estén ya en facturables
                var contratosConDecomision = await context.Contratos
                    .Where(c => idsContratosConDecomision.Contains(c.Id) && !idsContratosFacturables.Contains(c.Id))
                    .ToListAsync();
                
                if (contratosConDecomision.Any())
                {
                    Console.WriteLine($"Contratos con decomisión (dados de baja): {contratosConDecomision.Count}");
                    foreach (var c in contratosConDecomision)
                    {
                        Console.WriteLine($"  - Contrato ID {c.Id}, Estado: '{c.Estado}', Tipo: '{c.Tipo}'");
                    }
                    
                    // Agregar estos contratos a la lista de facturables para que se muestren
                    contratosFacurables.AddRange(contratosConDecomision);
                    Console.WriteLine($"Lista de facturables actualizada. Total: {contratosFacurables.Count}");
                }
            }
            
            // Log final: mostrar todos los contratos que se van a mostrar
            Console.WriteLine($"=== CONTRATOS FINALES A MOSTRAR ===");
            foreach (var cf in contratosFacurables.OrderBy(c => c.Tipo).ThenByDescending(c => c.FechaCreacion))
            {
                var identificador = cf.EnCups ?? cf.LineaMovilPrincipal ?? cf.Direccion ?? $"ID:{cf.Id}";
                Console.WriteLine($"  ID={cf.Id}, Tipo={cf.Tipo}, Estado={cf.Estado}, Ref={identificador}");
            }
            
            // Verificar todos los contratos de este usuario
            var todosContratos = await context.Contratos
                .Where(c => c.Comercial == usuarioSeleccionado.NombreUsuario)
                .Select(c => new { c.Id, c.Tipo, c.Estado, c.Comercial })
                .ToListAsync();
            
            Console.WriteLine($"Total contratos del usuario: {todosContratos.Count}");
            foreach (var c in todosContratos)
            {
                Console.WriteLine($"  - ID: {c.Id}, Tipo: {c.Tipo}, Estado: '{c.Estado}', Comercial: '{c.Comercial}'");
            }
            
            // Calcular las listas derivadas de contratos por tipo
            contratosEnergia = contratosFacurables.Where(c => 
            {
                var tipoNormalizado = c.Tipo?.ToLower()
                    .Replace("í", "i")
                    .Replace("ó", "o")
                    .Replace("á", "a")
                    .Replace("é", "e")
                    .Replace("ú", "u");
                return tipoNormalizado == "energia";
            }).ToList();
            
            contratosTelefonia = contratosFacurables.Where(c => 
            {
                var tipoNormalizado = c.Tipo?.ToLower()
                    .Replace("í", "i")
                    .Replace("ó", "o")
                    .Replace("á", "a")
                    .Replace("é", "e")
                    .Replace("ú", "u");
                return tipoNormalizado == "telefonia";
            }).ToList();
            
            contratosAlarmas = contratosFacurables.Where(c => 
            {
                var tipoNormalizado = c.Tipo?.ToLower()
                    .Replace("í", "i")
                    .Replace("ó", "o")
                    .Replace("á", "a")
                    .Replace("é", "e")
                    .Replace("ú", "u");
                return tipoNormalizado == "alarma";
            }).ToList();
            
            Console.WriteLine($"[FILTRADO] Energía: {contratosEnergia.Count}, Telefonía: {contratosTelefonia.Count}, Alarmas: {contratosAlarmas.Count}");
            
            mostrarModalContratos = true;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar contratos: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al cargar contratos: {ex.Message}");
        }
    }

