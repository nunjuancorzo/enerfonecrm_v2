    private async Task RechazarLiquidacionPendiente(int liquidacionId)
    {
        try
        {
            // VALIDACIÓN DE SEGURIDAD: Solo administradores y superadmin pueden rechazar
            if (!AuthService.EsAdministrador && !AuthService.EsSuperAdmin)
            {
                mensajeError = "No tienes permisos para rechazar liquidaciones pendientes";
                Console.WriteLine($"[LIQUIDACIONES] Usuario {AuthService.UsuarioActual?.NombreUsuario} intentó rechazar liquidación sin permisos");
                return;
            }

            await using var context = DbContextProvider.CreateDbContext();
            
            // Obtener la liquidación pendiente directamente por ID
            var liquidacion = await context.HistoricoLiquidaciones
                .Include(l => l.Detalles)
                .FirstOrDefaultAsync(l => l.Id == liquidacionId && l.Estado == "Pendiente");
            
            if (liquidacion == null)
            {
                mensajeError = "No se encontró la liquidación pendiente.";
                return;
            }
            
            // Obtener información del usuario
            var usuario = await context.Usuarios.FindAsync(liquidacion.UsuarioId);
            if (usuario == null)
            {
                mensajeError = "Usuario no encontrado.";
                return;
            }

            // Contar contratos vinculados a esta liquidación
            var idsContratos = await context.DetallesComisionLiquidacion
                .Where(d => d.HistoricoLiquidacionId == liquidacion.Id)
                .Select(d => d.ContratoId)
                .Distinct()
                .ToListAsync();
            
            var contratos = await context.Contratos
                .Where(c => idsContratos.Contains(c.Id))
                .ToListAsync();

            Console.WriteLine($"[LIQUIDACIONES] Liquidación encontrada: ID={liquidacion.Id}, Usuario={usuario.NombreUsuario}");
            Console.WriteLine($"[LIQUIDACIONES] Contratos vinculados: {contratos.Count}");
            
            if (contratos.Count == 0)
            {
                Console.WriteLine($"[LIQUIDACIONES] ADVERTENCIA: Esta liquidación no tiene contratos vinculados");
            }

            // Preparar y mostrar el modal de confirmación
            usuarioIdEliminar = liquidacionId; // Guardamos el ID de la liquidación
            mensajeConfirmacionEliminar = usuario.NombreUsuario;
            contratosADesvincular = contratos.Count;
            mostrarModalConfirmacionEliminar = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al preparar eliminación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al preparar eliminación: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
        }
    }

