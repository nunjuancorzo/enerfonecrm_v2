    private async Task EliminarLiquidacion(int liquidacionId)
    {
        try
        {
            // VALIDACIÓN DE SEGURIDAD: Solo administradores y superadmin pueden eliminar liquidaciones
            if (!AuthService.EsAdministrador && !AuthService.EsSuperAdmin)
            {
                mensajeError = "No tienes permisos para eliminar liquidaciones";
                Console.WriteLine($"[LIQUIDACIONES] Usuario {AuthService.UsuarioActual?.NombreUsuario} intentó eliminar liquidación sin permisos");
                return;
            }

            // Solicitar confirmación
            bool confirmado = await JSRuntime.InvokeAsync<bool>(
                "confirm", 
                "¿Está seguro de que desea eliminar esta liquidación?\n\nEsta acción no se puede deshacer y eliminará la liquidación, sus detalles y desvinculará los contratos.");
            
            if (!confirmado)
            {
                return;
            }

            await using var context = DbContextProvider.CreateDbContext();
            
            // Obtener la liquidación
            var liquidacion = await context.HistoricoLiquidaciones
                .Include(l => l.Detalles)
                .FirstOrDefaultAsync(l => l.Id == liquidacionId);
            
            if (liquidacion == null)
            {
                mensajeError = "No se encontró la liquidación.";
                return;
            }
            
            Console.WriteLine($"[LIQUIDACIONES] ===== ELIMINANDO LIQUIDACIÓN =====");
            Console.WriteLine($"[LIQUIDACIONES] Liquidación ID: {liquidacionId}");
            Console.WriteLine($"[LIQUIDACIONES] Usuario: {liquidacion.UsuarioNombre}");
            Console.WriteLine($"[LIQUIDACIONES] Estado: {liquidacion.Estado}");

            // Desvincular contratos y restaurar su estado a "Act/Facturable"
            var contratos = await context.Contratos
                .Where(c => c.HistoricoLiquidacionId == liquidacionId)
                .ToListAsync();
            
            foreach (var contrato in contratos)
            {
                contrato.HistoricoLiquidacionId = null;
                if (contrato.Estado == "Liquidado")
                {
                    contrato.Estado = "Act/Facturable";
                }
            }
            
            Console.WriteLine($"[LIQUIDACIONES] Desvinculados {contratos.Count} contratos y restaurados a Act/Facturable");
            
            // Desvincular decomisiones
            var decomisiones = await context.Decomisiones
                .Where(d => d.LiquidacionDecomisionId == liquidacionId)
                .ToListAsync();
            
            foreach (var decomision in decomisiones)
            {
                decomision.LiquidacionDecomisionId = null;
            }
            
            if (decomisiones.Any())
            {
                Console.WriteLine($"[LIQUIDACIONES] Desvinculadas {decomisiones.Count} decomisiones");
            }

            // Eliminar los detalles de la liquidación
            if (liquidacion.Detalles != null && liquidacion.Detalles.Any())
            {
                context.DetallesComisionLiquidacion.RemoveRange(liquidacion.Detalles);
                Console.WriteLine($"[LIQUIDACIONES] Eliminados {liquidacion.Detalles.Count} detalles de comisión");
            }

            // Si es una liquidación de colaborador que fue aceptada, eliminar también las liquidaciones de jerarquía creadas
            var usuario = await context.Usuarios.FindAsync(liquidacion.UsuarioId);
            if (usuario != null && usuario.Rol == "Colaborador" && liquidacion.Estado == "Aceptada")
            {
                // Buscar liquidaciones de jerarquía creadas cuando el colaborador aceptó
                // Las liquidaciones de jerarquía tienen AprobadoPorId = colaboradorId
                var liquidacionesJerarquia = await context.HistoricoLiquidaciones
                    .Include(l => l.Detalles)
                    .Where(l => l.AprobadoPorId == liquidacion.UsuarioId 
                            && l.FechaAprobacion.Date == liquidacion.FechaAceptada.Value.Date
                            && l.Id != liquidacionId)
                    .ToListAsync();
                
                foreach (var liqJerarquia in liquidacionesJerarquia)
                {
                    // Eliminar detalles
                    if (liqJerarquia.Detalles != null && liqJerarquia.Detalles.Any())
                    {
                        context.DetallesComisionLiquidacion.RemoveRange(liqJerarquia.Detalles);
                    }
                    context.HistoricoLiquidaciones.Remove(liqJerarquia);
                    Console.WriteLine($"[LIQUIDACIONES] Eliminada liquidación de jerarquía {liqJerarquia.Id} ({liqJerarquia.UsuarioNombre})");
                }
            }

            // Eliminar la liquidación principal
            context.HistoricoLiquidaciones.Remove(liquidacion);
            
            await context.SaveChangesAsync();
            
            Console.WriteLine($"[LIQUIDACIONES] Liquidación {liquidacionId} eliminada exitosamente");
            Console.WriteLine($"[LIQUIDACIONES] ====================================");
            
            // Recargar las liquidaciones
            await CargarLiquidacionesPorEstado();
            await CargarUsuariosConContratos();
            
            mensajeError = string.Empty;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al eliminar la liquidación: {ex.Message}";
            Console.WriteLine($"[LIQUIDACIONES] Error al eliminar liquidación: {ex.Message}");
            Console.WriteLine($"[LIQUIDACIONES] Stack trace: {ex.StackTrace}");
        }
    }

