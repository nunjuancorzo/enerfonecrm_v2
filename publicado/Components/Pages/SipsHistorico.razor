@page "/sips/historico"
@using EnerfoneCRM.Services
@using EnerfoneCRM.Models
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject SipsService SipsService
@rendermode InteractiveServer

<PageTitle>Histórico SIPS - CRM</PageTitle>

@if (!cargado)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (!AuthService.EstaAutenticado)
{
    Navigation.NavigateTo("/login", false);
}
else if (!AuthService.EsSuperAdmin)
{
    <div class="container-fluid p-4">
        <div class="alert alert-warning" role="alert">
            No tienes permisos para acceder al histórico de SIPS.
        </div>
        <button class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/home"))">
            Volver
        </button>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">
                <i class="bi bi-clock-history me-2 text-purple"></i>Histórico SIPS
            </h2>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-12 col-lg-6">
                @if (quotaUsed.HasValue)
                {
                    <div class="card shadow-sm">
                        <div class="card-body py-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Cuota mensual</div>
                                    <div class="fw-bold" style="font-size: 1.1rem;">
                                        @quotaUsed@(quotaTotal.HasValue ? $"/{quotaTotal}" : string.Empty)
                                        <span class="text-muted" style="font-weight: 400; font-size: 0.9rem;">consultas API</span>
                                    </div>
                                </div>
                                <i class="bi bi-speedometer2 text-purple" style="font-size: 1.6rem;"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted" style="font-size: 0.85rem;">Acceso rápido</div>
                                <div class="fw-bold" style="font-size: 1.1rem;">Abrir consulta por CUPS</div>
                            </div>
                            <a class="btn btn-sm btn-outline-primary" href="/sips">
                                <i class="bi bi-search me-1"></i>Ir a consulta
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensajeError))
        {
            <div class="alert alert-danger" role="alert">
                @mensajeError
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center">
                    <i class="bi bi-list-ul me-2"></i>
                    <span class="fw-semibold">Últimas consultas</span>
                    <span class="text-muted ms-2" style="font-size: 0.9rem;">(máx. @take)</span>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="Cargar" disabled="@cargando">
                    <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
                </button>
            </div>
            <div class="card-body">
                @if (cargando)
                {
                    <div class="text-center p-4">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (items == null || items.Count == 0)
                {
                    <div class="text-muted">No hay consultas registradas todavía.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm align-middle">
                            <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                                <tr>
                                    <th>Fecha</th>
                                    <th>CUPS</th>
                                    <th>Usuario</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">HTTP</th>
                                    <th class="text-end">Tamaño</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in items)
                                {
                                    <tr class="@(row.Success ? string.Empty : "table-danger")">
                                        <td>@row.FechaConsulta.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="fw-bold font-monospace">@row.Cups</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.UsuarioNombre) ? "-" : row.UsuarioNombre)</td>
                                        <td class="text-center">
                                            @if (row.Success)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check2-circle me-1"></i>OK</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger" title="@row.ErrorMessage"><i class="bi bi-x-circle me-1"></i>ERROR</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (row.HttpStatusCode.HasValue)
                                            {
                                                <span class="badge bg-secondary">@row.HttpStatusCode</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-end">@(row.ResponseSize.HasValue ? (row.ResponseSize.Value / 1024.0).ToString("N1") + " KB" : "-")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-primary" @onclick="() => Abrir(row.Cups)">
                                                <i class="bi bi-box-arrow-up-right me-1"></i>Abrir
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="text-muted mt-2" style="font-size: 0.85rem;">
                        <i class="bi bi-info-circle me-1"></i>
                        Las filas en rojo son errores; la app no repite errores 4xx durante el TTL configurado.
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .text-purple {
        color: #9C27B0;
    }
</style>

@code {
    private bool cargado;
    private bool cargando;
    private string? mensajeError;
    private List<HistoricoSipsConsulta>? items;
    private int take = 200;
    private int? quotaUsed;
    private int? quotaTotal;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.CargarSesionAsync();
        cargado = true;
        StateHasChanged();

        if (!AuthService.EstaAutenticado) return;

        await Cargar();
    }

    private async Task Cargar()
    {
        try
        {
            cargando = true;
            mensajeError = null;
            StateHasChanged();

            items = await SipsService.ObtenerUltimasConsultasAsync(take);
            var quota = await SipsService.ObtenerCuotaMesActualAsync();
            quotaUsed = quota.Used;
            quotaTotal = quota.Quota;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar el histórico: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void Abrir(string cups)
    {
        Navigation.NavigateTo($"/sips?cups={Uri.EscapeDataString(cups)}");
    }
}
