        if (string.IsNullOrWhiteSpace(emailCliente) || !emailCliente.Contains("@"))
            errores.Add("Paso 3: El email del cliente es inválido");
        if (string.IsNullOrWhiteSpace(direccionCliente))
            errores.Add("Paso 3: La dirección del cliente es obligatoria");

        // Validar consultor si está activo
        if (mostrarDatosConsultor)
        {
            if (string.IsNullOrWhiteSpace(nombreConsultor))
                errores.Add("Paso 3: El nombre del consultor es obligatorio");
            if (string.IsNullOrWhiteSpace(telefonoConsultor))
                errores.Add("Paso 3: El teléfono del consultor es obligatorio");
            if (string.IsNullOrWhiteSpace(emailConsultor) || !emailConsultor.Contains("@"))
                errores.Add("Paso 3: El email del consultor es inválido");
        }

        // Validar Paso 4: Consumo anual y facturación
        if (consumoAnual <= 0)
            errores.Add("Paso 4: El consumo anual debe ser mayor que 0");
        if (!fechaInicioFacturacion.HasValue || !fechaFinFacturacion.HasValue)
            errores.Add("Paso 4: Las fechas de facturación son obligatorias");
        if (fechaInicioFacturacion.HasValue && fechaFinFacturacion.HasValue && 
            fechaFinFacturacion.Value <= fechaInicioFacturacion.Value)
            errores.Add("Paso 4: La fecha de fin debe ser posterior a la de inicio");

        // Validar Paso 5: Potencia
        if (potenciaPunta <= 0 || potenciaValle <= 0)
            errores.Add("Paso 5: Las potencias Punta y Valle son obligatorias");
        if (precioPotenciaPunta < 0 || precioPotenciaValle < 0)
            errores.Add("Paso 5: Los precios de potencia no pueden ser negativos");

        // Paso 7: Los consumos por periodo son opcionales
        // Si no hay consumos por periodo, se usará el consumo anual distribuido proporcionalmente

        // Si hay errores, mostrarlos y no continuar
        if (errores.Any())
        {
            mensajeError = string.Join("<br/>", errores);
            return;
        }

        // Calcular directamente las ofertas
        await CalcularComparativa();
    }

    private void OnTipoIVAChanged()
    {
        porcentajeIVA = tipoIVA switch
        {
            "General" => 21,
            "Reducido" => 10,
            "Superreducido" => 4,
            _ => 21
        };
    }

    private void OnConceptoChanged(string concepto, ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        
        if (isChecked && !conceptosSeleccionados.Contains(concepto))
        {
            conceptosSeleccionados.Add(concepto);
        }
        else if (!isChecked && conceptosSeleccionados.Contains(concepto))
        {
            conceptosSeleccionados.Remove(concepto);
        }
    }

    private void OnOfertaSeleccionada(int posicion, ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        
        if (isChecked && !ofertasSeleccionadas.Contains(posicion))
        {
            ofertasSeleccionadas.Add(posicion);
        }
        else if (!isChecked && ofertasSeleccionadas.Contains(posicion))
        {
            ofertasSeleccionadas.Remove(posicion);
        }
    }

    private async Task CalcularComparativa()
    {
        calculando = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
        StateHasChanged();

        try
        {
            // Si no hay consumos por periodo pero sí consumo anual, distribuir proporcionalmente
            if (consumoPunta <= 0 && consumoLlano <= 0 && consumoValle <= 0 && consumoAnual > 0)
            {
                // Distribución típica para tarifa 2.0TD: 40% Punta, 60% Valle
                consumoPunta = consumoAnual * 0.4m / 12; // Mensual
                consumoValle = consumoAnual * 0.6m / 12; // Mensual
                consumoLlano = 0;
            }

            // Obtener todas las tarifas de energía
            var todasLasTarifas = await TarifaEnergiaService.ObtenerTodasAsync();
            
            comercializadoras.Clear();

            // Calcular el coste actual del cliente para comparación
            decimal costeActualMensual = 0;
            decimal costePotenciaMensual = ((potenciaPunta * precioPotenciaPunta) + (potenciaValle * precioPotenciaValle)) * 
                                           (tipoFacturacionPotencia == "Diaria" ? 30 : tipoFacturacionPotencia == "Mensual" ? 1 : 1.0m/12);
            decimal costeConsumoMensual = (consumoPunta * precioConsumoPunta + consumoLlano * precioConsumoLlano + consumoValle * precioConsumoValle);
            
            // Aplicar descuentos
            if (descuentoPotencia > 0)
                costePotenciaMensual *= (1 - descuentoPotencia / 100);
            if (descuentoConsumo > 0)
                costeConsumoMensual *= (1 - descuentoConsumo / 100);
            
            // Aplicar impuestos
            decimal baseImponible = costePotenciaMensual + costeConsumoMensual + alquilerContador;
            baseImponible *= (1 + porcentajeImpuestoElectricidad / 100);
            costeActualMensual = baseImponible * (1 + porcentajeIVA / 100);

            foreach (var tarifa in todasLasTarifas)
            {
                // Solo incluir tarifas activas
                if (!tarifa.Activa)
                    continue;

                // Calcular costes mensuales estimados
                decimal terminoFijo = (tarifa.TerminoFijoDiario ?? 0) * 30;
                
                decimal costePotencia = ((tarifa.PrecioPotenciaP1 ?? 0) * potenciaPunta + 
                                        (tarifa.PrecioPotenciaP2 ?? 0) * potenciaValle) * 30;
                
                decimal costeEnergia = (tarifa.PrecioEnergiaP1 ?? 0) * consumoPunta + 
                                      (tarifa.PrecioEnergiaP2 ?? 0) * consumoLlano + 
                                      (tarifa.PrecioEnergiaP3 ?? 0) * consumoValle;
                
                decimal costeTotal = terminoFijo + costePotencia + costeEnergia;
                
                // Aplicar impuestos
                costeTotal *= (1 + porcentajeImpuestoElectricidad / 100);
                costeTotal *= (1 + porcentajeIVA / 100);

                decimal ahorroMensual = costeActualMensual - costeTotal;
                decimal ahorroAnual = ahorroMensual * 12;
                decimal porcentajeAhorro = costeActualMensual > 0 ? (ahorroMensual / costeActualMensual) * 100 : 0;

                comercializadoras.Add(new ResultadoComparativa
                {
                    IdTarifa = tarifa.Id,
                    Empresa = tarifa.Empresa,
                    NombreTarifa = tarifa.Nombre,
                    CosteTerminoFijo = terminoFijo,
                    CostePotencia = costePotencia,
                    CosteEnergia = costeEnergia,
                    CosteTotal = costeTotal,
                    CosteMensual = costeTotal,
                    CosteActual = costeActualMensual,
                    AhorroMensual = ahorroMensual,
                    AhorroAnual = ahorroAnual,
                    PorcentajeAhorro = porcentajeAhorro,
                    PrecioPotenciaPunta = tarifa.PrecioPotenciaP1 ?? 0,
                    PrecioPotenciaValle = tarifa.PrecioPotenciaP2 ?? 0,
                    PrecioEnergiaPunta = tarifa.PrecioEnergiaP1 ?? 0,
                    PrecioEnergiaLlano = tarifa.PrecioEnergiaP2 ?? 0,
                    PrecioEnergiaValle = tarifa.PrecioEnergiaP3 ?? 0,
                    TerminoFijoDiario = tarifa.TerminoFijoDiario ?? 0
                });
            }

            // Filtrar por ahorro mínimo solo si hay un coste actual válido
            if (costeActualMensual > 0 && ahorroMinimo > 0)
            {
                var conAhorro = comercializadoras.Where(c => c.PorcentajeAhorro >= ahorroMinimo).ToList();
                if (conAhorro.Any())
                {
                    comercializadoras = conAhorro;
                }
                // Si no hay ninguna con ahorro suficiente, mostrar todas igual
            }

            // Ordenar por mejor ahorro (mayor ahorro primero) o por menor coste si no hay coste actual
            comercializadoras = costeActualMensual > 0 
                ? comercializadoras.OrderByDescending(c => c.AhorroMensual).ToList()
                : comercializadoras.OrderBy(c => c.CosteMensual).ToList();

            resultadosCalculados = true;
            
            if (comercializadoras.Count == 0)
            {
                mensajeError = "No se encontraron tarifas activas configuradas en el sistema.";
            }
            else
            {
                mensajeExito = $"Se encontraron {comercializadoras.Count} ofertas disponibles.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al calcular la comparativa: {ex.Message}";
        }
        finally
        {
            calculando = false;
            StateHasChanged();
        }
    }

    private bool ValidarPaso3()
    {
        if (string.IsNullOrWhiteSpace(nombreCliente))
            return false;

        if (string.IsNullOrWhiteSpace(emailCliente))
            return false;

        // Validar formato de email básico
        if (!emailCliente.Contains("@") || !emailCliente.Contains("."))
            return false;

        if (string.IsNullOrWhiteSpace(direccionCliente))
            return false;

        // Si el switch de consultor está activo, validar esos datos también
        if (mostrarDatosConsultor)
        {
            if (string.IsNullOrWhiteSpace(nombreConsultor))
                return false;

            if (string.IsNullOrWhiteSpace(telefonoConsultor))
                return false;

            // Validar que el teléfono tenga al menos 9 dígitos
            var digitosTelefono = new string(telefonoConsultor.Where(char.IsDigit).ToArray());
            if (digitosTelefono.Length < 9)
                return false;

            if (string.IsNullOrWhiteSpace(emailConsultor))
                return false;

            // Validar formato de email del consultor
            if (!emailConsultor.Contains("@") || !emailConsultor.Contains("."))
                return false;
        }

        return true;
    }

    private bool ValidarPaso4()
    {
        // Validar que el consumo anual sea mayor que 0
        if (consumoAnual <= 0)
            return false;

        // Validar que las fechas estén completas
        if (!fechaInicioFacturacion.HasValue || !fechaFinFacturacion.HasValue)
            return false;

        // Validar que la fecha de fin sea posterior a la de inicio
        if (fechaFinFacturacion.Value <= fechaInicioFacturacion.Value)
            return false;

        return true;
    }

    private bool ValidarPaso5()
    {
        // Validar que las potencias sean mayores que 0
        if (potenciaPunta <= 0 || potenciaValle <= 0)
            return false;

        // Validar que los precios de potencia sean mayores o iguales a 0
        if (precioPotenciaPunta < 0 || precioPotenciaValle < 0)
            return false;

        // Validar que el descuento esté entre 0 y 100
        if (descuentoPotencia < 0 || descuentoPotencia > 100)
            return false;

        return true;
    }

    private bool ValidarPaso7()
    {
        // Validar que al menos un consumo sea mayor que 0
        if (consumoPunta <= 0 && consumoLlano <= 0 && consumoValle <= 0)
            return false;

        // Validar que los precios de consumo sean mayores o iguales a 0
        if (precioConsumoPunta < 0 || precioConsumoLlano < 0 || precioConsumoValle < 0)
            return false;

        // Validar que el descuento esté entre 0 y 100
        if (descuentoConsumo < 0 || descuentoConsumo > 100)
            return false;

        return true;
    }

    private async Task CompararTarifas()
    {
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        // Validaciones
        if (string.IsNullOrEmpty(tipoTarifa))
        {
            mensajeError = "Debe seleccionar un tipo de tarifa";
            return;
        }

        if (potenciaP1 <= 0)
        {
            mensajeError = "Debe introducir al menos la potencia del periodo 1";
            return;
        }

        if (consumoP1 <= 0 && consumoP2 <= 0 && consumoP3 <= 0)
        {
            mensajeError = "Debe introducir al menos un consumo estimado";
            return;
        }

        calculando = true;
        StateHasChanged();

        try
        {
            // Obtener todas las tarifas de energía de la base de datos
            var todasLasTarifas = await TarifaEnergiaService.ObtenerTodasAsync();
            
            comercializadoras.Clear();

            foreach (var tarifa in todasLasTarifas)
            {
                // Solo incluir tarifas que tengan los precios configurados
                if (tarifa.TerminoFijoDiario == null || tarifa.TerminoFijoDiario <= 0 ||
                    tarifa.PrecioPotenciaP1 == null || tarifa.PrecioPotenciaP1 <= 0 ||
                    tarifa.PrecioEnergiaP1 == null || tarifa.PrecioEnergiaP1 <= 0)
                {
                    continue; // Saltar tarifas sin precios configurados
                }

                // Calcular costes anuales
                decimal costeTerminoFijo = tarifa.TerminoFijoDiario.Value * 365;
                
                decimal costePotencia = (tarifa.PrecioPotenciaP1.Value * potenciaP1 + 
                                        (tarifa.PrecioPotenciaP2 ?? 0) * potenciaP2 + 
                                        (tarifa.PrecioPotenciaP3 ?? 0) * potenciaP3) * 365;
                
                decimal costeEnergia = (tarifa.PrecioEnergiaP1.Value * consumoP1 + 
                                       (tarifa.PrecioEnergiaP2 ?? 0) * consumoP2 + 
                                       (tarifa.PrecioEnergiaP3 ?? 0) * consumoP3);
                
                decimal costeTotal = costeTerminoFijo + costePotencia + costeEnergia;

                comercializadoras.Add(new ResultadoComparativa
                {
                    Empresa = tarifa.Empresa,
                    NombreTarifa = tarifa.Nombre,
                    CosteTerminoFijo = costeTerminoFijo,
                    CostePotencia = costePotencia,
                    CosteEnergia = costeEnergia,
                    CosteTotal = costeTotal
                });
            }

            resultadosCalculados = true;
            
            if (comercializadoras.Count == 0)
            {
                mensajeError = "No se encontraron tarifas con precios configurados. Por favor, configure los precios en las tarifas de energía.";
            }
            else
            {
                mensajeExito = $"Comparativa realizada con éxito. Se encontraron {comercializadoras.Count} tarifas.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al realizar la comparativa: {ex.Message}";
        }
        finally
        {
            calculando = false;
            StateHasChanged();
        }
    }

