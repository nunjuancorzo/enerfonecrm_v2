    private async Task OnConsultarSipsChanged(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        consultarSips = isChecked;

        // Solo consultar si se marca el checkbox y hay un CUPS
        if (!isChecked || string.IsNullOrWhiteSpace(cups))
        {
            // Si se desmarca, limpiar mensaje de éxito
            if (!isChecked)
            {
                mensajeExito = string.Empty;
            }
            return;
        }

        // Mostrar indicador de carga
        mensajeError = string.Empty;
        mensajeExito = "Consultando SIPS...";
        StateHasChanged();

        try
        {
            // Consultar SIPS
            var resultado = await SipsService.ObtenerDatosCupsConCacheAsync(cups);
            
            if (resultado.Respuesta == null || resultado.Respuesta.ClientesSips == null || !resultado.Respuesta.ClientesSips.Any())
            {
                mensajeError = "No se pudo obtener información del CUPS. Verifica que sea correcto.";
                mensajeExito = string.Empty;
                consultarSips = false;
                return;
            }

            var datosSips = resultado.Respuesta.ClientesSips.First();
            var consumosSips = resultado.Respuesta.ConsumosSips?.OrderByDescending(c => c.FechaFin).FirstOrDefault();

            // ===== PASO 2: Datos base =====
            // Autocompletar compañía (si está en el listado)
            if (!string.IsNullOrEmpty(datosSips.NombreEmpresaDistribuidora))
            {
                var companiaEncontrada = listadoCompanias.FirstOrDefault(c => 
                    c.Contains(datosSips.NombreEmpresaDistribuidora, StringComparison.OrdinalIgnoreCase) ||
                    datosSips.NombreEmpresaDistribuidora.Contains(c, StringComparison.OrdinalIgnoreCase));
                
                if (companiaEncontrada != null)
                    companiaActual = companiaEncontrada;
                else
                    companiaActual = datosSips.NombreEmpresaDistribuidora;
            }

            // Autocompletar tarifa
            if (!string.IsNullOrEmpty(datosSips.CodigoTarifaATREnVigor))
            {
                var codigoTarifa = datosSips.CodigoTarifaATREnVigor;
                
                // Mapear el código de SIPS a las tarifas disponibles
                // Si viene 2.0DHA, 2.0A, etc., se mapea a 2.0TD
                if (codigoTarifa.StartsWith("2.0"))
                    tarifaActual = "2.0TD";
                else if (codigoTarifa.StartsWith("3.0"))
                    tarifaActual = "3.0TD";
                else if (codigoTarifa.StartsWith("6.1"))
                    tarifaActual = "6.1TD";
                else if (listadoTarifas.Contains(codigoTarifa))
                    tarifaActual = codigoTarifa;
                else
                    tarifaActual = "No lo sé"; // Si no se puede mapear, usar "No lo sé"
                
                // Forzar actualización de UI
                StateHasChanged();
            }
            else
            {
                // Si SIPS no devuelve código de tarifa, poner "No lo sé"
                tarifaActual = "No lo sé";
            }

            // ===== PASO 3: Datos del cliente =====
            // Autocompletar dirección completa
            if (!string.IsNullOrEmpty(datosSips.ViaPS))
            {
                var direccion = "";
                if (!string.IsNullOrEmpty(datosSips.TipoViaPS))
                    direccion += datosSips.TipoViaPS + " ";
                direccion += datosSips.ViaPS ?? "";
                if (!string.IsNullOrEmpty(datosSips.NumFincaPS))
                    direccion += " " + datosSips.NumFincaPS;
                if (!string.IsNullOrEmpty(datosSips.PortalPS))
                    direccion += ", Portal " + datosSips.PortalPS;
                if (!string.IsNullOrEmpty(datosSips.EscaleraPS))
                    direccion += ", Escalera " + datosSips.EscaleraPS;
                if (!string.IsNullOrEmpty(datosSips.PisoPS))
                    direccion += ", " + datosSips.PisoPS + "º";
                if (!string.IsNullOrEmpty(datosSips.PuertaPS))
                    direccion += " " + datosSips.PuertaPS;
                if (!string.IsNullOrEmpty(datosSips.CodigoPostalPS))
                    direccion += ", " + datosSips.CodigoPostalPS;
                if (!string.IsNullOrEmpty(datosSips.DesMunicipioPS))
                    direccion += " " + datosSips.DesMunicipioPS;
                if (!string.IsNullOrEmpty(datosSips.DesProvinciaPS))
                    direccion += ", " + datosSips.DesProvinciaPS;
                
                direccionCliente = direccion.Trim();
            }

            // ===== PASO 4: Consumo anual y facturación =====
            if (consumosSips != null)
            {
                // Calcular consumo anual total de todos los periodos
                decimal consumoTotal = 0;
                if (consumosSips.Activa1.HasValue) consumoTotal += consumosSips.Activa1.Value;
                if (consumosSips.Activa2.HasValue) consumoTotal += consumosSips.Activa2.Value;
                if (consumosSips.Activa3.HasValue) consumoTotal += consumosSips.Activa3.Value;
                if (consumosSips.Activa4.HasValue) consumoTotal += consumosSips.Activa4.Value;
                if (consumosSips.Activa5.HasValue) consumoTotal += consumosSips.Activa5.Value;
                if (consumosSips.Activa6.HasValue) consumoTotal += consumosSips.Activa6.Value;
                
                consumoAnual = consumoTotal;

                // Autocompletar fechas de facturación
                if (consumosSips.FechaInicio.HasValue)
                    fechaInicioFacturacion = DateOnly.FromDateTime(consumosSips.FechaInicio.Value);
                if (consumosSips.FechaFin.HasValue)
                    fechaFinFacturacion = DateOnly.FromDateTime(consumosSips.FechaFin.Value);
            }

            // Tipo de facturación según el código de periodicidad
            if (!string.IsNullOrEmpty(datosSips.CodigoPeriodicidadFacturacion))
            {
                // M = Mensual, B = Bimensual, etc.
                tipoFacturacionPotencia = datosSips.CodigoPeriodicidadFacturacion == "M" ? "Mensual" : "Diaria";
            }

            // ===== PASO 5: Potencia contratada =====
            // Autocompletar potencias (convertir de W a kW)
            if (datosSips.PotenciasContratadasEnWP1.HasValue)
                potenciaPunta = datosSips.PotenciasContratadasEnWP1.Value / 1000m;
            if (datosSips.PotenciasContratadasEnWP2.HasValue)
                potenciaValle = datosSips.PotenciasContratadasEnWP2.Value / 1000m;

            // Los precios de potencia no vienen en SIPS, el usuario deberá completarlos manualmente

            // ===== PASO 6: Impuestos y zona =====
            // Autocompletar zona según provincia
            if (!string.IsNullOrEmpty(datosSips.DesProvinciaPS))
            {
                var provincia = datosSips.DesProvinciaPS.ToLower();
                if (provincia.Contains("baleares") || provincia.Contains("illes balears") || provincia.Contains("mallorca") || 
                    provincia.Contains("menorca") || provincia.Contains("ibiza") || provincia.Contains("formentera"))
                    zona = "Baleares";
                else if (provincia.Contains("canarias") || provincia.Contains("las palmas") || provincia.Contains("tenerife") ||
                         provincia.Contains("gran canaria") || provincia.Contains("lanzarote") || provincia.Contains("fuerteventura") ||
                         provincia.Contains("la palma") || provincia.Contains("gomera") || provincia.Contains("hierro"))
                    zona = "Canarias";
                else if (provincia.Contains("ceuta"))
                    zona = "Ceuta";
                else if (provincia.Contains("melilla"))
                    zona = "Melilla";
                else
                    zona = "Península";
            }

            // ===== PASO 7: Consumo por periodos =====
            if (consumosSips != null)
            {
                // Distribuir consumos según tarifa
                var tarifa = datosSips.CodigoTarifaATREnVigor ?? "";
                
                if (tarifa.StartsWith("2.0"))
                {
                    // 2.0TD tiene 2 periodos: P1 (Punta) y P2 (Valle)
                    if (consumosSips.Activa1.HasValue)
                        consumoPunta = consumosSips.Activa1.Value;
                    if (consumosSips.Activa2.HasValue)
                        consumoValle = consumosSips.Activa2.Value;
                }
                else if (tarifa.StartsWith("3.0") || tarifa.StartsWith("6."))
                {
                    // 3.0TD y 6.XTD tienen 3 o 6 periodos
                    if (consumosSips.Activa1.HasValue)
                        consumoPunta = consumosSips.Activa1.Value;
                    if (consumosSips.Activa2.HasValue)
                        consumoLlano = consumosSips.Activa2.Value;
                    if (consumosSips.Activa3.HasValue)
                        consumoValle = consumosSips.Activa3.Value;
                    // Si hay más periodos, sumarlos al llano
                    if (consumosSips.Activa4.HasValue)
                        consumoLlano += consumosSips.Activa4.Value;
                    if (consumosSips.Activa5.HasValue)
                        consumoLlano += consumosSips.Activa5.Value;
                    if (consumosSips.Activa6.HasValue)
                        consumoLlano += consumosSips.Activa6.Value;
                }
            }

            // Mensaje de éxito con información adicional
            var consumosAutocompletados = (consumoPunta > 0 || consumoLlano > 0 || consumoValle > 0);
            if (consumosAutocompletados)
                mensajeExito = "✓ Datos del CUPS cargados correctamente desde SIPS (incluidos consumos por periodo)";
            else
                mensajeExito = "✓ Datos del CUPS cargados desde SIPS (consumos por periodo se calcularán automáticamente)";
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al consultar SIPS: {ex.Message}";
            mensajeExito = string.Empty;
            consultarSips = false;
        }
        finally
        {
            StateHasChanged();
        }
    }

