@page "/comparador/energia"
@using EnerfoneCRM.Models
@using EnerfoneCRM.Services
@using System.Linq
@rendermode InteractiveServer
@inject TarifaEnergiaService TarifaEnergiaService
@inject ComercializadoraService ComercializadoraService
@inject SipsService SipsService
@inject AuthService AuthService
@inject PdfComparadorService PdfComparadorService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Comparador de Tarifas de Energía - Enerfone CRM</PageTitle>

@if (cargandoSesion)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    @if (!AuthService.EstaAutenticado)
    {
        <div class="alert alert-warning m-4">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No tienes acceso a esta página. Por favor, inicia sesión.
        </div>
    }
    else
    {
        <div class="container-fluid p-4">
            <div class="row mb-4">
                <div class="col-md-12">
                    <h2 class="mb-0">
                        <i class="bi bi-calculator me-2 text-warning"></i>
                        Comparador de Tarifas de Energía
                    </h2>
                    <p class="text-muted">Introduce los datos de tu contrato actual y descubre las tarifas más económicas</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(mensajeExito))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@mensajeExito
                    <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @((MarkupString)mensajeError)
                    <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                </div>
            }

            @if (!resultadosCalculados)
            {
                <!-- Wizard de comparativa -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body p-5">
                        @if (pasoActual == 1)
                        {
                            <!-- Botón de avance superior -->
                            <div class="d-flex justify-content-center mb-4">
                                <button class="btn btn-warning px-4" 
                                        @onclick="AvanzarPaso1" 
                                        disabled="@(string.IsNullOrWhiteSpace(cups))">
                                    <i class="bi bi-arrow-right me-2"></i>Continuar
                                </button>
                            </div>

                            <!-- Título CUPS -->
                            <div class="text-center mb-4">
                                <h4 class="text-muted">CUPS</h4>
                            </div>

                            <!-- Campo CUPS -->
                            <div class="mb-3">
                                <input type="text" 
                                       class="form-control form-control-lg text-center" 
                                       @bind="cups" 
                                       placeholder="Introduce el CUPS"
                                       style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                            </div>

                            <!-- Checkbox Consultar SIPS (solo superadmin) -->
                            @if (AuthService.EsSuperAdmin)
                            {
                                <div class="d-flex justify-content-center mb-5">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" 
                                               type="checkbox" 
                                               role="switch" 
                                               id="switchSips"
                                               checked="@consultarSips"
                                               @onchange="OnConsultarSipsChanged"
                                               disabled="@(string.IsNullOrWhiteSpace(cups))"
                                               style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                        <label class="form-check-label ms-2 fs-6" for="switchSips" style="cursor: pointer;">
                                            Consultar SIPS (autocompletar datos)
                                        </label>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-5"></div>
                            }

                            <!-- Compañía actual y Tarifa -->
                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Compañía actual</label>
                                    <select class="form-select form-select-lg" 
                                            @bind="companiaActual"
                                            style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                        <option value=""></option>
                                        @foreach (var compania in listadoCompanias)
                                        {
                                            <option value="@compania">@compania</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Tarifa</label>
                                    <select class="form-select form-select-lg" 
                                            @bind="tarifaActual"
                                            style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                        <option value=""></option>
                                        @foreach (var tarifa in listadoTarifas)
                                        {
                                            <option value="@tarifa">@tarifa</option>
                                        }
                                        @if (!string.IsNullOrEmpty(tarifaActual) && !listadoTarifas.Contains(tarifaActual))
                                        {
                                            <option value="@tarifaActual" selected>@tarifaActual</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Toggle Particular/Empresa -->
                            <div class="d-flex justify-content-center">
                                <div class="btn-group" role="group">
                                    <button type="button" 
                                            class="btn btn-lg px-5 @(tipoCliente == "Particular" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoCliente = "Particular"'>
                                        <i class="bi bi-house-door me-2"></i>Particular
                                    </button>
                                    <button type="button" 
                                            class="btn btn-lg px-5 @(tipoCliente == "Empresa" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoCliente = "Empresa"'>
                                        <i class="bi bi-building me-2"></i>Empresa
                                    </button>
                                </div>
                            </div>
                        }
                        else if (pasoActual == 2)
                        {
                            <!-- Botón de avance superior -->
                            <div class="d-flex justify-content-center mb-4">
                                <button class="btn btn-warning px-4" 
                                        @onclick="AvanzarPaso2">
                                    <i class="bi bi-arrow-right me-2"></i>Continuar
                                </button>
                            </div>

                            <!-- Título CUPS -->
                            <div class="text-center mb-4">
                                <h4 class="text-muted">CUPS</h4>
                            </div>

                            <!-- Campo CUPS validado -->
                            <div class="mb-5 position-relative">
                                <input type="text" 
                                       class="form-control form-control-lg text-center" 
                                       @bind="cups" 
                                       readonly
                                       style="border: 2px solid #28a745; border-radius: 10px; padding-right: 50px;" />
                                <i class="bi bi-check-circle-fill text-success position-absolute" 
                                   style="right: 20px; top: 50%; transform: translateY(-50%); font-size: 1.5rem;"></i>
                            </div>

                            <!-- Compañía actual y Tarifa -->
                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Compañía actual</label>
                                    <select class="form-select form-select-lg" 
                                            @bind="companiaActual"
                                            style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                        <option value=""></option>
                                        @foreach (var compania in listadoCompanias)
                                        {
                                            <option value="@compania">@compania</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Tarifa</label>
                                    <select class="form-select form-select-lg" 
                                            @bind="tarifaActual"
                                            style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                        <option value=""></option>
                                        @foreach (var tarifa in listadoTarifas)
                                        {
                                            <option value="@tarifa">@tarifa</option>
                                        }
                                        @if (!string.IsNullOrEmpty(tarifaActual) && !listadoTarifas.Contains(tarifaActual))
                                        {
                                            <option value="@tarifaActual" selected>@tarifaActual</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Toggle Particular/Empresa -->
                            <div class="d-flex justify-content-center">
                                <div class="btn-group" role="group">
                                    <button type="button" 
                                            class="btn btn-lg px-5 @(tipoCliente == "Particular" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoCliente = "Particular"'>
                                        <i class="bi bi-house-door me-2"></i>Particular
                                    </button>
                                    <button type="button" 
                                            class="btn btn-lg px-5 @(tipoCliente == "Empresa" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoCliente = "Empresa"'>
                                        <i class="bi bi-building me-2"></i>Empresa
                                    </button>
                                </div>
                            </div>
                        }
                        else if (pasoActual == 3)
                        {
                            <!-- Botones de navegación superiores -->
                            <div class="d-flex justify-content-center gap-3 mb-4">
                                <button class="btn btn-outline-warning px-4" 
                                        @onclick="RetrocederPaso">
                                    <i class="bi bi-arrow-left me-2"></i>Atrás
                                </button>
                                <button class="btn btn-warning px-4" 
                                        @onclick="AvanzarPaso3"
                                        disabled="@(!ValidarPaso3())">
                                    <i class="bi bi-arrow-right me-2"></i>Continuar
                                </button>
                            </div>

                            <!-- Título -->
                            <div class="text-center mb-4">
                                <h4 class="fw-bold">Datos del cliente</h4>
                            </div>

                            <!-- Nombre y Email -->
                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <input type="text" 
                                           class="form-control form-control-lg" 
                                           @bind="nombreCliente" 
                                           placeholder="Nombre completo"
                                           style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                </div>
                                <div class="col-md-6">
                                    <input type="email" 
                                           class="form-control form-control-lg" 
                                           @bind="emailCliente" 
                                           placeholder="Email"
                                           style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                </div>
                            </div>

                            <!-- Dirección -->
                            <div class="mb-4">
                                <input type="text" 
                                       class="form-control form-control-lg" 
                                       @bind="direccionCliente" 
                                       placeholder="Dirección completa"
                                       style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                            </div>

                            <!-- Switch: Misma dirección de correspondencia -->
                            <div class="d-flex align-items-center mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           role="switch" 
                                           id="switchDireccion"
                                           @bind="mismaDireccionCorrespondencia"
                                           style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    <label class="form-check-label ms-2 fs-5" for="switchDireccion" style="cursor: pointer;">
                                        Misma dirección de correspondencia
                                    </label>
                                </div>
                            </div>

                            <!-- Switch: Datos del consultor -->
                            <div class="d-flex align-items-center justify-content-center">
                                <label class="fs-5 fw-bold me-3">Datos del consultor</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           role="switch" 
                                           id="switchConsultor"
                                           @bind="mostrarDatosConsultor"
                                           style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                </div>
                            </div>

                            <!-- Campos del consultor (mostrar solo si el switch está activo) -->
                            @if (mostrarDatosConsultor)
                            {
                                <div class="mt-4">
                                    <div class="row g-4">
                                        <div class="col-md-4">
                                            <input type="text" 
                                                   class="form-control form-control-lg" 
                                                   @bind="nombreConsultor" 
                                                   placeholder="Nombre del consultor"
                                                   style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                        </div>
                                        <div class="col-md-4">
                                            <input type="tel" 
                                                   class="form-control form-control-lg" 
                                                   @bind="telefonoConsultor" 
                                                   placeholder="Teléfono"
                                                   style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                        </div>
                                        <div class="col-md-4">
                                            <input type="email" 
                                                   class="form-control form-control-lg" 
                                                   @bind="emailConsultor" 
                                                   placeholder="Email del consultor"
                                                   style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else if (pasoActual == 4)
                        {
                            <!-- Botones de navegación superiores -->
                            <div class="d-flex justify-content-center gap-3 mb-4">
                                <button class="btn btn-outline-warning px-4" 
                                        @onclick="RetrocederPaso">
                                    <i class="bi bi-arrow-left me-2"></i>Atrás
                                </button>
                                <button class="btn btn-warning px-4" 
                                        @onclick="AvanzarPaso4"
                                        disabled="@(!ValidarPaso4())">
                                    <i class="bi bi-arrow-right me-2"></i>Continuar
                                </button>
                            </div>

                            <!-- Título -->
                            <div class="text-center mb-5">
                                <h4 class="fw-bold">Consumo anual y facturación</h4>
                            </div>

                            <!-- Consumo anual -->
                            <div class="mb-5">
                                <label class="form-label text-muted fw-normal mb-3">Consumo anual (kWh)</label>
                                <input type="number" 
                                       class="form-control form-control-lg" 
                                       @bind="consumoAnual"
                                       step="0.01"
                                       min="0"
                                       placeholder="Ej: 3500"
                                       style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                            </div>

                            <!-- Tipo de facturación de potencia (tabs) -->
                            <div class="mb-5">
                                <label class="form-label text-muted fw-normal mb-3">Facturación de potencia</label>
                                <div class="btn-group w-100" role="group">
                                    <button type="button" 
                                            class="btn btn-lg @(tipoFacturacionPotencia == "Diaria" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoFacturacionPotencia = "Diaria"'>
                                        Diaria
                                    </button>
                                    <button type="button" 
                                            class="btn btn-lg @(tipoFacturacionPotencia == "Mensual" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoFacturacionPotencia = "Mensual"'>
                                        Mensual
                                    </button>
                                    <button type="button" 
                                            class="btn btn-lg @(tipoFacturacionPotencia == "Anual" ? "btn-warning" : "btn-outline-warning")"
                                            @onclick='() => tipoFacturacionPotencia = "Anual"'>
                                        Anual
                                    </button>
                                </div>
                            </div>

                            <!-- Fechas de facturación -->
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Inicio facturación</label>
                                    <input type="date" 
                                           class="form-control form-control-lg" 
                                           @bind="fechaInicioFacturacion"
                                           style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-normal">Fin facturación</label>
                                    <input type="date" 
                                           class="form-control form-control-lg" 
                                           @bind="fechaFinFacturacion"
                                           style="border: 2px solid #e0e0e0; border-radius: 10px;" />
                                </div>
                            </div>

                            <!-- Nota informativa -->
                            <div class="alert alert-info mt-4">
                                <small>
                                    <i class="bi bi-info-circle me-1"></i>
                                    Es importante indicar cómo está facturada la potencia y las fechas de facturación para que el cálculo sea real.
                                </small>
                            </div>
                        }
                        else if (pasoActual == 5)
                        {
                            <!-- Botones de navegación superiores -->
                            <div class="d-flex justify-content-center gap-3 mb-4">
                                <button class="btn btn-outline-warning px-4" 
                                        @onclick="RetrocederPaso">
                                    <i class="bi bi-arrow-left me-2"></i>Atrás
                                </button>
                                <button class="btn btn-warning px-4" 
                                        @onclick="AvanzarPaso5"
                                        disabled="@(!ValidarPaso5())">
                                    <i class="bi bi-arrow-right me-2"></i>Continuar
                                </button>
                            </div>

                            <!-- Título -->
                            <div class="text-center mb-5">
                                <h4 class="fw-bold">Potencia</h4>
                            </div>

                            <!-- Potencia Punta -->
                            <div class="row g-3 mb-4 align-items-center">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-normal">Punta</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="potenciaPunta"
                                               step="0.01"
                                               min="0"
                                               placeholder="9,2"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">kW</span>
                                    </div>
                                </div>
                                <div class="col-md-2 text-center">
                                    <label class="form-label text-muted fw-normal mb-0">Precio Punta</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="precioPotenciaPunta"
                                               step="0.0001"
                                               min="0"
                                               placeholder="0"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kW/día</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Potencia Valle -->
                            <div class="row g-3 mb-5 align-items-center">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-normal">Valle</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="potenciaValle"
                                               step="0.01"
                                               min="0"
                                               placeholder="9,2"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">kW</span>
                                    </div>
                                </div>
                                <div class="col-md-2 text-center">
                                    <label class="form-label text-muted fw-normal mb-0">Precio Valle</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="precioPotenciaValle"
                                               step="0.0001"
                                               min="0"
                                               placeholder="0"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kW/día</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Descuento -->
                            <div class="text-center mb-4">
                                <label class="form-label text-muted fw-normal">Descuento</label>
                            </div>
                            <div class="row justify-content-center mb-5">
                                <div class="col-md-6">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="descuentoPotencia"
                                               step="0.01"
                                               min="0"
                                               max="100"
                                               placeholder="0"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">%</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Switch: Optimizar potencias -->
                            <div class="d-flex align-items-center">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           role="switch" 
                                           id="switchOptimizar"
                                           @bind="optimizarPotencias"
                                           style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    <label class="form-check-label ms-2 fs-5" for="switchOptimizar" style="cursor: pointer;">
                                        Optimizar potencias
                                    </label>
                                </div>
                            </div>
                        }
                        else if (pasoActual == 6)
                        {
                            <!-- Botón de navegación superior (solo retroceso) -->
                            <div class="d-flex justify-content-center gap-3 mb-4">
                                <button class="btn btn-outline-warning px-4" 
                                        @onclick="RetrocederPaso">
                                    <i class="bi bi-arrow-left me-2"></i>Atrás
                                </button>
                            </div>

                            <!-- Selector de zona -->
                            <div class="mb-4">
                                <select class="form-select form-select-lg" 
                                        @bind="zona"
                                        style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                    <option value="Península">Península</option>
                                    <option value="Baleares">Baleares</option>
                                    <option value="Canarias">Canarias</option>
                                    <option value="Ceuta">Ceuta</option>
                                    <option value="Melilla">Melilla</option>
                                </select>
                            </div>

                            <!-- IVA e Impuesto electricidad -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="row g-2 align-items-center">
                                        <div class="col-8">
                                            <select class="form-select" 
                                                    @bind="tipoIVA"
                                                    @bind:after="OnTipoIVAChanged"
                                                    style="border: 2px solid #e0e0e0; border-radius: 10px;">
                                                <option value="General">I.V.A.</option>
                                                <option value="Reducido">I.V.A. Reducido</option>
                                                <option value="Superreducido">I.V.A. Superreducido</option>
                                            </select>
                                        </div>
                                        <div class="col-4">
                                            <div class="input-group">
                                                <input type="number" 
                                                       class="form-control" 
                                                       @bind="porcentajeIVA"
                                                       step="0.01"
                                                       min="0"
                                                       style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                                <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">%</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row g-2 align-items-center">
                                        <div class="col-8">
                                            <label class="form-label mb-0">Impuesto electricidad</label>
                                        </div>
                                        <div class="col-4">
                                            <div class="input-group">
                                                <input type="number" 
                                                       class="form-control" 
                                                       @bind="porcentajeImpuestoElectricidad"
                                                       step="0.01"
                                                       min="0"
                                                       style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                                <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">%</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Otros conceptos (sin I.V.A.) -->
                            <div class="mb-4">
                                <h6 class="text-center mb-3">Otros conceptos (sin I.V.A.)</h6>
                                
                                <!-- Alquiler del contador -->
                                <div class="row g-3 mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <label class="form-label mb-0">Alquiler del contador</label>
                                    </div>
                                    <div class="col-md-4">
                                        <input type="text" 
                                               class="form-control text-muted" 
                                               value="(Cálculo opcional)"
                                               readonly
                                               style="border: 2px solid #e0e0e0; border-radius: 10px; background-color: #f8f9fa;" />
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-primary w-100" disabled>
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="input-group">
                                            <input type="number" 
                                                   class="form-control" 
                                                   @bind="alquilerContador"
                                                   step="0.01"
                                                   min="0"
                                                   placeholder="0"
                                                   style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                            <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Selector de conceptos adicionales -->
                                <div class="mb-3">
                                    <label class="form-label text-muted">Seleccione los conceptos a añadir</label>
                                    @foreach (var concepto in conceptosDisponibles)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" 
                                                   type="checkbox" 
                                                   id="@concepto.Replace(" ", "")"
                                                   checked="@conceptosSeleccionados.Contains(concepto)"
                                                   @onchange="@(e => OnConceptoChanged(concepto, e))">
                                            <label class="form-check-label" for="@concepto.Replace(" ", "")">
                                                @concepto
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Ahorro mínimo -->
                            <div class="mb-4">
                                <div class="row align-items-center">
                                    <div class="col-md-6">
                                        <label class="form-label mb-0">Ahorro mínimo</label>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="input-group">
                                            <input type="number" 
                                                   class="form-control" 
                                                   @bind="ahorroMinimo"
                                                   step="0.01"
                                                   min="0"
                                                   placeholder="5"
                                                   style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                            <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">%</span>
                                        </div>
                                    </div>
                                </div>
                                <small class="text-muted">Solo se mostrarán ofertas que ofrezcan, como mínimo, este porcentaje de ahorro.</small>
                            </div>

                            <!-- Mostrar ahorro en -->
                            <div class="mb-4">
                                <div class="row align-items-center">
                                    <div class="col-md-6">
                                        <label class="form-label mb-0 fw-bold">Mostrar ahorro en</label>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex gap-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" 
                                                       type="checkbox" 
                                                       role="switch" 
                                                       id="switchEuros"
                                                       @bind="mostrarAhorroEuros"
                                                       style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                                                <label class="form-check-label ms-1" for="switchEuros" style="cursor: pointer;">
                                                    Euros (€)
                                                </label>
                                            </div>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" 
                                                       type="checkbox" 
                                                       role="switch" 
                                                       id="switchPorcentaje"
                                                       @bind="mostrarAhorroPorcentaje"
                                                       style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                                                <label class="form-check-label ms-1" for="switchPorcentaje" style="cursor: pointer;">
                                                    Porcentaje (%)
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- CO consumo y CO potencia -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="row align-items-center">
                                        <div class="col-6">
                                            <label class="form-label mb-0">CO consumo</label>
                                        </div>
                                        <div class="col-6">
                                            <div class="input-group">
                                                <input type="number" 
                                                       class="form-control" 
                                                       @bind="coConsumo"
                                                       step="0.01"
                                                       min="0"
                                                       placeholder="0"
                                                       style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                                <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/MWh</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row align-items-center">
                                        <div class="col-6">
                                            <label class="form-label mb-0">CO potencia</label>
                                        </div>
                                        <div class="col-6">
                                            <div class="input-group">
                                                <input type="number" 
                                                       class="form-control" 
                                                       @bind="coPotencia"
                                                       step="0.01"
                                                       min="0"
                                                       placeholder="0"
                                                       style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                                <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kW/mes</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Nota final -->
                            <div class="alert alert-warning mb-3">
                                <small>
                                    <strong>Para ver productos personalizables introduce un coste operativo</strong>
                                </small>
                            </div>

                            <!-- Botón Ver ofertas -->
                            <div class="text-center mb-3">
                                <button class="btn btn-warning btn-lg w-100 py-3" 
                                        @onclick="VerOfertas"
                                        style="font-size: 1.2rem; font-weight: bold;">
                                    <i class="bi bi-search me-2"></i>Ver ofertas
                                </button>
                            </div>

                            <!-- Aviso legal -->
                            <div class="alert alert-warning d-flex align-items-center mb-0">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <small>El precio mostrado en las simulaciones no es vinculante.</small>
                            </div>
                        }
                        else if (pasoActual == 7)
                        {
                            <!-- Botones de navegación superiores -->
                            <div class="d-flex justify-content-center gap-3 mb-4">
                                <button class="btn btn-outline-warning px-4" 
                                        @onclick="RetrocederPaso">
                                    <i class="bi bi-arrow-left me-2"></i>Atrás
                                </button>
                                <button class="btn btn-warning px-4" 
                                        @onclick="CalcularComparativa"
                                        disabled="@(!ValidarPaso7())">
                                    <i class="bi bi-check2 me-2"></i>Calcular
                                </button>
                            </div>

                            <!-- Título -->
                            <div class="text-center mb-5">
                                <h4 class="fw-bold">Consumo</h4>
                            </div>

                            <!-- Consumo Punta -->
                            <div class="row g-3 mb-4 align-items-center">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-normal">Punta</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="consumoPunta"
                                               step="0.01"
                                               min="0"
                                               placeholder="33.11"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">kWh</span>
                                    </div>
                                </div>
                                <div class="col-md-2 text-center">
                                    <label class="form-label text-muted fw-normal mb-0">Precio Punta</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="precioConsumoPunta"
                                               step="0.000001"
                                               min="0"
                                               placeholder="0.302117"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kWh</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Consumo Llano -->
                            <div class="row g-3 mb-4 align-items-center">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-normal">Llano</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="consumoLlano"
                                               step="0.01"
                                               min="0"
                                               placeholder="29.46"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">kWh</span>
                                    </div>
                                </div>
                                <div class="col-md-2 text-center">
                                    <label class="form-label text-muted fw-normal mb-0">Precio Llano</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="precioConsumoLlano"
                                               step="0.000001"
                                               min="0"
                                               placeholder="0.198437"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kWh</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Consumo Valle -->
                            <div class="row g-3 mb-5 align-items-center">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-normal">Valle</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="consumoValle"
                                               step="0.01"
                                               min="0"
                                               placeholder="42.88"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">kWh</span>
                                    </div>
                                </div>
                                <div class="col-md-2 text-center">
                                    <label class="form-label text-muted fw-normal mb-0">Precio Valle</label>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="precioConsumoValle"
                                               step="0.000001"
                                               min="0"
                                               placeholder="0.165362"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">€/kWh</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Descuento -->
                            <div class="text-center mb-4">
                                <label class="form-label text-muted fw-normal">Descuento</label>
                            </div>
                            <div class="row justify-content-center">
                                <div class="col-md-6">
                                    <div class="input-group input-group-lg">
                                        <input type="number" 
                                               class="form-control" 
                                               @bind="descuentoConsumo"
                                               step="0.01"
                                               min="0"
                                               max="100"
                                               placeholder="0"
                                               style="border: 2px solid #e0e0e0; border-radius: 10px 0 0 10px; text-align: right;" />
                                        <span class="input-group-text" style="border: 2px solid #e0e0e0; border-left: none; border-radius: 0 10px 10px 0; background-color: #f8f9fa;">%</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (resultadosCalculados)
            {
                <!-- Resultados de la comparativa -->
                <div class="card shadow-sm" id="resultados-comparativa">
                    <div class="card-body p-4">
                        <!-- Pestañas: Coste factura / Filtro comercial -->
                        <ul class="nav nav-tabs mb-4">
                            <li class="nav-item">
                                <button class="nav-link @(vistaActual == "coste" ? "active" : "")" 
                                        @onclick='() => vistaActual = "coste"'>
                                    Coste factura
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(vistaActual == "filtro" ? "active" : "")" 
                                        @onclick='() => vistaActual = "filtro"'>
                                    Filtro comercial
                                </button>
                            </li>
                        </ul>

                        @if (vistaActual == "coste")
                        {
                            <!-- Selector de presentación -->
                            <div class="mb-4">
                                <div class="btn-group" role="group">
                                    <button type="button" 
                                            class="btn @(presentacion == "simple" ? "btn-success" : "btn-outline-success")"
                                            @onclick='() => presentacion = "simple"'>
                                        Presentación simple
                                    </button>
                                    <button type="button" 
                                            class="btn @(presentacion == "detallada" ? "btn-success" : "btn-outline-success")"
                                            @onclick='() => presentacion = "detallada"'>
                                        Presentación detallada
                                    </button>
                                </div>
                            </div>

                            @if (comercializadoras.Any())
                            {
                                @if (presentacion == "simple")
                                {
                                    @* PRESENTACIÓN SIMPLE *@
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th>#</th>
                                                    <th>Compañía</th>
                                                    <th>Descripción</th>
                                                    <th class="text-end">Coste</th>
                                                    <th class="text-end">Ahorro</th>
                                                    <th class="text-end">Ahorro anual</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    int posicion = 1;
                                                }
                                                @foreach (var oferta in comercializadoras)
                                                {
                                                    var esLaMejor = posicion == 1;
                                                    <tr class="@(esLaMejor ? "table-light" : "")" style="@(esLaMejor ? "background-color: #f0f0f0;" : "")">
                                                        <td>
                                                            <input class="form-check-input" 
                                                                   type="checkbox" 
                                                                   checked="@ofertasSeleccionadas.Contains(posicion)"
                                                                   @onchange="@(e => OnOfertaSeleccionada(posicion, e))" />
                                                        </td>
                                                        <td>
                                                            <span class="fw-bold">#@posicion</span>
                                                        </td>
                                                        <td>
                                                            @{
                                                                var logoUrl = ObtenerLogoComercializadora(oferta.Empresa);
                                                                if (!string.IsNullOrEmpty(logoUrl))
                                                                {
                                                                    <img src="@logoUrl" alt="@oferta.Empresa" 
                                                                         style="max-width: 100px; max-height: 40px; object-fit: contain;" 
                                                                         title="@oferta.Empresa" />
                                                                }
                                                                else
                                                                {
                                                                    <strong>@oferta.Empresa</strong>
                                                                }
                                                            }
                                                        </td>
                                                        <td>@oferta.NombreTarifa</td>
                                                        <td class="text-end">
                                                            <strong>@oferta.CosteMensual.ToString("N2") €</strong>
                                                        </td>
                                                        <td class="text-end">
                                                            @if (oferta.AhorroMensual > 0)
                                                            {
                                                                @if (mostrarAhorroEuros)
                                                                {
                                                                    <div class="text-success">
                                                                        <strong>@oferta.AhorroMensual.ToString("N2") €</strong>
                                                                    </div>
                                                                }
                                                                @if (mostrarAhorroPorcentaje)
                                                                {
                                                                    <div class="text-success" style="color: #e91e63 !important;">
                                                                        <strong>@oferta.PorcentajeAhorro.ToString("N0")%</strong>
                                                                    </div>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                        <td class="text-end">
                                                            @if (oferta.AhorroAnual > 0)
                                                            {
                                                                <strong class="text-warning">@oferta.AhorroAnual.ToString("N2") €</strong>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                    posicion++;
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    @* PRESENTACIÓN DETALLADA *@
                                    @foreach(var item in comercializadoras.Select((oferta, index) => new { oferta, posicionDetallada = index + 1 }))
                                    {
                                        var esLaMejor = item.posicionDetallada == 1;
                                        var oferta = item.oferta;
                                        var posicionDetallada = item.posicionDetallada;
                                        <div class="card mb-3 @(esLaMejor ? "border-success" : "")" style="@(esLaMejor ? "background-color: #f0fff0;" : "")">
                                            <div class="card-body">
                                                <div class="row align-items-center mb-3">
                                                    <div class="col-auto">
                                                        <input class="form-check-input" 
                                                               type="checkbox" 
                                                               checked="@ofertasSeleccionadas.Contains(posicionDetallada)"
                                                               @onchange="@(e => OnOfertaSeleccionada(posicionDetallada, e))"
                                                               style="width: 20px; height: 20px;" />
                                                    </div>
                                                    <div class="col">
                                                        <div class="d-flex align-items-center">
                                                            <span class="badge bg-primary me-2" style="font-size: 1rem;">#@posicionDetallada</span>
                                                            @{
                                                                var logoUrl = ObtenerLogoComercializadora(oferta.Empresa);
                                                                if (!string.IsNullOrEmpty(logoUrl))
                                                                {
                                                                    <img src="@logoUrl" alt="@oferta.Empresa" 
                                                                         class="me-3"
                                                                         style="max-width: 120px; max-height: 50px; object-fit: contain;" 
                                                                         title="@oferta.Empresa" />
                                                                }
                                                                else
                                                                {
                                                                    <h5 class="mb-0 me-3">@oferta.Empresa</h5>
                                                                }
                                                            }
                                                            <span class="text-muted">@oferta.NombreTarifa</span>
                                                            @if (esLaMejor)
                                                            {
                                                                <span class="badge bg-success ms-3">MEJOR OFERTA</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>

                                                <hr />

                                                <div class="row g-4">
                                                    @* Desglose de costes *@
                                                    <div class="col-md-8">
                                                        <h6 class="text-muted mb-3">DESGLOSE DE COSTES MENSUALES</h6>
                                                        <div class="row g-3">
                                                            <div class="col-4">
                                                                <div class="p-3 border rounded text-center">
                                                                    <div class="text-muted small">Término fijo</div>
                                                                    <div class="fw-bold fs-5 text-primary">@oferta.CosteTerminoFijo.ToString("N2") €</div>
                                                                </div>
                                                            </div>
                                                            <div class="col-4">
                                                                <div class="p-3 border rounded text-center">
                                                                    <div class="text-muted small">Potencia</div>
                                                                    <div class="fw-bold fs-5 text-info">@oferta.CostePotencia.ToString("N2") €</div>
                                                                </div>
                                                            </div>
                                                            <div class="col-4">
                                                                <div class="p-3 border rounded text-center">
                                                                    <div class="text-muted small">Energía</div>
                                                                    <div class="fw-bold fs-5 text-warning">@oferta.CosteEnergia.ToString("N2") €</div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @* Total y ahorro *@
                                                    <div class="col-md-4">
                                                        <div class="h-100 d-flex flex-column justify-content-between">
                                                            <div class="p-3 bg-light rounded text-center mb-2">
                                                                <div class="text-muted small mb-1">COSTE TOTAL MENSUAL</div>
                                                                <div class="fw-bold" style="font-size: 1.8rem; color: #0d6efd;">
                                                                    @oferta.CosteMensual.ToString("N2") €
                                                                </div>
                                                            </div>
                                                            @if (oferta.AhorroMensual > 0)
                                                            {
                                                                <div class="p-3 bg-success bg-opacity-10 border border-success rounded text-center">
                                                                    <div class="text-success small mb-1">AHORRO</div>
                                                                    <div class="fw-bold fs-5 text-success">
                                                                        @oferta.AhorroMensual.ToString("N2") € / mes
                                                                    </div>
                                                                    <div class="fw-bold text-success">
                                                                        (@oferta.PorcentajeAhorro.ToString("N0")%)
                                                                    </div>
                                                                    <div class="small text-muted mt-1">
                                                                        @oferta.AhorroAnual.ToString("N2") € / año
                                                                    </div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="p-3 bg-light rounded text-center">
                                                                    <div class="text-muted small">Sin ahorro respecto a tarifa actual</div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
