                                <hr class="my-4" />
                                <h6 class="text-success mb-3"><i class="bi bi-sun me-2"></i>Energía Solar y Batería</h6>
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Precio Excedentes</label>
                                        <InputText class="form-control" @bind-Value="tarifaActual.Excedentes" placeholder="Ej: 0.07" />
