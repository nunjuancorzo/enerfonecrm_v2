                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Batería Virtual</label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.BateriaVirtual">
                                            <option value="">-- Seleccionar --</option>
