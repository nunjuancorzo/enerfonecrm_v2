                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-12">
                                        <strong class="d-block mb-2">Precios de Potencia (€/kW/día)</strong>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 1 (Punta)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioPotenciaP1" step="0.000001" />
                                            <span class="input-group-text">€/kW/día</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.105000</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 2 (Llano/Valle)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioPotenciaP2" step="0.000001" />
                                            <span class="input-group-text">€/kW/día</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.046000</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 3 (Valle)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioPotenciaP3" step="0.000001" />
                                            <span class="input-group-text">€/kW/día</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.003400</small>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-12">
                                        <strong class="d-block mb-2">Precios de Energía (€/kWh)</strong>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 1 (Punta)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioEnergiaP1" step="0.000001" />
                                            <span class="input-group-text">€/kWh</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.168000</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 2 (Llano)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioEnergiaP2" step="0.000001" />
                                            <span class="input-group-text">€/kWh</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.098000</small>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodo 3 (Valle)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.PrecioEnergiaP3" step="0.000001" />
                                            <span class="input-group-text">€/kWh</span>
                                        </div>
                                        <small class="text-muted">Ej: 0.065000</small>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }

        <!-- Modal Confirmar Eliminación -->
        @if (mostrarModalEliminar)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar Eliminación
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalEliminar = false"></button>
                        </div>
                        <div class="modal-body p-4">
                            <p class="mb-3">¿Estás seguro de que deseas eliminar esta tarifa?</p>
                            <div class="alert alert-warning mb-0">
                                <strong><i class="bi bi-lightning-charge-fill me-2"></i>@tarifaAEliminar?.Empresa - @tarifaAEliminar?.Nombre</strong>
                                <br />
                                <small>Esta acción no se puede deshacer</small>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-secondary" @onclick="() => mostrarModalEliminar = false">
                                <i class="bi bi-x-circle me-2"></i>Cancelar
                            </button>
                            <button type="button" class="btn btn-danger" @onclick="EliminarTarifa" disabled="@eliminando">
                                @if (eliminando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Eliminando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-trash me-2"></i>
                                    <span>Eliminar Tarifa</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private bool cargandoSesion = true;
    private bool cargando = true;
    private bool guardando = false;
    private bool eliminando = false;
    private bool mostrarModal = false;
    private bool mostrarModalEliminar = false;
    private bool modoEdicion = false;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    private List<TarifaEnergia> tarifas = new();
    private List<TarifaEnergia> tarifasFiltradas = new();
    private List<Comercializadora> comercializadoras = new();
    private TarifaEnergia tarifaActual = new();
    private TarifaEnergia? tarifaAEliminar;
    
    // Ordenamiento
    private string columnaOrden = "Empresa";
    private bool ordenAscendente = true;
    
    // Paginación
    private int paginaActual = 1;
    private int elementosPorPagina = 10;
    private int totalElementos = 0;
    private int totalPaginas = 0;

    // Filtros
    private HashSet<string> comercializadorasSeleccionadas = new();
    private HashSet<string> tiposClienteSeleccionados = new();
    private HashSet<string> peajesLuzSeleccionados = new();
    private HashSet<string> peajesGasSeleccionados = new();
    private string textoBusqueda = string.Empty;
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    
    private List<string> tiposClienteDisponibles = new() { "Residencial", "Pyme", "Autonomo" };
    private List<string> peajesLuzDisponibles = new() { "2.0", "3.0", "6.1", "6.2" };
    private List<string> peajesGasDisponibles = new() { "RL1", "RL2", "RL3", "RL4", "RL5", "RL6" };
    private List<TarifaEnergia> tarifasParaPaginar = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.CargarSesionAsync();

            if (!AuthService.EstaAutenticado)
            {
                Navigation.NavigateTo("/login", false);
                return;
            }

            cargandoSesion = false;
            await CargarComercializadoras();
            await CargarTarifas();
            StateHasChanged();
        }
    }

    private async Task CargarComercializadoras()
    {
        try
        {
            comercializadoras = await ComercializadoraService.ObtenerActivasAsync();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar comercializadoras: {ex.Message}";
        }
    }

    private async Task CargarTarifas()
    {
        cargando = true;
        try
        {
            tarifas = await TarifaService.ObtenerTodasAsync();
            AplicarFiltros();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar tarifas: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private void OrdenarPor(string columna)
    {
        paginaActual = 1;
        if (columnaOrden == columna)
        {
            ordenAscendente = !ordenAscendente;
        }
        else
        {
            columnaOrden = columna;
            ordenAscendente = true;
        }
        
        AplicarOrdenamiento();
    }

    private void AplicarOrdenamiento()
    {
        var tarifasOrdenadas = columnaOrden switch
        {
            "Empresa" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Empresa).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Empresa).ToList(),
            "Tipo" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Tipo).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Tipo).ToList(),
            "Nombre" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Nombre).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Nombre).ToList(),
            "Comision" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Comision).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Comision).ToList(),
            _ => tarifasParaPaginar
        };
        
        totalElementos = tarifasOrdenadas.Count;
        totalPaginas = (int)Math.Ceiling((double)totalElementos / elementosPorPagina);
        
        tarifasFiltradas = tarifasOrdenadas
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina)
            .ToList();
        
        StateHasChanged();
    }
    
    private void AplicarFiltros()
    {
        var listaTemp = tarifas.ToList();

        // Filtrar por comercializadoras
        if (comercializadorasSeleccionadas.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                t.Empresa != null && 
                comercializadorasSeleccionadas.Contains(t.Empresa)
            ).ToList();
        }

        // Filtrar por tipos de cliente
        if (tiposClienteSeleccionados.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                t.TipoCliente != null && 
                tiposClienteSeleccionados.Contains(t.TipoCliente)
            ).ToList();
        }

        // Filtrar por peajes luz
        if (peajesLuzSeleccionados.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                t.Peaje != null && 
                peajesLuzSeleccionados.Contains(t.Peaje)
            ).ToList();
        }

        // Filtrar por peajes gas
        if (peajesGasSeleccionados.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                t.PeajeGas != null && 
                peajesGasSeleccionados.Contains(t.PeajeGas)
            ).ToList();
        }

        // Filtrar por búsqueda de texto (nombre)
        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            listaTemp = listaTemp.Where(t =>
                (t.Nombre != null && t.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (t.Empresa != null && t.Empresa.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (t.Tipo != null && t.Tipo.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase))
            ).ToList();
        }

        // Filtrar por rango de fechas
        if (filtroFechaDesde.HasValue)
        {
            listaTemp = listaTemp.Where(t => 
                t.FechaCarga.HasValue && 
                t.FechaCarga.Value.Date >= filtroFechaDesde.Value.Date
            ).ToList();
        }

        if (filtroFechaHasta.HasValue)
        {
            listaTemp = listaTemp.Where(t => 
                t.FechaCarga.HasValue && 
                t.FechaCarga.Value.Date <= filtroFechaHasta.Value.Date
            ).ToList();
        }

        tarifasParaPaginar = listaTemp;
        paginaActual = 1;
        AplicarOrdenamiento();
    }

    private void LimpiarFiltros()
    {
        comercializadorasSeleccionadas.Clear();
        tiposClienteSeleccionados.Clear();
        peajesLuzSeleccionados.Clear();
        peajesGasSeleccionados.Clear();
        textoBusqueda = string.Empty;
        filtroFechaDesde = null;
        filtroFechaHasta = null;
        AplicarFiltros();
    }

    private void ToggleComercializadora(string comercializadora)
    {
        if (comercializadorasSeleccionadas.Contains(comercializadora))
        {
            comercializadorasSeleccionadas.Remove(comercializadora);
        }
        else
        {
            comercializadorasSeleccionadas.Add(comercializadora);
        }
    }

    private void SeleccionarTodasComercializadoras()
    {
        comercializadorasSeleccionadas.Clear();
    }

    private void ToggleTipoCliente(string tipoCliente)
    {
        if (tiposClienteSeleccionados.Contains(tipoCliente))
        {
