@page "/tarifas/energia"
@using EnerfoneCRM.Models
@using EnerfoneCRM.Services
@rendermode InteractiveServer
@inject TarifaEnergiaService TarifaService
@inject ComercializadoraService ComercializadoraService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Enerfone CRM</PageTitle>

@if (cargandoSesion)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    @if (!AuthService.EstaAutenticado)
    {
        <div class="alert alert-warning m-4">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No tienes acceso a esta página. Por favor, inicia sesión.
        </div>
    }
    else if (!AuthService.PuedeGestionarTarifas)
    {
        <div class="alert alert-danger m-4">
            <i class="bi bi-shield-exclamation me-2"></i>
            No tienes permisos para acceder a esta página. Solo usuarios autorizados pueden gestionar tarifas.
        </div>
    }
    else
    {
        <div class="container-fluid p-4">
            <div class="row mb-4">
                <div class="col-md-12">
                    <h2 class="mb-0">
                        <i class="bi bi-lightning-charge-fill me-2 text-warning"></i>
                        Gestión de Tarifas de Energía
                    </h2>
                    <p class="text-muted">Administra las tarifas de electricidad y gas</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(mensajeExito))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@mensajeExito
                    <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@mensajeError
                    <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                </div>
            }

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filtros</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Comercializadora</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownComercializadora" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (comercializadorasSeleccionadas.Count == 0)
                                    {
                                        <span>Todas</span>
                                    }
                                    else if (comercializadorasSeleccionadas.Count == 1)
                                    {
                                        <span>@comercializadorasSeleccionadas.First()</span>
                                    }
                                    else
                                    {
                                        <span>@comercializadorasSeleccionadas.Count seleccionadas</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownComercializadora" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="comercializadoraTodas" @onchange="SeleccionarTodasComercializadoras" checked="@(comercializadorasSeleccionadas.Count == 0)">
                                            <label class="form-check-label w-100" for="comercializadoraTodas" style="cursor: pointer;">
                                                <small><strong>Todas</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var comercializadora in comercializadoras)
                                    {
                                        var comId = $"com_{comercializadora.Nombre.Replace(" ", "_")}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@comId" 
                                                       checked="@comercializadorasSeleccionadas.Contains(comercializadora.Nombre)"
                                                       @onchange="() => ToggleComercializadora(comercializadora.Nombre)">
                                                <label class="form-check-label w-100" for="@comId" style="cursor: pointer;">
                                                    <small>@comercializadora.Nombre</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Tipo Cliente</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownTipoCliente" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (tiposClienteSeleccionados.Count == 0)
                                    {
                                        <span>Todos</span>
                                    }
                                    else if (tiposClienteSeleccionados.Count == 1)
                                    {
                                        <span>@tiposClienteSeleccionados.First()</span>
                                    }
                                    else
                                    {
                                        <span>@tiposClienteSeleccionados.Count seleccionados</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownTipoCliente" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="tipoClienteTodos" @onchange="SeleccionarTodosTiposCliente" checked="@(tiposClienteSeleccionados.Count == 0)">
                                            <label class="form-check-label w-100" for="tipoClienteTodos" style="cursor: pointer;">
                                                <small><strong>Todos</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var tipoCliente in tiposClienteDisponibles)
                                    {
                                        var tcId = $"tc_{tipoCliente.Replace(" ", "_")}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@tcId" 
                                                       checked="@tiposClienteSeleccionados.Contains(tipoCliente)"
                                                       @onchange="() => ToggleTipoCliente(tipoCliente)">
                                                <label class="form-check-label w-100" for="@tcId" style="cursor: pointer;">
                                                    <small>@tipoCliente</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Peaje Luz</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownPeajeLuz" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (peajesLuzSeleccionados.Count == 0)
                                    {
                                        <span>Todos</span>
                                    }
                                    else if (peajesLuzSeleccionados.Count == 1)
                                    {
                                        <span>@peajesLuzSeleccionados.First()</span>
                                    }
                                    else
                                    {
                                        <span>@peajesLuzSeleccionados.Count seleccionados</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownPeajeLuz" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="peajeLuzTodos" @onchange="SeleccionarTodosPeajesLuz" checked="@(peajesLuzSeleccionados.Count == 0)">
                                            <label class="form-check-label w-100" for="peajeLuzTodos" style="cursor: pointer;">
                                                <small><strong>Todos</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var peajeLuz in peajesLuzDisponibles)
                                    {
                                        var plId = $"pl_{peajeLuz.Replace(".", "_")}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@plId" 
                                                       checked="@peajesLuzSeleccionados.Contains(peajeLuz)"
                                                       @onchange="() => TogglePeajeLuz(peajeLuz)">
                                                <label class="form-check-label w-100" for="@plId" style="cursor: pointer;">
                                                    <small>@peajeLuz</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Peaje Gas</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownPeajeGas" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (peajesGasSeleccionados.Count == 0)
                                    {
                                        <span>Todos</span>
                                    }
                                    else if (peajesGasSeleccionados.Count == 1)
                                    {
                                        <span>@peajesGasSeleccionados.First()</span>
                                    }
                                    else
                                    {
                                        <span>@peajesGasSeleccionados.Count seleccionados</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownPeajeGas" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="peajeGasTodos" @onchange="SeleccionarTodosPeajesGas" checked="@(peajesGasSeleccionados.Count == 0)">
                                            <label class="form-check-label w-100" for="peajeGasTodos" style="cursor: pointer;">
                                                <small><strong>Todos</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var peajeGas in peajesGasDisponibles)
                                    {
                                        var pgId = $"pg_{peajeGas}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@pgId" 
                                                       checked="@peajesGasSeleccionados.Contains(peajeGas)"
                                                       @onchange="() => TogglePeajeGas(peajeGas)">
                                                <label class="form-check-label w-100" for="@pgId" style="cursor: pointer;">
                                                    <small>@peajeGas</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fecha Desde</label>
                            <input type="date" @bind="filtroFechaDesde" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Fecha Hasta</label>
                            <input type="date" @bind="filtroFechaHasta" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Buscar</label>
                            <input type="text" @bind="textoBusqueda" class="form-control" placeholder="Nombre, Empresa, Tipo..." />
                        </div>
                        <div class="col-md-2 d-flex align-items-end gap-2">
                            <button class="btn btn-primary flex-grow-1" @onclick="AplicarFiltros">
                                <i class="bi bi-search me-1"></i>Filtrar
                            </button>
                            <button class="btn btn-secondary" @onclick="LimpiarFiltros">
                                <i class="bi bi-x-circle me-1"></i>Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Listado de Tarifas</h5>
                    <button class="btn btn-primary" @onclick="MostrarModalCrear">
                        <i class="bi bi-plus-circle me-2"></i>Nueva Tarifa
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (cargando)
                    {
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando tarifas...</span>
                            </div>
                            <p class="mt-3 text-muted">Cargando tarifas...</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Empresa")'>
                                            Empresa
                                            @if (columnaOrden == "Empresa")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Tipo")'>
                                            Tipo
                                            @if (columnaOrden == "Tipo")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Nombre")'>
                                            Nombre
                                            @if (columnaOrden == "Nombre")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>Tipo Cliente</th>
                                        <th>Peaje Luz</th>
                                        <th>Peaje Gas</th>
                                        <th>P1</th>
                                        <th>E1</th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Comision")'>
                                            Comisión
                                            @if (columnaOrden == "Comision")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>Permanencia</th>
                                        <th>Batería</th>
                                        <th>Estado</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (tarifas == null || !tarifas.Any())
                                    {
                                        <tr>
                                            <td colspan="13" class="text-center text-muted py-4">
                                                <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                                                <p class="mb-0 mt-2">No hay tarifas registradas</p>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var tarifa in tarifasFiltradas)
                                        {
                                            <tr>
                                                <td><strong>@tarifa.Empresa</strong></td>
                                                <td><span class="badge @ObtenerColorTipo(tarifa.Tipo)">@tarifa.Tipo</span></td>
                                                <td>@tarifa.Nombre</td>
                                                <td><small>@(tarifa.TipoCliente ?? "-")</small></td>
                                                <td><small>@(tarifa.Peaje ?? "-")</small></td>
                                                <td><small>@(tarifa.PeajeGas ?? "-")</small></td>
                                                <td><small>@(tarifa.Potencia1 ?? "-")</small></td>
                                                <td><small>@(tarifa.Energia1 ?? "-")</small></td>
                                                <td><span class="badge bg-success">@tarifa.Comision.ToString("N2")%</span></td>
                                                <td><small>@(tarifa.Permanencia ?? "-")</small></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(tarifa.BateriaVirtual) && tarifa.BateriaVirtual == "SI")
                                                    {
                                                        <i class="bi bi-battery-charging text-success" title="Batería Virtual"></i>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (tarifa.Activa)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Activa</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactiva</span>
                                                    }
                                                </td>
                                                <td class="text-end" style="white-space: nowrap;">
                                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => MostrarModalEditar(tarifa)" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-info me-1" @onclick="() => MostrarModalDuplicar(tarifa)" title="Duplicar">
                                                        <i class="bi bi-files"></i>
                                                    </button>
                                                    @if (tarifa.Activa)
                                                    {
                                                        <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => CambiarEstadoTarifa(tarifa)" title="Desactivar">
                                                            <i class="bi bi-toggle-on"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => CambiarEstadoTarifa(tarifa)" title="Activar">
                                                            <i class="bi bi-toggle-off"></i>
                                                        </button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(tarifa)" title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Paginación -->
                        @if (tarifas != null && tarifas.Any() && totalPaginas > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-muted">
                                        Mostrando @((paginaActual - 1) * elementosPorPagina + 1) - @(Math.Min(paginaActual * elementosPorPagina, totalElementos)) de @totalElementos tarifas
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="text-muted">Mostrar:</small>
                                        <select class="form-select form-select-sm" style="width: auto;" @onchange="CambiarElementosPorPaginaEvento">
                                            <option value="10" selected="@(elementosPorPagina == 10)">10</option>
                                            <option value="25" selected="@(elementosPorPagina == 25)">25</option>
                                            <option value="50" selected="@(elementosPorPagina == 50)">50</option>
                                        </select>
                                    </div>
                                </div>
                                <nav>
                                    <ul class="pagination mb-0">
                                        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(1)" disabled="@(paginaActual == 1)">
                                                <i class="bi bi-chevron-double-left"></i>
                                            </button>
                                        </li>
                                        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)" disabled="@(paginaActual == 1)">
                                                <i class="bi bi-chevron-left"></i>
                                            </button>
                                        </li>
                                        @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
                                        {
                                            var pagina = i;
                                            <li class="page-item @(paginaActual == pagina ? "active" : "")">
                                                <button class="page-link" @onclick="() => CambiarPagina(pagina)">@pagina</button>
                                            </li>
                                        }
                                        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)" disabled="@(paginaActual == totalPaginas)">
                                                <i class="bi bi-chevron-right"></i>
                                            </button>
                                        </li>
                                        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(totalPaginas)" disabled="@(paginaActual == totalPaginas)">
                                                <i class="bi bi-chevron-double-right"></i>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Modal Crear/Editar -->
        @if (mostrarModal)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-height: 90vh;">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-@(modoEdicion ? "pencil-square" : "plus-circle-fill") me-2"></i>
                                @(modoEdicion ? "Editar" : "Nueva") Tarifa de Energía
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                        </div>
                        <EditForm Model="tarifaActual" OnValidSubmit="GuardarTarifa">
                            <div class="modal-header bg-light border-bottom">
                                <div class="d-flex gap-2 w-100">
                                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal" disabled="@guardando">
                                        Cancelar
                                    </button>
                                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-save me-2"></i>
                                        }
                                        Guardar
                                    </button>
                                </div>
                            </div>
                            <div class="modal-body p-4" style="background-color: #e9ecef; max-height: calc(90vh - 140px); overflow-y: auto;">
                                <DataAnnotationsValidator />
                                
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Empresa <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.Empresa">
                                            <option value="">-- Selecciona una comercializadora --</option>
                                            @foreach (var comercializadora in comercializadoras)
                                            {
                                                <option value="@comercializadora.Nombre">@comercializadora.Nombre</option>
                                            }
                                        </InputSelect>
                                        <ValidationMessage For="() => tarifaActual.Empresa" class="text-danger" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Tipo Energía <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.Tipo">
                                            <option value="">-- Seleccionar tipo --</option>
                                            <option value="LUZ">LUZ</option>
                                            <option value="GAS">GAS</option>
                                            <option value="LUZ+GAS">LUZ+GAS</option>
                                        </InputSelect>
                                        <ValidationMessage For="() => tarifaActual.Tipo" class="text-danger" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Nombre <span class="text-danger">*</span></label>
                                        <InputText class="form-control" @bind-Value="tarifaActual.Nombre" placeholder="Ej: Tarifa Plana" />
                                        <ValidationMessage For="() => tarifaActual.Nombre" class="text-danger" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            <InputCheckbox class="form-check-input" @bind-Value="tarifaActual.Activa" id="switchActiva" style="cursor: pointer;" />
