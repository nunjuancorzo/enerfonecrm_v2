    private void CerrarModal()
    {
        mostrarModal = false;
        tarifaActual = new();
    }

    private async Task GuardarTarifa()
    {
        guardando = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            var (exito, mensaje) = modoEdicion
                ? await TarifaService.ActualizarAsync(tarifaActual)
                : await TarifaService.CrearAsync(tarifaActual);

            if (exito)
            {
                mensajeExito = mensaje;
                CerrarModal();
                await CargarTarifas();
            }
            else
            {
                mensajeError = mensaje;
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private void ConfirmarEliminar(TarifaEnergia tarifa)
    {
        tarifaAEliminar = tarifa;
        mostrarModalEliminar = true;
    }

    private async Task EliminarTarifa()
    {
        if (tarifaAEliminar == null) return;

        eliminando = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            var (exito, mensaje) = await TarifaService.EliminarAsync(tarifaAEliminar.Id);

            if (exito)
            {
                mensajeExito = mensaje;
                mostrarModalEliminar = false;
                await CargarTarifas();
            }
            else
            {
                mensajeError = mensaje;
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            eliminando = false;
            tarifaAEliminar = null;
            StateHasChanged();
        }
    }

    private async Task CambiarEstadoTarifa(TarifaEnergia tarifa)
    {
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            tarifa.Activa = !tarifa.Activa;
            var (exito, mensaje) = await TarifaService.ActualizarAsync(tarifa);

            if (exito)
            {
                mensajeExito = tarifa.Activa 
                    ? $"Tarifa '{tarifa.Nombre}' activada correctamente" 
                    : $"Tarifa '{tarifa.Nombre}' desactivada correctamente";
                await CargarTarifas();
            }
            else
            {
                // Revertir cambio si falla
                tarifa.Activa = !tarifa.Activa;
                mensajeError = mensaje;
            }
        }
        catch (Exception ex)
        {
            // Revertir cambio si hay error
            tarifa.Activa = !tarifa.Activa;
            mensajeError = $"Error al cambiar estado: {ex.Message}";
        }
        finally
        {
            StateHasChanged();
        }
    }

    private string ObtenerColorTipo(string tipo)
    {
        if (string.IsNullOrEmpty(tipo)) return "bg-secondary";
        
        var tipoLower = tipo.ToLower().Trim();
        
        return tipoLower switch
        {
            "pyme" => "bg-primary",
            "autonomo" => "bg-primary",
            "residencial" => "bg-success",
            _ => "bg-secondary"
        };
    }
