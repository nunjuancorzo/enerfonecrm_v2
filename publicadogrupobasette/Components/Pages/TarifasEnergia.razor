                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Días de Penalización</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.DiasPenalizacion" />
                                            <span class="input-group-text">días</span>
