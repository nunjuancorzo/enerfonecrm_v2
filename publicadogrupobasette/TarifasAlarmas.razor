@page "/tarifas/alarmas"
@using EnerfoneCRM.Models
@using EnerfoneCRM.Services
@rendermode InteractiveServer
@inject TarifaAlarmaService TarifaService
@inject EmpresaAlarmaService EmpresaAlarmaService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Enerfone CRM - Tarifas de Alarmas</PageTitle>

@if (cargandoSesion)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else
{
    @if (!AuthService.EstaAutenticado)
    {
        <div class="alert alert-warning m-4">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No tienes acceso a esta página. Por favor, inicia sesión.
        </div>
    }
    else if (AuthService.UsuarioActual?.Rol != "Administrador")
    {
        <div class="alert alert-danger m-4">
            <i class="bi bi-shield-exclamation me-2"></i>
            No tienes permisos para acceder a esta página. Solo los administradores pueden gestionar tarifas.
        </div>
    }
    else
    {
        <div class="container-fluid p-4">
            <div class="row mb-4">
                <div class="col-md-12">
                    <h2 class="mb-0">
                        <i class="bi bi-shield-check me-2 text-danger"></i>
                        Gestión de Tarifas de Alarmas
                    </h2>
                    <p class="text-muted">Administra las tarifas de alarmas para hogar y negocio</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(mensajeExito))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@mensajeExito
                    <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@mensajeError
                    <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                </div>
            }

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filtros</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Empresa</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownEmpresa" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (empresasSeleccionadas.Count == 0)
                                    {
                                        <span>Todas</span>
                                    }
                                    else if (empresasSeleccionadas.Count == 1)
                                    {
                                        <span>@empresasSeleccionadas.First()</span>
                                    }
                                    else
                                    {
                                        <span>@empresasSeleccionadas.Count seleccionadas</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownEmpresa" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="empresaTodas" @onchange="SeleccionarTodasEmpresas" checked="@(empresasSeleccionadas.Count == 0)">
                                            <label class="form-check-label w-100" for="empresaTodas" style="cursor: pointer;">
                                                <small><strong>Todas</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var empresa in empresasAlarmas)
                                    {
                                        var empId = $"emp_{empresa.Nombre.Replace(" ", "_")}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@empId" 
                                                       checked="@empresasSeleccionadas.Contains(empresa.Nombre)"
                                                       @onchange="() => ToggleEmpresa(empresa.Nombre)">
                                                <label class="form-check-label w-100" for="@empId" style="cursor: pointer;">
                                                    <small>@empresa.Nombre</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Tipo</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownTipo" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (tiposSeleccionados.Count == 0)
                                    {
                                        <span>Todos</span>
                                    }
                                    else if (tiposSeleccionados.Count == 1)
                                    {
                                        <span>@tiposSeleccionados.First()</span>
                                    }
                                    else
                                    {
                                        <span>@tiposSeleccionados.Count seleccionados</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownTipo" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="tipoTodos" @onchange="SeleccionarTodosTipos" checked="@(tiposSeleccionados.Count == 0)">
                                            <label class="form-check-label w-100" for="tipoTodos" style="cursor: pointer;">
                                                <small><strong>Todos</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var tipo in tiposDisponibles)
                                    {
                                        var tId = $"t_{tipo.Replace(" ", "_")}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@tId" 
                                                       checked="@tiposSeleccionados.Contains(tipo)"
                                                       @onchange="() => ToggleTipo(tipo)">
                                                <label class="form-check-label w-100" for="@tId" style="cursor: pointer;">
                                                    <small>@tipo</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Tipo Inmueble</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="dropdownInmueble" data-bs-toggle="dropdown" aria-expanded="false">
                                    @if (tiposInmuebleSeleccionados.Count == 0)
                                    {
                                        <span>Todos</span>
                                    }
                                    else if (tiposInmuebleSeleccionados.Count == 1)
                                    {
                                        <span>@tiposInmuebleSeleccionados.First()</span>
                                    }
                                    else
                                    {
                                        <span>@tiposInmuebleSeleccionados.Count seleccionados</span>
                                    }
                                </button>
                                <ul class="dropdown-menu p-2 bg-white" aria-labelledby="dropdownInmueble" style="max-height: 300px; overflow-y: auto; width: 100%;" @onclick:stopPropagation="true">
                                    <li class="px-2 py-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="inmuebleTodos" @onchange="SeleccionarTodosTiposInmueble" checked="@(tiposInmuebleSeleccionados.Count == 0)">
                                            <label class="form-check-label w-100" for="inmuebleTodos" style="cursor: pointer;">
                                                <small><strong>Todos</strong></small>
                                            </label>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    @foreach (var tipoInmueble in tiposInmuebleDisponibles)
                                    {
                                        var tiId = $"ti_{tipoInmueble}";
                                        <li class="px-2 py-1">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@tiId" 
                                                       checked="@tiposInmuebleSeleccionados.Contains(tipoInmueble)"
                                                       @onchange="() => ToggleTipoInmueble(tipoInmueble)">
                                                <label class="form-check-label w-100" for="@tiId" style="cursor: pointer;">
                                                    <small>@tipoInmueble</small>
                                                </label>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Estado</label>
                            <select @bind="filtroActiva" class="form-select">
                                <option value="">Todas</option>
                                <option value="activas">Activas</option>
                                <option value="inactivas">Inactivas</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Buscar</label>
                            <input type="text" @bind="textoBusqueda" class="form-control" placeholder="Nombre de tarifa..." />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 d-flex justify-content-end gap-2">
                            <button class="btn btn-primary" @onclick="AplicarFiltros">
                                <i class="bi bi-search me-1"></i>Filtrar
                            </button>
                            <button class="btn btn-secondary" @onclick="LimpiarFiltros">
                                <i class="bi bi-x-circle me-1"></i>Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Listado de Tarifas</h5>
                    <button class="btn btn-primary" @onclick="MostrarModalCrear">
                        <i class="bi bi-plus-circle me-2"></i>Nueva Tarifa
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (cargando)
                    {
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando tarifas...</span>
                            </div>
                            <p class="mt-3 text-muted">Cargando tarifas...</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Tipo")'>
                                            Tipo
                                            @if (columnaOrden == "Tipo")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("TipoInmueble")'>
                                            Inmueble
                                            @if (columnaOrden == "TipoInmueble")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("NombreTarifa")'>
                                            Nombre Tarifa
                                            @if (columnaOrden == "NombreTarifa")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>Empresa</th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("CuotaMensual")'>
                                            Cuota Mensual
                                            @if (columnaOrden == "CuotaMensual")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>Permanencia</th>
                                        <th style="cursor: pointer;" @onclick='() => OrdenarPor("Comision")'>
                                            Comisión
                                            @if (columnaOrden == "Comision")
                                            {
                                                <i class="bi bi-@(ordenAscendente ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>Estado</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (tarifas == null || !tarifas.Any())
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center text-muted py-4">
                                                <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                                                <p class="mb-0 mt-2">No hay tarifas registradas</p>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var tarifa in tarifasFiltradas)
                                        {
                                            <tr>
                                                <td><span class="badge @ObtenerColorTipo(tarifa.Tipo)">@tarifa.Tipo</span></td>
                                                <td><span class="badge bg-secondary">@tarifa.TipoInmueble</span></td>
                                                <td><strong>@tarifa.NombreTarifa</strong></td>
                                                <td>@tarifa.Empresa</td>
                                                <td><strong>@tarifa.CuotaMensual.ToString("N2")€</strong></td>
                                                <td><span class="badge bg-info">@tarifa.Permanencia meses</span></td>
                                                <td>@(tarifa.Comision?.ToString("N2") ?? "N/A")€</td>
                                                <td>
                                                    @if (tarifa.Activa)
                                                    {
                                                        <span class="badge bg-success">Activa</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Inactiva</span>
                                                    }
                                                </td>
                                                <td class="text-end" style="white-space: nowrap;">
                                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => MostrarModalEditar(tarifa)" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-info me-1" @onclick="() => MostrarModalDuplicar(tarifa)" title="Duplicar">
                                                        <i class="bi bi-files"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarEliminar(tarifa)" title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Paginación -->
                        @if (tarifas != null && tarifas.Any() && totalPaginas > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                                <div class="text-muted">
                                    Mostrando @((paginaActual - 1) * elementosPorPagina + 1) - @(Math.Min(paginaActual * elementosPorPagina, totalElementos)) de @totalElementos tarifas
                                </div>
                                <nav>
                                    <ul class="pagination mb-0">
                                        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(1)" disabled="@(paginaActual == 1)">
                                                <i class="bi bi-chevron-double-left"></i>
                                            </button>
                                        </li>
                                        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(paginaActual - 1)" disabled="@(paginaActual == 1)">
                                                <i class="bi bi-chevron-left"></i>
                                            </button>
                                        </li>
                                        @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
                                        {
                                            var pagina = i;
                                            <li class="page-item @(paginaActual == pagina ? "active" : "")">
                                                <button class="page-link" @onclick="() => CambiarPagina(pagina)">@pagina</button>
                                            </li>
                                        }
                                        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(paginaActual + 1)" disabled="@(paginaActual == totalPaginas)">
                                                <i class="bi bi-chevron-right"></i>
                                            </button>
                                        </li>
                                        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                            <button class="page-link" @onclick="() => CambiarPagina(totalPaginas)" disabled="@(paginaActual == totalPaginas)">
                                                <i class="bi bi-chevron-double-right"></i>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Modal Crear/Editar -->
        @if (mostrarModal)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg modal-dialog-scrollable" style="max-height: 90vh;">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-@(modoEdicion ? "pencil-square" : "plus-circle-fill") me-2"></i>
                                @(modoEdicion ? "Editar" : "Nueva") Tarifa de Alarma
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                        </div>
                        <EditForm Model="tarifaActual" OnValidSubmit="GuardarTarifa">
                            <div class="modal-header bg-light border-bottom">
                                <div class="d-flex gap-2 w-100">
                                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal" disabled="@guardando">
                                        Cancelar
                                    </button>
                                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                                        @if (guardando)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-save me-2"></i>
                                        }
                                        Guardar
                                    </button>
                                </div>
                            </div>
                            <div class="modal-body p-4" style="background-color: #e9ecef; max-height: calc(90vh - 140px); overflow-y: auto;">
                                <DataAnnotationsValidator />
                                
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Tipo <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.Tipo">
                                            <option value="">-- Seleccionar --</option>
                                            <option value="Kit">Kit</option>
                                            <option value="Opcional">Opcional</option>
                                            <option value="Campaña">Campaña</option>
                                        </InputSelect>
                                        <ValidationMessage For="() => tarifaActual.Tipo" class="text-danger" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Tipo Inmueble <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.TipoInmueble">
                                            <option value="">-- Seleccionar --</option>
                                            <option value="Hogar">Hogar</option>
                                            <option value="Negocio">Negocio</option>
                                        </InputSelect>
                                        <ValidationMessage For="() => tarifaActual.TipoInmueble" class="text-danger" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Nombre de Tarifa <span class="text-danger">*</span></label>
                                        <InputText class="form-control" @bind-Value="tarifaActual.NombreTarifa" placeholder="Ej: Kit Básico Hogar" />
                                        <ValidationMessage For="() => tarifaActual.NombreTarifa" class="text-danger" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Empresa</label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.Empresa">
                                            <option value="">-- Seleccionar empresa --</option>
                                            @foreach (var empresa in empresasAlarmas)
                                            {
                                                <option value="@empresa.Nombre">@empresa.Nombre</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>

                                <hr class="my-4" />

                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Cuota Mensual (€) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.CuotaMensual" step="0.01" />
                                            <span class="input-group-text">€/mes</span>
                                        </div>
                                        <ValidationMessage For="() => tarifaActual.CuotaMensual" class="text-danger" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Permanencia (meses) <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="tarifaActual.Permanencia">
                                            <option value="0">-- Seleccionar --</option>
                                            <option value="12">12 meses</option>
                                            <option value="24">24 meses</option>
                                            <option value="36">36 meses</option>
                                        </InputSelect>
                                        <ValidationMessage For="() => tarifaActual.Permanencia" class="text-danger" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Comisión (€)</label>
                                        <div class="input-group">
                                            <InputNumber class="form-control" @bind-Value="tarifaActual.Comision" step="0.01" />
                                            <span class="input-group-text">€</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">Descripción</label>
                                        <InputTextArea class="form-control" @bind-Value="tarifaActual.Descripcion" rows="3" placeholder="Descripción adicional de la tarifa..." />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" id="activa" @bind-Value="tarifaActual.Activa" />
                                            <label class="form-check-label" for="activa">
                                                Tarifa Activa
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }

        <!-- Modal Confirmar Eliminación -->
        @if (mostrarModalEliminar)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar Eliminación
                            </h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalEliminar = false"></button>
                        </div>
                        <div class="modal-body p-4">
                            <p class="mb-3">¿Estás seguro de que deseas eliminar esta tarifa?</p>
                            <div class="alert alert-warning mb-0">
                                <strong><i class="bi bi-shield-check me-2"></i>@tarifaAEliminar?.NombreTarifa</strong>
                                <p class="mb-0 mt-2">
                                    <small>@tarifaAEliminar?.Tipo - @tarifaAEliminar?.TipoInmueble - @tarifaAEliminar?.CuotaMensual.ToString("N2")€/mes</small>
                                </p>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="() => mostrarModalEliminar = false">
                                <i class="bi bi-x-circle me-2"></i>Cancelar
                            </button>
                            <button type="button" class="btn btn-danger" @onclick="EliminarTarifa" disabled="@guardando">
                                @if (guardando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Eliminando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-trash me-2"></i>
                                    <span>Eliminar</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private List<TarifaAlarma> tarifas = new();
    private List<TarifaAlarma> tarifasFiltradas = new();
    private TarifaAlarma tarifaActual = new();
    private TarifaAlarma? tarifaAEliminar;
    private List<EmpresaAlarma> empresasAlarmas = new();
    
    // Ordenamiento
    private string columnaOrden = "NombreTarifa";
    private bool ordenAscendente = true;
    
    // Paginación
    private int paginaActual = 1;
    private int elementosPorPagina = 10;
    private int totalElementos = 0;
    private int totalPaginas = 0;
    
    // Filtros
    private HashSet<string> empresasSeleccionadas = new();
    private HashSet<string> tiposSeleccionados = new();
    private HashSet<string> tiposInmuebleSeleccionados = new();
    private string textoBusqueda = string.Empty;
    private string filtroActiva = string.Empty;
    
    private List<string> tiposDisponibles = new() { "Kit", "Opcional", "Campaña" };
    private List<string> tiposInmuebleDisponibles = new() { "Hogar", "Negocio" };
    private List<TarifaAlarma> tarifasParaPaginar = new();
    
    private bool cargandoSesion = true;
    private bool cargando = false;
    private bool guardando = false;
    private bool mostrarModal = false;
    private bool mostrarModalEliminar = false;
    private bool modoEdicion = false;
    
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.CargarSesionAsync();
            cargandoSesion = false;
            StateHasChanged();
            
            if (AuthService.EstaAutenticado)
            {
                await CargarEmpresasAlarmas();
                await CargarTarifas();
            }
        }
    }

    private async Task CargarEmpresasAlarmas()
    {
        try
        {
            empresasAlarmas = await EmpresaAlarmaService.ObtenerActivasAsync();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar empresas de alarmas: {ex.Message}";
        }
    }

    private async Task CargarTarifas()
    {
        cargando = true;
        StateHasChanged();
        
        try
        {
            tarifas = await TarifaService.ObtenerTodasAsync();
            AplicarFiltros();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar tarifas: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void OrdenarPor(string columna)
    {
        paginaActual = 1;
        if (columnaOrden == columna)
        {
            ordenAscendente = !ordenAscendente;
        }
        else
        {
            columnaOrden = columna;
            ordenAscendente = true;
        }
        
        AplicarOrdenamiento();
    }

    private void AplicarOrdenamiento()
    {
        var tarifasOrdenadas = columnaOrden switch
        {
            "Tipo" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Tipo).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Tipo).ToList(),
            "TipoInmueble" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.TipoInmueble).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.TipoInmueble).ToList(),
            "NombreTarifa" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.NombreTarifa).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.NombreTarifa).ToList(),
            "CuotaMensual" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.CuotaMensual).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.CuotaMensual).ToList(),
            "Comision" => ordenAscendente
                ? tarifasParaPaginar.OrderBy(t => t.Comision).ToList()
                : tarifasParaPaginar.OrderByDescending(t => t.Comision).ToList(),
            _ => tarifasParaPaginar
        };
        
        totalElementos = tarifasOrdenadas.Count;
        totalPaginas = (int)Math.Ceiling((double)totalElementos / elementosPorPagina);
        
        tarifasFiltradas = tarifasOrdenadas
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina)
            .ToList();
        
        StateHasChanged();
    }
    
    private void AplicarFiltros()
    {
        var listaTemp = tarifas.ToList();

        // Filtrar por empresas
        if (empresasSeleccionadas.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                t.Empresa != null && 
                empresasSeleccionadas.Contains(t.Empresa)
            ).ToList();
        }

        // Filtrar por tipos
        if (tiposSeleccionados.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                tiposSeleccionados.Contains(t.Tipo)
            ).ToList();
        }

        // Filtrar por tipos de inmueble
        if (tiposInmuebleSeleccionados.Count > 0)
        {
            listaTemp = listaTemp.Where(t => 
                tiposInmuebleSeleccionados.Contains(t.TipoInmueble)
            ).ToList();
        }

        // Filtrar por estado activa
        if (!string.IsNullOrEmpty(filtroActiva))
        {
            if (filtroActiva == "activas")
            {
                listaTemp = listaTemp.Where(t => t.Activa).ToList();
            }
            else if (filtroActiva == "inactivas")
            {
                listaTemp = listaTemp.Where(t => !t.Activa).ToList();
            }
        }

        // Filtrar por búsqueda de texto
        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            listaTemp = listaTemp.Where(t =>
                (t.NombreTarifa != null && t.NombreTarifa.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (t.Descripcion != null && t.Descripcion.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase))
            ).ToList();
        }

        tarifasParaPaginar = listaTemp;
        paginaActual = 1;
        AplicarOrdenamiento();
    }

    private void LimpiarFiltros()
    {
        empresasSeleccionadas.Clear();
        tiposSeleccionados.Clear();
        tiposInmuebleSeleccionados.Clear();
        textoBusqueda = string.Empty;
        filtroActiva = string.Empty;
        AplicarFiltros();
    }

    private void ToggleEmpresa(string empresa)
    {
        if (empresasSeleccionadas.Contains(empresa))
        {
            empresasSeleccionadas.Remove(empresa);
        }
        else
        {
            empresasSeleccionadas.Add(empresa);
        }
    }

    private void SeleccionarTodasEmpresas()
    {
        empresasSeleccionadas.Clear();
    }

    private void ToggleTipo(string tipo)
    {
        if (tiposSeleccionados.Contains(tipo))
        {
            tiposSeleccionados.Remove(tipo);
        }
        else
        {
            tiposSeleccionados.Add(tipo);
        }
    }

    private void SeleccionarTodosTipos()
    {
        tiposSeleccionados.Clear();
    }

    private void ToggleTipoInmueble(string tipoInmueble)
    {
        if (tiposInmuebleSeleccionados.Contains(tipoInmueble))
        {
            tiposInmuebleSeleccionados.Remove(tipoInmueble);
        }
        else
        {
            tiposInmuebleSeleccionados.Add(tipoInmueble);
        }
    }

    private void SeleccionarTodosTiposInmueble()
    {
        tiposInmuebleSeleccionados.Clear();
    }
    
    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= totalPaginas)
        {
            paginaActual = nuevaPagina;
            AplicarOrdenamiento();
        }
    }

    private void MostrarModalCrear()
    {
        tarifaActual = new TarifaAlarma { Activa = true };
        modoEdicion = false;
        mostrarModal = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void MostrarModalEditar(TarifaAlarma tarifa)
    {
        tarifaActual = new TarifaAlarma
        {
            Id = tarifa.Id,
            Tipo = tarifa.Tipo,
            TipoInmueble = tarifa.TipoInmueble,
            NombreTarifa = tarifa.NombreTarifa,
            CuotaMensual = tarifa.CuotaMensual,
            Permanencia = tarifa.Permanencia,
            Empresa = tarifa.Empresa,
            Comision = tarifa.Comision,
            Descripcion = tarifa.Descripcion,
            Activa = tarifa.Activa
        };
        modoEdicion = true;
        mostrarModal = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void MostrarModalDuplicar(TarifaAlarma tarifa)
    {
        tarifaActual = new TarifaAlarma
        {
            Tipo = tarifa.Tipo,
            TipoInmueble = tarifa.TipoInmueble,
            NombreTarifa = tarifa.NombreTarifa + " (Copia)",
            CuotaMensual = tarifa.CuotaMensual,
            Permanencia = tarifa.Permanencia,
            Empresa = tarifa.Empresa,
            Comision = tarifa.Comision,
            Descripcion = tarifa.Descripcion,
            Activa = tarifa.Activa
        };
        modoEdicion = false;
        mostrarModal = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        tarifaActual = new();
    }

    private async Task GuardarTarifa()
    {
        guardando = true;
        StateHasChanged();
        
        try
        {
            var (exito, mensaje) = modoEdicion 
                ? await TarifaService.ActualizarAsync(tarifaActual)
                : await TarifaService.CrearAsync(tarifaActual);

            if (exito)
            {
                mensajeExito = mensaje;
                CerrarModal();
                await CargarTarifas();
            }
            else
            {
                mensajeError = mensaje;
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private void ConfirmarEliminar(TarifaAlarma tarifa)
    {
        tarifaAEliminar = tarifa;
        mostrarModalEliminar = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
    }

    private async Task EliminarTarifa()
    {
        if (tarifaAEliminar == null) return;

        guardando = true;
        StateHasChanged();

        try
        {
            var (exito, mensaje) = await TarifaService.EliminarAsync(tarifaAEliminar.Id);
            
            if (exito)
            {
                mensajeExito = mensaje;
                mostrarModalEliminar = false;
                await CargarTarifas();
            }
            else
            {
                mensajeError = mensaje;
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private string ObtenerColorTipo(string tipo)
    {
        return tipo switch
        {
            "Kit" => "bg-primary",
            "Opcional" => "bg-success",
            "Campaña" => "bg-warning",
            _ => "bg-secondary"
        };
    }
}
